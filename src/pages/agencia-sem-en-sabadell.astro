---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildAlternates } from '../lib/i18n';
import { strapiClient } from '../lib/strapi';
import LogoMarquee from '../components/sections/LogoMarquee.astro';
import FaqHome from '../components/sections/FaqHome.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-sem-en-sabadell', '/ca/agencia-sem-a-sabadell', SITE_URL);

let pageCases: any[] = [];
try {
  const res = await strapiClient.getCaseStudies('es');
  pageCases = res.data.map((i: any) => i.attributes ?? i).filter((c: any) => {
    const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
    return cats.some((s: string) => s.includes('google-ads') || s.includes('ads'));
  });
} catch {}

const faqItems = [
  {
    question: "¿Google Ads puede ayudar a mi empresa del polígon industrial de Sabadell a conseguir más clientes B2B?",
    answer: "Sí. Las empresas de los polígons industrials de Can Feu, Polígon de Ribatallada o del Vallès Occidental tienen un gran potencial con Google Ads B2B. Sus clientes también buscan proveedores en Google. Diseñamos campañas orientadas a palabras clave de alta intención de compra industrial que generan presupuestos y contratos, no solo clics."
  },
  {
    question: "¿Cuánto tengo que invertir en Google Ads para que mi tienda del centro de Sabadell capte resultados?",
    answer: "En Sabadell, con un nivel de competencia medio, los primeros resultados pueden verse con inversiones desde 300-500€/mes bien gestionados. Lo importante no es el volumen total, sino la optimización. En Nova exprimimos cada euro para que tu negocio en la Rambla o el centro comercial consiga el mayor número de clientes potenciales posible."
  },
  {
    question: "¿Cuánto tiempo tarda mi empresa de Sabadell en aparecer en Google con los anuncios?",
    answer: "A diferencia del SEO, Google Ads es casi inmediato. Una vez configuramos tu campaña, tu empresa de Sabadell puede empezar a aparecer en Google en cuestión de horas. Ideal para negocios locales que necesitan clientes ahora mismo."
  },
  {
    question: "¿Mis anuncios pueden aparecer en Google Maps para atraer clientes al local de Sabadell?",
    answer: "Sí. Configuramos campañas locales para que tu negocio en el centro de Sabadell, en la Rambla o en cualquier barrio de la ciudad aparezca en Google Maps cuando alguien busca tu servicio cerca. Es especialmente efectivo para restaurantes, clínicas, tiendas y servicios de proximidad."
  },
  {
    question: "¿Por qué contratar una agencia de Google Ads en Sabadell y no gestionar yo mismo los anuncios?",
    answer: "Google Ads es una plataforma potente pero compleja. Sin experiencia, es fácil malgastar el presupuesto en clics que no convierten. En Nova conocemos el mercado del Vallès Occidental, los sectores punteros de Sabadell y cómo segmentar correctamente para que cada euro trabaje para tu negocio."
  }
];

const steps = [
  { title: "Estudio de Keywords en Sabadell", desc: "Analizamos las búsquedas con mayor intención de compra en Sabadell y el Vallès Occidental. Identificamos qué buscan los clientes en Can Feu, Creu Alta y el centro comercial para atraer visitas que compran." },
  { title: "Optimización de Landings", desc: "Adaptamos las páginas de destino de tu web para que los sabadellenses que llegan desde los anuncios encuentren exactamente lo que buscaban, aumentando la tasa de conversión." },
  { title: "Creación de Anuncios Locales", desc: "Redactamos anuncios que hablan el idioma del cliente local del Vallès, con mensajes que resuenan tanto para comercios del Mercat Central como para industrias de los polígons de Sabadell." },
  { title: "Test A/B y Optimización Continua", desc: "Probamos continuamente distintas versiones de anuncios y páginas de aterrizaje para bajar el CPC y elevar la rentabilidad de cada euro invertido en publicidad en Sabadell." }
];
---

<BaseLayout
  title="Agencia Google Ads en Sabadell | Nova Marketing"
  description="Gestión de campañas de Google Ads para empresas de Sabadell. Rentabiliza tu inversión publicitaria en el Vallès Occidental desde el primer día. Auditoría gratuita."
  locale="es"
  alternates={alternates}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="min-h-[88vh] flex items-center justify-center pt-24 pb-16 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-7xl mx-auto reveal relative z-10">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-6 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Especialistas en Google Ads en Sabadell
            </span>

            <h1 class="text-4xl sm:text-6xl md:text-7xl lg:text-[5.5rem] uppercase font-black tracking-tighter leading-[0.82] mb-8 text-zinc-900 flex flex-col items-center text-center">
                <span>Agencia de</span>
                <span>Google Ads</span>
                <span class="text-mktg-gradient px-4 overflow-visible inline-block">en Sabadell</span>
            </h1>

            <p class="text-base sm:text-lg text-zinc-500 font-light leading-relaxed max-w-2xl mx-auto mb-12">
                Rentabilizamos tu inversión en Google Ads para empresas de Sabadell desde el primer día. Desde las empresas del centro y la Rambla hasta los polígons industrials de Can Feu, diseñamos campañas que captan clientes con intención de compra real.
            </p>

            <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
                <button class="contact-modal-trigger btn-mktg-v5 shadow-[0_20px_40px_-10px_rgba(0,0,0,0.15)] hover:shadow-[0_25px_50px_-12px_rgba(0,0,0,0.25)] hover:-translate-y-1 transition-all duration-300 !py-5 !px-12 !text-[12px] !tracking-wider font-black w-full sm:w-auto">
                    SOLICITAR AUDITORÍA GRATIS
                </button>
            </div>
        </div>
    </section>

    <!-- ═══ LOGOS CLIENTES (SOCIAL PROOF) ══════════════════════════════════ -->
    <LogoMarquee />

    <!-- ═══ SECCIÓN 1: DOMINIO TOTAL ═════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6 relative overflow-hidden">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808005_1px,transparent_1px),linear-gradient(to_bottom,#80808005_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_50%,#000_80%,transparent_100%)]"></div>

        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <h2 class="text-3xl sm:text-5xl lg:text-7xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.82]">
                    Dominio Total de <br class="hidden sm:inline" /> Google Ads en Sabadell
                </h2>
                <p class="text-zinc-500 font-light text-base sm:text-lg leading-relaxed max-w-2xl mx-auto">
                    No experimentamos con el presupuesto de empresas de Sabadell. Diseñamos campañas quirúrgicas que impactan en el cliente ideal del Vallès cuando está listo para comprar.
                </p>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 items-stretch">
                {[
                    { title: "Auditoría de Cuenta Sabadell", desc: "Analizamos tu historial publicitario detectando fugas de presupuesto habituales en el mercado del Vallès Occidental, con especial atención a sectores como la industria de Can Feu y el comercio del centro." },
                    { title: "Keyword Research SEM", desc: "Seleccionamos las búsquedas con mayor intención de compra en Sabadell: desde servicios locales en la Rambla hasta empresas B2B de los polígons industrials del Vallès." },
                    { title: "Anuncios de Impacto", desc: "Redactamos textos que conectan con el cliente sabadellense, haciendo referencia a su entorno local para aumentar el CTR y mejorar el nivel de calidad de las campañas." },
                    { title: "Optimización de Puja", desc: "Ajustamos las pujas para que tu empresa de Sabadell pague lo mínimo por cada cliente captado, priorizando las búsquedas con mayor tasa de conversión en el mercado local." }
                ].map((s, i) => (
                    <div class="group flex flex-col justify-between p-8 sm:p-10 h-full bg-white rounded-3xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden reveal flex-1">
                        <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
                        <div class="absolute -bottom-6 -right-4 text-9xl font-black text-black/2 group-hover:text-accent/[0.04] transition-all duration-500 select-none">
                            0{i + 1}
                        </div>
                        <div class="relative z-10 flex flex-col h-full justify-between">
                            <div>
                                <div class="p-3 bg-zinc-50 border border-black/5 w-fit rounded-xl mb-6 group-hover:bg-accent/5 transition-colors">
                                    <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                                </div>
                                <h3 class="text-xl sm:text-2xl uppercase mb-3 tracking-tighter group-hover:text-accent font-black text-zinc-900 border-b border-zinc-100 pb-2 w-fit">{s.title}</h3>
                                <p class="text-xs sm:text-sm text-zinc-500 leading-relaxed font-light">{s.desc}</p>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ═══ SECCIÓN 2: TIMELINE ═══════════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <h2 class="text-2xl sm:text-5xl lg:text-7xl font-black tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.85]">
                    Cómo trabajamos la publicidad en Google en Sabadell
                </h2>
                <div class="text-zinc-500 w-[75%] mx-auto font-light text-sm sm:text-base leading-relaxed space-y-4">
                    <p>
                        Olvídate de las campañas en piloto automático. Contarás con un <strong>Account Manager dedicado</strong> que trabajará de la mano con tu equipo en Sabadell para supervisar avances y mantenerte informado con métricas reales de negocio.
                    </p>
                </div>
            </div>

            <div id="timeline-container" class="relative timeline-container">
                <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
                <div class="progress-bar hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100" style="height: 0%;"></div>

                <div class="space-y-16 md:space-y-24 flex flex-col items-center">
                    {steps.map((step, index) => (
                        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal" style={`transition-delay: ${index * 100}ms`}>
                            <div class="hidden md:block md:flex-1 text-right md:order-1">
                                {index % 2 === 0 && (
                                    <div class="md:pr-12">
                                        <h3 class="text-xl sm:text-2xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{step.title}</h3>
                                        <p class="text-sm text-zinc-500 font-light max-w-md ml-auto">{step.desc}</p>
                                    </div>
                                )}
                            </div>
                            <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all duration-300">
                                0{index + 1}
                            </div>
                            <div class="flex-1 text-left md:order-3">
                                <div class="md:pl-12">
                                    <h3 class:list={["text-xl sm:text-2xl font-black uppercase tracking-tighter mb-2 text-zinc-900", index % 2 === 0 ? "md:hidden" : ""]}>{step.title}</h3>
                                    <p class:list={["text-sm text-zinc-500 font-light max-w-md mr-auto", index % 2 === 0 ? "md:hidden" : ""]}>{step.desc}</p>
                                </div>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <style>
        .timeline-container .reveal { opacity: 0; transform: translateY(20px); transition: all 0.6s cubic-bezier(0.165, 0.84, 0.44, 1); }
        .timeline-container .reveal.active { opacity: 1; transform: translateY(0); }
    </style>

    <script is:inline>
        function initTimeline() {
            const timeline = document.getElementById('timeline-container');
            const progressBar = timeline?.querySelector('.progress-bar');
            function updateProgress() {
                if (!timeline || !progressBar) return;
                const rect = timeline.getBoundingClientRect();
                const winHeight = window.innerHeight;
                const topPassed = (winHeight / 2) - rect.top;
                let percentage = (topPassed / rect.height) * 100;
                percentage = Math.max(0, Math.min(100, percentage));
                progressBar.style.height = `${percentage}%`;
                const nodes = timeline.querySelectorAll('.node-circle');
                nodes.forEach((node) => {
                    const nodeTop = node.getBoundingClientRect().top;
                    if (nodeTop < winHeight / 2) { node.classList.add('!border-accent', '!bg-accent', '!text-white'); }
                    else { node.classList.remove('!border-accent', '!bg-accent', '!text-white'); }
                });
            }
            window.addEventListener('scroll', updateProgress);
            document.addEventListener('astro:page-load', updateProgress);
            updateProgress();
        }
        document.addEventListener('DOMContentLoaded', initTimeline);
        document.addEventListener('astro:page-load', initTimeline);
    </script>

    <!-- ═══ CASOS DE ÉXITO GOOGLE ADS ════════════════════════════════════ -->
    {pageCases.length > 0 && (
    <section class="py-20 sm:py-32 bg-zinc-50 border-t border-black/5 px-4 sm:px-6">
        <div class="max-w-7xl mx-auto">
            <div class="mb-16 reveal">
                <span class="text-[10px] font-black uppercase tracking-[0.3em] text-accent mb-4 block">Resultados probados</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl uppercase tracking-tighter font-extrabold text-zinc-900 leading-[0.9]">
                    Casos de éxito de Google Ads<br class="hidden md:inline" /> en Sabadell
                </h2>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                {pageCases.map((cs: any, i: number) => {
                  const catName = (cs.categories || []).map((c: any) => c.name || c.attributes?.name).filter(Boolean).join(' | ');
                  const caseUrl = cs.isPublic && cs.slug ? `/casos-exito/${cs.slug}/` : null;
                  return (
                    <div class="bg-white p-8 border border-black/5 flex flex-col justify-between group hover:shadow-xl hover:-translate-y-1 transition-all duration-300 rounded-2xl reveal" style={`transition-delay: ${i * 80}ms`}>
                      <div>
                        {catName && <span class="text-[10px] font-black uppercase tracking-widest text-accent mb-4 block">{catName}</span>}
                        <h3 class="text-base font-black uppercase tracking-tight text-zinc-900 mb-3 group-hover:text-accent transition-colors leading-tight">{cs.title}</h3>
                        <p class="text-xs text-zinc-500 font-light leading-relaxed">{cs.description}</p>
                      </div>
                      {caseUrl && (
                        <a href={caseUrl} class="mt-6 text-[9px] font-black tracking-[0.25em] text-accent flex items-center gap-1.5 hover:gap-3 transition-all uppercase">
                          VER MÁS <span class="text-sm">→</span>
                        </a>
                      )}
                    </div>
                  );
                })}
            </div>
        </div>
    </section>
    )}

    <!-- ═══ FAQ ════════════════════════════════════════════════════════════ -->
    <FaqHome
        items={faqItems}
        title="Preguntas sobre Google Ads en Sabadell<br/>que nos hacen otras pymes"
    />

</BaseLayout>
