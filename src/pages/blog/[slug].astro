---
/**
 * pages/blog/[slug].astro
 * Artículo individual del blog con diseño Cinematic Hero
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageBlocks from '../../components/blocks/PageBlocks.astro';
import AuthorCard from '../../components/blog/AuthorCard.astro';
import BlogCard from '../../components/blog/BlogCard.astro';
import { strapiClient } from '../../lib/strapi';
import { buildAlternates } from '../../lib/i18n';
import { articleSchema } from '../../lib/schema';
import type { BlogPost, Author } from '../../lib/strapi';
import { getStrapiImageUrl } from '../../lib/strapi';

export async function getStaticPaths() {
  try {
    const [resEs, resCa] = await Promise.all([
      strapiClient.getBlogPosts('es'),
      strapiClient.getBlogPosts('ca'),
    ]);

    // Mapa documentId → slug CA
    const caSlugMap: Record<string, string> = {};
    for (const item of resCa.data) {
      const p = item.attributes ?? item;
      if (item.documentId) caSlugMap[item.documentId] = p.slug;
    }

    return resEs.data.map((item: any) => {
      const post: BlogPost = item.attributes ?? item;
      const caSlug = (item.documentId && caSlugMap[item.documentId]) || post.slug;
      return {
        params: { slug: post.slug },
        props: { post, caSlug },
      };
    });
  } catch {
    return [];
  }
}

const { post: initialPost, caSlug }: { post: BlogPost; caSlug: string } = Astro.props;

// Fetch detallado para obtener page_blocks con deep populate (getBlogPosts usa populate=* superficial)
let post: BlogPost = initialPost;
try {
  const detailRes = await strapiClient.getBlogPost(initialPost.slug, 'es');
  post = detailRes.data[0]?.attributes ?? detailRes.data[0] ?? initialPost;
} catch {}

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const canonicalPath = `/blog/${post.slug}`;
const canonicalUrl = `${SITE_URL}${canonicalPath}`;
const alternates = buildAlternates(canonicalPath, `/ca/blog/${caSlug}`, SITE_URL);

const schemas: object[] = [];

function formatDate(dateStr?: string) {
  if (!dateStr) return '';
  return new Date(dateStr).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' });
}

const coverUrl = getStrapiImageUrl(post.featuredImage ?? (post as any).cover_image) || '/og-default.jpg';

// Fetch author con foto (populate=* en /api/articles no popula campos anidados del autor)
let author: Author | undefined = post.author;
if (author) {
  try {
    const authorsRes = await strapiClient.getAuthors();
    const found = (authorsRes.data ?? []).find((a: any) => {
      const d = a.attributes ?? a;
      return d.name === author!.name || a.id === author!.id;
    });
    if (found) author = found.attributes ?? found;
  } catch {}
}

// Sidebar: últimos artículos (sin filtrar el actual para que siempre haya resultados)
let latestPosts: any[] = [];
try {
  const postsRes = await strapiClient.getBlogPosts('es', { limit: 5 });
  latestPosts = (postsRes.data ?? []).map((i: any) => i.attributes ?? i);
} catch {}

// CTA dinámico según categoría
const categoryName = ((post.category?.name || (post as any).categories?.[0]?.name || '') as string).toLowerCase();
const ctaTitle = categoryName.includes('seo') || categoryName.includes('consultor')
  ? 'Auditoría SEO para tu web'
  : categoryName.includes('ads') || categoryName.includes('google')
  ? 'Auditoría de tu cuenta de Google Ads'
  : categoryName.includes('diseño') || categoryName.includes('diseno') || categoryName.includes('web')
  ? 'Presentación de diseño funcional para tu web'
  : 'Auditoría para tu web';
---

<BaseLayout
  title={post.seo?.metaTitle || post.title}
  description={post.metadescription || post.seo?.metaDescription || post.excerpt || ''}
  canonical={canonicalUrl}
  locale="es"
  alternates={alternates}
  schemas={schemas}
>
  <!-- Cinematic Hero -->
  <header class="relative min-h-[75vh] flex items-end pb-24 px-6 sm:px-12 overflow-hidden bg-black">
    <!-- background image -->
    <div class="absolute inset-0 z-0 opacity-60">
        <img 
          src={coverUrl} 
          alt={post.title} 
          class="w-full h-full object-cover scale-105"
        />
        <!-- Vignette & Gradient Overlay -->
        <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent"></div>
    </div>

    <div class="max-w-5xl mx-auto w-full relative z-10 animate-reveal">
      <div class="flex flex-wrap items-center gap-4 mb-8">
        <a href="/blog" class="text-white/60 hover:text-white text-[10px] font-black uppercase tracking-[0.3em] flex items-center gap-2 transition-colors">
            ← VOLVER AL BLOG
        </a>
        <span class="w-1 h-1 bg-white/30 rounded-full"></span>
        {post.category && (
          <span class="px-3 py-1 text-[10px] tracking-widest font-black uppercase bg-accent text-white rounded-lg">
            {post.category.name.toUpperCase()}
          </span>
        )}
        <span class="text-white/60 text-[10px] font-black tracking-widest uppercase">
            {(post.publishedDate || post.publishedAt) && formatDate(post.publishedDate || post.publishedAt).toUpperCase()}
        </span>
      </div>
      
      <h1 class="text-5xl md:text-8xl font-black mb-12 leading-[0.95] tracking-tighter text-white max-w-5xl">
        {post.title}
      </h1>
      
      <div class="flex flex-wrap items-center justify-between gap-8 border-t border-white/10 pt-10">
          {author && (
            <div class="flex items-center gap-4">
                {author.photo && (
                    <img
                        src={author.photo?.formats?.small?.url
                          ? (author.photo.formats.small.url.startsWith('http') ? author.photo.formats.small.url : `${import.meta.env.STRAPI_URL || 'http://localhost:1337'}${author.photo.formats.small.url}`)
                          : getStrapiImageUrl(author.photo)}
                        alt={author.name}
                        class="w-16 h-16 rounded-full border-2 border-white/20 object-cover"
                    />
                )}
                <div>
                   <div class="text-white font-bold text-lg leading-none mb-1">{author.name}</div>
                   <div class="text-white/40 text-[10px] font-black uppercase tracking-widest">{author.job_title || 'Equipo Nova'}</div>
                </div>
            </div>
          )}
          
          <div class="flex items-center gap-4">
               <button
                 id="share-btn"
                 data-title={post.title}
                 data-url={canonicalUrl}
                 class="px-6 py-3 rounded-xl bg-white/5 border border-white/10 text-white text-[10px] font-black tracking-widest uppercase hover:bg-white/10 transition-colors"
               >
                COMPARTIR
               </button>
          </div>
      </div>
    </div>
  </header>

  <main class="py-24 px-6 sm:px-12 bg-white relative">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-[1fr_340px] gap-20">

      <!-- Contenido Principal -->
      <article class="max-w-none">
        {post.excerpt && (
            <p class="text-2xl font-light text-zinc-500 italic border-l-4 border-accent pl-8 mb-16 leading-relaxed">
                {post.excerpt}
            </p>
        )}

        {post.page_blocks?.length > 0
          ? <PageBlocks blocks={post.page_blocks} />
          : <p class="text-zinc-500 italic">Contenido no disponible.</p>
        }

        <!-- CTA inline -->
        <div class="reveal mt-16 mb-8 relative group overflow-hidden p-8 sm:p-14 rounded-[3rem] bg-zinc-950 border border-white/10 transition-all duration-700 hover:border-accent/40 hover:shadow-[0_0_80px_-20px_rgba(59,130,246,0.3)]">
          <div class="absolute -top-24 -right-24 w-80 h-80 bg-accent/20 rounded-full blur-[100px] group-hover:bg-accent/30 transition-all duration-1000"></div>
          <div class="absolute -bottom-24 -left-24 w-80 h-80 bg-purple-600/10 rounded-full blur-[100px] group-hover:bg-purple-600/20 transition-all duration-1000"></div>
          <div class="relative z-10 flex flex-col items-center text-center gap-6 md:gap-10">
            <div class="w-full">
              <div class="text-xl sm:text-2xl md:text-3xl lg:text-4xl font-black text-white mb-4 leading-none tracking-tighter uppercase transition-transform duration-500 group-hover:scale-[1.01]">
                ¿Quieres que tu empresa <span class="text-mktg-gradient">empiece a crecer</span>?
              </div>
              <p class="text-white/60 font-light text-base md:text-lg max-w-2xl mx-auto">
                Cuéntanos qué tienes en mente y qué necesidades tienes. Nosotros nos encargamos del resto.
              </p>
            </div>
            <div class="mt-4">
              <button class="contact-modal-trigger relative group/btn flex items-center gap-6 px-14 py-7 bg-accent text-white rounded-3xl font-black uppercase tracking-widest text-[13px] overflow-hidden transition-all duration-500 hover:scale-105 hover:bg-white hover:text-black shadow-[0_20px_60px_rgba(59,130,246,0.3)] hover:shadow-[0_30px_80px_rgba(255,255,255,0.2)]">
                <span class="relative z-10">Empezar Proyecto</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="relative z-10 transition-transform duration-500 group-hover/btn:translate-x-3"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </button>
            </div>
          </div>
        </div>

        {author && <AuthorCard author={author} locale="es" />}
      </article>

      <!-- Sidebar -->
      <aside>
        <div class="sticky top-32 flex flex-col gap-6">
          <!-- CTA dinámico -->
          <div class="bg-black p-8 rounded-[2rem] text-white">
            <span class="inline-block px-3 py-1 bg-accent text-[9px] font-black tracking-widest rounded-full mb-5">AUDITORÍA GRATUITA</span>
            <div class="text-2xl font-black mb-3 leading-tight uppercase">{ctaTitle}</div>
            <p class="text-white/50 font-light mb-7 text-sm leading-relaxed">Analizamos 5 puntos clave de tu web que empieces a facturar más.</p>
            <button class="contact-modal-trigger block w-full text-center py-4 bg-white text-black text-[10px] font-black tracking-widest rounded-xl hover:bg-accent hover:text-white transition-all cursor-pointer">
              SOLICITAR AHORA
            </button>
          </div>

          <!-- Servicios de marketing -->
          <div class="rounded-[2rem] border border-zinc-100 bg-zinc-50 p-8">
            <div class="text-[10px] font-black tracking-[0.25em] uppercase text-zinc-400 mb-5">Servicios de marketing</div>
            <ul class="flex flex-col gap-0">
              {[
                { label: 'Posicionamiento SEO', href: '/agencia-seo-para-pymes/' },
                { label: 'Google Ads', href: '/agencia-sem-para-pymes/' },
                { label: 'Diseño de páginas web', href: '/diseno-web-para-pymes/' },
                { label: 'Consultoría de marketing', href: '/consultoria-marketing-para-pymes/' },
              ].map(s => (
                <li class="border-b border-zinc-200 last:border-0">
                  <a href={s.href} class="group flex items-center justify-between py-3">
                    <span class="text-sm font-bold text-zinc-700 group-hover:text-accent transition-colors uppercase tracking-tight">{s.label}</span>
                    <span class="text-accent text-base font-black translate-x-0 group-hover:translate-x-1 transition-transform">→</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </aside>

    </div>
  </main>

  <!-- Más noticias de marketing -->
  {latestPosts.length > 0 && (
    <section class="py-16 px-6 sm:px-12 bg-zinc-50 border-t border-zinc-100">
      <div class="max-w-7xl mx-auto">
        <div class="text-[10px] font-black tracking-[0.25em] uppercase text-zinc-400 mb-8">Más noticias de marketing</div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {latestPosts.map((p: any) => (
            <BlogCard post={p} locale="es" />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
    .animate-reveal {
        animation: reveal 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    @keyframes reveal {
        from { opacity: 0; transform: translateY(60px); filter: blur(10px); }
        to { opacity: 1; transform: translateY(0); filter: blur(0); }
    }
</style>

<script>
  const btn = document.getElementById('share-btn');
  if (btn) {
    btn.addEventListener('click', async () => {
      const title = btn.dataset.title ?? document.title;
      const url = btn.dataset.url ?? location.href;
      if (navigator.share) {
        try { await navigator.share({ title, url }); } catch {}
      } else {
        await navigator.clipboard.writeText(url);
        const orig = btn.textContent;
        btn.textContent = '✓ COPIADO';
        setTimeout(() => { btn.textContent = orig; }, 2000);
      }
    });
  }
</script>
