---
/**
 * pages/blog/[slug].astro
 * Artículo individual del blog con diseño Cinematic Hero
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageBlocks from '../../components/blocks/PageBlocks.astro';
import AuthorCard from '../../components/blog/AuthorCard.astro';
import { strapiClient } from '../../lib/strapi';
import { buildAlternates } from '../../lib/i18n';
import { articleSchema } from '../../lib/schema';
import type { BlogPost, Author } from '../../lib/strapi';
import { getStrapiImageUrl } from '../../lib/strapi';

export async function getStaticPaths() {
  try {
    const res = await strapiClient.getBlogPosts('es');
    return res.data.map((item: any) => {
      const post: BlogPost = item.attributes ?? item;
      return {
        params: { slug: post.slug },
        props: { post },
      };
    });
  } catch {
    return [];
  }
}

const { post }: { post: BlogPost } = Astro.props;
const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const canonicalPath = `/blog/${post.slug}`;
const canonicalUrl = `${SITE_URL}${canonicalPath}`;
const alternates = buildAlternates(canonicalPath, `/ca/blog/${post.slug}`, SITE_URL);

const schemas: object[] = [];

function formatDate(dateStr?: string) {
  if (!dateStr) return '';
  return new Date(dateStr).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' });
}

const coverUrl = getStrapiImageUrl(post.featuredImage ?? (post as any).cover_image) || '/og-default.jpg';

// Fetch author con foto (populate=* en /api/articles no popula campos anidados del autor)
let author: Author | undefined = post.author;
if (author) {
  try {
    const authorsRes = await strapiClient.getAuthors();
    const found = (authorsRes.data ?? []).find((a: any) => {
      const d = a.attributes ?? a;
      return d.name === author!.name || a.id === author!.id;
    });
    if (found) author = found.attributes ?? found;
  } catch {}
}

// Sidebar: últimos artículos (sin filtrar el actual para que siempre haya resultados)
let latestPosts: any[] = [];
try {
  const postsRes = await strapiClient.getBlogPosts('es', { limit: 5 });
  latestPosts = (postsRes.data ?? []).map((i: any) => i.attributes ?? i);
} catch {}

// CTA dinámico según categoría
const categoryName = ((post.category?.name || (post as any).categories?.[0]?.name || '') as string).toLowerCase();
const ctaTitle = categoryName.includes('seo') || categoryName.includes('consultor')
  ? 'Auditoría SEO para tu web'
  : categoryName.includes('ads') || categoryName.includes('google')
  ? 'Auditoría de tu cuenta de Google Ads'
  : categoryName.includes('diseño') || categoryName.includes('diseno') || categoryName.includes('web')
  ? 'Presentación de diseño funcional para tu web'
  : 'Auditoría para tu web';
---

<BaseLayout
  title={post.seo?.metaTitle || `${post.title} | Blog Nova Marketing`}
  description={post.seo?.metaDescription || post.excerpt || ''}
  canonical={canonicalUrl}
  locale="es"
  alternates={alternates}
  schemas={schemas}
>
  <!-- Cinematic Hero -->
  <header class="relative min-h-[75vh] flex items-end pb-24 px-6 sm:px-12 overflow-hidden bg-black">
    <!-- background image -->
    <div class="absolute inset-0 z-0 opacity-60">
        <img 
          src={coverUrl} 
          alt={post.title} 
          class="w-full h-full object-cover scale-105"
        />
        <!-- Vignette & Gradient Overlay -->
        <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent"></div>
    </div>

    <div class="max-w-5xl mx-auto w-full relative z-10 animate-reveal">
      <div class="flex flex-wrap items-center gap-4 mb-8">
        <a href="/blog" class="text-white/60 hover:text-white text-[10px] font-black uppercase tracking-[0.3em] flex items-center gap-2 transition-colors">
            ← VOLVER AL BLOG
        </a>
        <span class="w-1 h-1 bg-white/30 rounded-full"></span>
        {post.category && (
          <span class="px-3 py-1 text-[10px] tracking-widest font-black uppercase bg-accent text-white rounded-lg">
            {post.category.name.toUpperCase()}
          </span>
        )}
        <span class="text-white/60 text-[10px] font-black tracking-widest uppercase">
            {(post.publishedDate || post.publishedAt) && formatDate(post.publishedDate || post.publishedAt).toUpperCase()}
        </span>
      </div>
      
      <h1 class="text-5xl md:text-8xl font-black mb-12 leading-[0.95] tracking-tighter text-white max-w-5xl">
        {post.title}
      </h1>
      
      <div class="flex flex-wrap items-center justify-between gap-8 border-t border-white/10 pt-10">
          {author && (
            <div class="flex items-center gap-4">
                {author.photo && (
                    <img
                        src={author.photo?.formats?.small?.url
                          ? (author.photo.formats.small.url.startsWith('http') ? author.photo.formats.small.url : `${import.meta.env.STRAPI_URL || 'http://localhost:1337'}${author.photo.formats.small.url}`)
                          : getStrapiImageUrl(author.photo)}
                        alt={author.name}
                        class="w-16 h-16 rounded-full border-2 border-white/20 object-cover"
                    />
                )}
                <div>
                   <div class="text-white font-bold text-lg leading-none mb-1">{author.name}</div>
                   <div class="text-white/40 text-[10px] font-black uppercase tracking-widest">{author.job_title || 'Equipo Nova'}</div>
                </div>
            </div>
          )}
          
          <div class="flex items-center gap-4">
               <button class="px-6 py-3 rounded-xl bg-white/5 border border-white/10 text-white text-[10px] font-black tracking-widest uppercase hover:bg-white/10 transition-colors">
                COMPARTIR
               </button>
          </div>
      </div>
    </div>
  </header>

  <main class="py-24 px-6 sm:px-12 bg-white relative">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-[1fr_350px] gap-20">
      
      <!-- Contenido Principal -->
      <article class="max-w-none">
        {post.excerpt && (
            <p class="text-2xl font-light text-zinc-500 italic border-l-4 border-accent pl-8 mb-16 leading-relaxed">
                {post.excerpt}
            </p>
        )}

        {post.page_blocks?.length > 0
          ? <PageBlocks blocks={post.page_blocks} />
          : <p class="text-zinc-500 italic">Contenido no disponible.</p>
        }

        {author && <AuthorCard author={author} locale="es" />}
      </article>

      <!-- Sidebar -->
      <aside class="space-y-12">
        <div class="sticky top-32 space-y-12">
          <!-- CTA dinámico -->
          <div class="bg-black p-10 rounded-[2.5rem] text-white">
            <span class="inline-block px-3 py-1 bg-accent text-[9px] font-black tracking-widest rounded-full mb-6">AUDITORÍA GRATUITA</span>
            <h3 class="text-3xl font-black mb-4 leading-none uppercase">{ctaTitle}</h3>
            <p class="text-white/50 font-light mb-8 text-sm">Analizamos 5 puntos clave de tu web que empieces a facturar más.</p>
            <button class="contact-modal-trigger block w-full text-center py-5 bg-white text-black text-[10px] font-black tracking-widest rounded-2xl hover:bg-accent hover:text-white transition-all cursor-pointer">
              SOLICITAR AHORA
            </button>
          </div>

          <!-- Servicios de marketing -->
          <div class="px-4">
            <h4 class="text-xs font-black tracking-[0.2em] uppercase text-zinc-400 mb-8">Servicios de marketing</h4>
            <ul class="space-y-6">
              {[
                { label: 'Posicionamiento SEO', href: '/agencia-seo-para-pymes/' },
                { label: 'Google Ads', href: '/agencia-sem-para-pymes/' },
                { label: 'Diseño de páginas web', href: '/diseno-web-para-pymes/' },
                { label: 'Consultoría de marketing', href: '/consultoria-marketing-para-pymes/' },
              ].map(s => (
                <li>
                  <a href={s.href} class="group flex items-center justify-between">
                    <span class="text-sm font-bold text-black group-hover:text-accent transition-colors uppercase tracking-tight">{s.label}</span>
                    <span class="text-accent opacity-0 group-hover:opacity-100 transition-all font-black">→</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Más noticias de marketing -->
          {latestPosts.length > 0 && (
            <div class="px-4">
              <h4 class="text-xs font-black tracking-[0.2em] uppercase text-zinc-400 mb-8">Más noticias de marketing</h4>
              <ul class="space-y-6">
                {latestPosts.map((p: any) => (
                  <li>
                    <a href={`/blog/${p.slug}`} class="group block">
                      <span class="text-sm font-bold text-black group-hover:text-accent transition-colors leading-snug line-clamp-2">{p.title}</span>
                      {(p.publishedDate || p.publishedAt) && (
                        <span class="text-[10px] text-zinc-400 uppercase tracking-widest font-black mt-1 block">
                          {new Date(p.publishedDate || p.publishedAt).toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' })}
                        </span>
                      )}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </aside>

    </div>
  </main>
</BaseLayout>

<style>
    .animate-reveal {
        animation: reveal 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    @keyframes reveal {
        from { opacity: 0; transform: translateY(60px); filter: blur(10px); }
        to { opacity: 1; transform: translateY(0); filter: blur(0); }
    }

    /* Los estilos del blog los gestiona StrapiBlocks.astro */
</style>
