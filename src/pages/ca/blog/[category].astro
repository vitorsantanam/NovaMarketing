---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/blog/PageHeader.astro';
import BlogCard from '../../../components/blog/BlogCard.astro';
import CategoryTabs from '../../../components/blog/CategoryTabs.astro';
import { strapiClient } from '../../../lib/strapi';
import { buildAlternates } from '../../../lib/i18n';

export async function getStaticPaths() {
  try {
    const categoriesRes = await strapiClient.getBlogCategories('ca');
    const allCategories = categoriesRes.data.map(i => i.attributes ?? i);

    return allCategories.map(cat => ({
      params: { category: cat.slug },
      props: { categoryData: cat }
    }));
  } catch (e) {
    console.error("DEBUG: Blog CA getStaticPaths error:", e);
    return [];
  }
}

const { categoryData } = Astro.props;
const { category } = Astro.params;

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const canonicalPath = `/blog/${category}`;
const alternates = buildAlternates(canonicalPath, canonicalPath, SITE_URL);

// Fetch data
let posts = [];
let allCategories = [];
try {
  const postsRes = await strapiClient.getBlogPosts('ca', { category });
  posts = postsRes.data.map(i => i.attributes ?? i);
} catch (e) { console.error('Blog CA category posts error:', e); }
try {
  const allCategoriesRes = await strapiClient.getBlogCategories('ca');
  allCategories = allCategoriesRes.data.map(i => i.attributes ?? i);
} catch (e) { console.error('Blog CA categories error:', e); }
---

<BaseLayout
  title={`${categoryData.name} | Blog | Nova Marketing`}
  description={categoryData.description || `Articles sobre ${categoryData.name} per a pimes.`}
  locale="ca"
  alternates={alternates}
>
  <PageHeader 
    badge={`BLOG > ${categoryData.name.toUpperCase()}`}
    title={categoryData.name}
    description={`Recursos i notícies especialitzades en ${categoryData.name.toLowerCase()}.`}
  />

  <section class="py-20 px-6 sm:px-12 bg-white">
    <div class="max-w-7xl mx-auto">
      
      <CategoryTabs 
        categories={allCategories} 
        currentCategory={category} 
        baseUrl="/ca/blog"
        locale="ca"
      />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map(post => (
          <BlogCard post={post} locale="ca" />
        ))}
      </div>

      {posts.length === 0 && (
        <div class="text-center py-40 border-2 border-dashed border-zinc-100 rounded-3xl">
          <p class="text-zinc-400 font-light">Encara no hi ha articles en aquesta categoria.</p>
        </div>
      )}
    </div>
  </section>

</BaseLayout>
