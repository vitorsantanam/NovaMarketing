---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../lib/i18n';
import { strapiClient } from '../../lib/strapi';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/consultoria-marketing-digital-sant-cugat/', '/ca/consultoria-marketing-digital-sant-cugat/', SITE_URL);

const faqItems = [
  { question: `Què és una consultoria de màrqueting digital a Sant Cugat?`, answer: `Una consultoria de màrqueting digital a Sant Cugat del Vallès analitza la teva situació actual, identifica les oportunitats del mercat local i dissenya una estratègia per augmentar les teves vendes. Abasta des de SEO i Google Ads fins a branding, continguts i analítica web adaptats al perfil del client de Sant Cugat.` },
  { question: `Quant costa la consultoria de màrqueting a Sant Cugat?`, answer: `El cost varia segons l'abast del projecte. Oferim una auditoria inicial gratuïta per a empreses de Sant Cugat del Vallès. Treballem amb pressupostos adaptats tant a pimes emergents de Volpelleres com a despatxos consolidats del centre.` },
  { question: `En quant de temps es veuen els resultats a Sant Cugat del Vallès?`, answer: `Depèn del canal i el sector. Amb Google Ads els resultats són immediats. Amb SEO, entre 3 i 6 mesos. Amb estratègia de continguts orientada al client premium de Sant Cugat, entre 6 i 12 mesos.` },
  { question: `Us especialitzeu en empreses tech i professionals liberals de Sant Cugat?`, answer: `Sí. Sant Cugat té un teixit empresarial molt particular: consultores, despatxos, clíniques, empreses tech i serveis premium. Entenem aquest mercat i dissenyem estratègies adaptades a aquest perfil de client a Sant Cugat i el Vallès.` },
  { question: `Puc contractar només l'auditoria sense compromís a Sant Cugat?`, answer: `Sí. L'auditoria inicial gratuïta no té cap compromís. Analitzem la teva web, la teva visibilitat a Google, els teus competidors a Sant Cugat i la teva estratègia actual. L'informe és teu independentment de si contractes els nostres serveis.` },
  { question: `La consultoria inclou estratègia de continguts per posicionar-me com a expert a Sant Cugat?`, answer: `Sí. Per al client exigent de Sant Cugat del Vallès, el contingut de valor és una palanca clau. La consultoria pot incloure una estratègia de continguts SEO i d'autoritat adaptada al teu sector i a la cerca del client local.` },
  { question: `Teniu oficina a Sant Cugat del Vallès?`, answer: `Sí, operem des del Carrer de Francesc Moragas 12 a Sant Cugat del Vallès. Podem reunir-nos en persona, fem seguiment presencial i coneixem el mercat local de primera mà.` },
  { question: `Com diferenciats el vostre enfocament a Sant Cugat del d'altres agències?`, answer: `A Sant Cugat el client és més exigent i el mercat més competitiu que en altres ciutats del Vallès. El nostre enfocament parteix de dades reals del mercat local, proposa accions amb KPIs clars i mesura el ROI de cada iniciativa. Sense promeses buides.` }
];

let consulCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('ca');
  consulCases = casesRes.data
    .map((i: any) => i.attributes ?? i)
    .filter((c: any) => {
      const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
      return cats.some((s: string) => s.includes('consul') || s.includes('marketing'));
    });
} catch {}

const faqSchema = {"@context":"https://schema.org","@type":"FAQPage","mainEntity":[
    {"@type":"Question","name":"Què és una consultoria de màrqueting digital a Sant Cugat?","acceptedAnswer":{"@type":"Answer","text":"Una consultoria de màrqueting digital a Sant Cugat del Vallès analitza la teva situació actual, identifica les oportunitats del mercat local i dissenya una estratègia per augmentar les teves vendes. Abasta des de SEO i Google Ads fins a branding, continguts i analítica web adaptats al perfil del client de Sant Cugat."}},
    {"@type":"Question","name":"Quant costa la consultoria de màrqueting a Sant Cugat?","acceptedAnswer":{"@type":"Answer","text":"El cost varia segons l'abast del projecte. Oferim una auditoria inicial gratuïta per a empreses de Sant Cugat del Vallès. Treballem amb pressupostos adaptats tant a pimes emergents de Volpelleres com a despatxos consolidats del centre."}},
    {"@type":"Question","name":"En quant de temps es veuen els resultats a Sant Cugat del Vallès?","acceptedAnswer":{"@type":"Answer","text":"Depèn del canal i el sector. Amb Google Ads els resultats són immediats. Amb SEO, entre 3 i 6 mesos. Amb estratègia de continguts orientada al client premium de Sant Cugat, entre 6 i 12 mesos."}},
    {"@type":"Question","name":"Us especialitzeu en empreses tech i professionals liberals de Sant Cugat?","acceptedAnswer":{"@type":"Answer","text":"Sí. Sant Cugat té un teixit empresarial molt particular: consultores, despatxos, clíniques, empreses tech i serveis premium. Entenem aquest mercat i dissenyem estratègies adaptades a aquest perfil de client a Sant Cugat i el Vallès."}},
    {"@type":"Question","name":"Puc contractar només l'auditoria sense compromís a Sant Cugat?","acceptedAnswer":{"@type":"Answer","text":"Sí. L'auditoria inicial gratuïta no té cap compromís. Analitzem la teva web, la teva visibilitat a Google, els teus competidors a Sant Cugat i la teva estratègia actual. L'informe és teu independentment de si contractes els nostres serveis."}},
    {"@type":"Question","name":"La consultoria inclou estratègia de continguts per posicionar-me com a expert a Sant Cugat?","acceptedAnswer":{"@type":"Answer","text":"Sí. Per al client exigent de Sant Cugat del Vallès, el contingut de valor és una palanca clau. La consultoria pot incloure una estratègia de continguts SEO i d'autoritat adaptada al teu sector i a la cerca del client local."}},
    {"@type":"Question","name":"Teniu oficina a Sant Cugat del Vallès?","acceptedAnswer":{"@type":"Answer","text":"Sí, operem des del Carrer de Francesc Moragas 12 a Sant Cugat del Vallès. Podem reunir-nos en persona, fem seguiment presencial i coneixem el mercat local de primera mà."}},
    {"@type":"Question","name":"Com diferenciats el vostre enfocament a Sant Cugat del d'altres agències?","acceptedAnswer":{"@type":"Answer","text":"A Sant Cugat el client és més exigent i el mercat més competitiu que en altres ciutats del Vallès. El nostre enfocament parteix de dades reals del mercat local, proposa accions amb KPIs clars i mesura el ROI de cada iniciativa. Sense promeses buides."}}
  ]};

const serviceSchema = {"@context":"https://schema.org","@type":"Service","serviceType":"Consultor de Marketing Digital para Pymes","provider":{"@type":"ProfessionalService","@id":"https://novamarketing.es/#organization","name":"Nova Marketing","image":"https://novamarketing.es/agencia-marketing-pymes-nova-marketing-logo.png","telephone":"+34644738270","priceRange":"€€","address":{"@type":"PostalAddress","streetAddress":"Carrer de Francesc Moragas 12","addressLocality":"Sant Cugat del Vallès","addressRegion":"Barcelona","postalCode":"08172","addressCountry":"ES"},"aggregateRating":{"@type":"AggregateRating","ratingValue":"4.9","reviewCount":"35"}},"areaServed":{"@type":"City","name":"Sant Cugat del Vallès","sameAs":"https://www.wikidata.org/wiki/Q12260"},"description":"Consultoria de màrqueting digital a mida per a pimes de Sant Cugat del Vallès. Estratègies de creixement per a empreses tech, professionals liberals i pimes del Vallès.","offers":{"@type":"Offer","priceRange":"€€"},"hasOfferCatalog":{"@type":"OfferCatalog","name":"Servicios de Consultoría de Marketing Digital","itemListElement":[{"@type":"Offer","itemOffered":{"@type":"Service","name":"Auditoría 360 de Marketing Digital"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Plan Estratégico de Marketing"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Consultoría de Competencia Digital"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Asesoría en Transformación Digital"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Análisis de Datos y Dashboarding"}}]}};
---

<BaseLayout
  title="Consultor de Màrqueting Digital a Sant Cugat del Vallès | Nova Marketing"
  description="Estratègies de màrqueting a mida per a pimes de Sant Cugat del Vallès. Auditoria gratuïta. Especialistes en el mercat local amb empreses tech i professionals liberals."
  locale="ca"
  alternates={alternates}
  schemas={[serviceSchema, faqSchema]}
>

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[88vh] flex items-center justify-center pt-24 pb-16 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
    <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
    <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>
    <div class="max-w-7xl mx-auto reveal relative z-10">
      <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-6 shadow-sm">
        <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
        Especialistes en Estratègia Digital
      </span>
      <h1 class="text-3xl sm:text-5xl md:text-6xl lg:text-[4.2rem] xl:text-[4.8rem] uppercase font-black tracking-tighter leading-[0.95] sm:leading-[0.9] mb-8 text-zinc-900 w-full text-center max-w-[85rem] mx-auto opacity-0 translate-y-4 animate-[fade-in-up_0.8s_ease-out_forwards]">
        <span class="block lg:inline">Consultor de Màrqueting</span>
                <span class="block lg:inline">Digital a</span>
                <span class="text-mktg-gradient inline-block px-1">Sant Cugat</span>
      </h1>
      <p class="text-base sm:text-lg text-zinc-500 font-light leading-relaxed max-w-2xl mx-auto mb-12">
        Estratègies de màrqueting a mida per escalar les vendes de la teva empresa a Sant Cugat del Vallès. Impulsem pimes i professionals des del centre de Sant Cugat amb visió estratègica real.
      </p>
      <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
        <button class="contact-modal-trigger btn-mktg-v5 shadow-[0_20px_40px_-10px_rgba(0,0,0,0.15)] hover:shadow-[0_25px_50px_-12px_rgba(0,0,0,0.25)] hover:-translate-y-1 transition-all duration-300 !py-5 !px-12 !text-[12px] !tracking-wider font-black w-full sm:w-auto">
          SOL·LICITAR AUDITORIA GRATIS
        </button>
      </div>
    </div>
  </section>
  <style>
    @keyframes fade-in-up {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>

  <!-- ═══ LOGOS CLIENTES ═══ -->
  <section class="py-12 border-b border-black/5 bg-zinc-50/40 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="text-[9px] sm:text-[10px] uppercase font-black tracking-widest text-zinc-400 text-center mb-8">PIMES QUE JA CREIXEN AMB EL SEU CONSULTOR A NOVA</p>
      <div class="overflow-hidden w-full relative [mask-image:linear-gradient(to_right,transparent,white_10%,white_90%,transparent)]">
        <div id="logos-consult-sc" class="flex items-center gap-16 w-max animate-scrollConsultSC"></div>
      </div>
    </div>
  </section>
  <style>
    @keyframes scrollConsultSC {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .animate-scrollConsultSC {
      animation: scrollConsultSC 60s linear infinite;
    }
  </style>
  <script is:inline>
    (function() {
      var logos = [
        { src: "/clients/bermaq-cliente-novamarketing.webp", alt: "Bermaq" },
        { src: "/clients/cb-lhospitalet-cliente-novamarketing.webp", alt: "CB l'Hospitalet" },
        { src: "/clients/medhs-cliente-novamarketing.webp", alt: "MedHS" },
        { src: "/clients/palacio-del-bebe-cliente-novamarketing.webp", alt: "Palacio del bebé" },
        { src: "/clients/tagtio-cliente-novamarketing.webp", alt: "Tagtio" },
        { src: "/clients/tejados-tapar-cliente-novamarketing.webp", alt: "Tejados Tapar" },
        { src: "/clients/fastpoint-cliente-novamarketing.webp", alt: "FastPoint" },
        { src: "/clients/mundeta-cliente-novamarketing.webp", alt: "Mundeta" },
        { src: "/clients/tattoox-cliente-novamarketing.webp", alt: "TattooX" },
        { src: "/clients/voltura-projects-cliente-novamarketing.webp", alt: "Voltura Projects" }
      ];
      function initMarquee() {
        var shuffled = logos.sort(function() { return Math.random() - 0.5; });
        var full = shuffled.concat(shuffled);
        var el = document.getElementById('logos-consult-sc');
        if (el) {
          el.innerHTML = full.map(function(l) {
            return '<img src="' + l.src + '" alt="' + l.alt + '" class="h-[50px] w-auto object-contain filter grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-300 pointer-events-none" style="mix-blend-mode:multiply" />';
          }).join('');
        }
      }
      document.addEventListener('DOMContentLoaded', initMarquee);
      document.addEventListener('astro:page-load', initMarquee);
      initMarquee();
    })();
  </script>

  <!-- ═══ CONSULTOR ═══ -->
  <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
    <div class="max-w-6xl mx-auto reveal">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
        <div class="md:col-span-5 relative group flex justify-center">
          <div class="absolute inset-0 bg-accent/20 rounded-full blur-3xl opacity-30 group-hover:scale-105 transition-transform duration-500"></div>
          <div class="relative w-full max-w-sm">
            <div class="absolute -top-6 -left-6 w-24 h-24 bg-[radial-gradient(#000000_15%,transparent_15%)] bg-[length:12px_12px] opacity-20"></div>
            <div class="overflow-hidden rounded-[2rem] shadow-[0_30px_60px_-15px_rgba(0,0,0,0.1)] border-4 border-white">
              <img src="/img/consultor_marketing.webp" alt="Sergio García serà el teu consultor de màrqueting a Sant Cugat" class="w-full h-auto object-cover">
            </div>
            <div class="absolute -bottom-4 -right-4 backdrop-blur-md bg-black/90 text-white px-6 py-4 rounded-xl shadow-xl flex items-center gap-3 border border-white/10">
              <div class="w-2 h-2 bg-accent rounded-full animate-pulse"></div>
              <div class="text-[10px] sm:text-xs font-black uppercase tracking-widest">Consultoria de Màrqueting</div>
            </div>
          </div>
        </div>
        <div class="md:col-span-7 text-left">
          <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.4em] text-accent mb-4 block">Consultoria de Màrqueting</span>
          <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.85]">
            Sergio García serà el teu consultor de màrqueting a Sant Cugat
          </h2>
          <p class="text-zinc-500 font-light text-base sm:text-lg leading-relaxed mb-8">Sant Cugat del Vallès té un perfil empresarial únic: empreses tech, professionals liberals, consultes mèdiques i despatxos a Can Bellet i Volpelleres. Coneixem aquest mercat. Dissenyem estratègies de màrqueting orientades al client de Sant Cugat i el Vallès Occidental, des del Monestir fins al Gurugú.</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="p-6 bg-zinc-50 border border-black/5 rounded-xl hover:bg-zinc-100 transition-colors">
              <div class="text-sm font-black uppercase tracking-wider text-black mb-2">Mercat Premium</div>
              <p class="text-xs text-zinc-400 font-light">Sant Cugat, professionals exigents.</p>
            </div>
            <div class="p-6 bg-zinc-50 border border-black/5 rounded-xl hover:bg-zinc-100 transition-colors">
              <div class="text-sm font-black uppercase tracking-wider text-black mb-2">Estratègia Diferenciada</div>
              <p class="text-xs text-zinc-400 font-light">Posicionament i conversió real.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FEATURE CARDS ═══ -->
  <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808005_1px,transparent_1px),linear-gradient(to_bottom,#80808005_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_50%,#000_80%,transparent_100%)]"></div>
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 sm:mb-24 reveal">
        <h2 class="text-3xl sm:text-5xl lg:text-7xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.82]">
          Consultoria de Màrqueting integral per a pimes de Sant Cugat
        </h2>
        <p class="text-zinc-500 font-light text-base sm:text-lg leading-relaxed max-w-2xl mx-auto">
          No et donem plantilles genèriques. Dissenyem estratègies adaptades al mercat diferencial de Sant Cugat del Vallès: alta renda, alta competència i clients exigents.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 items-stretch">
          <div class="group flex flex-col justify-between p-8 sm:p-10 h-full bg-white rounded-3xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden reveal flex-1">
            <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
            <div class="absolute -bottom-6 -right-4 text-9xl font-black text-black/2 group-hover:text-accent/[0.04] transition-all duration-500 select-none">01</div>
            <div class="relative z-10 flex flex-col h-full justify-between">
              <div>
                <div class="p-3 bg-zinc-50 border border-black/5 w-fit rounded-xl mb-6 group-hover:bg-accent/5 transition-colors">
                  <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
                </div>
                <h3 class="text-xl sm:text-2xl uppercase mb-3 tracking-tighter group-hover:text-accent font-black text-zinc-900 border-b border-zinc-100 pb-2 w-fit">Auditoria Estratègica</h3>
                <p class="text-xs sm:text-sm text-zinc-500 leading-relaxed font-light">Analitzem la teva presència digital, la teva competència a Sant Cugat i les oportunitats al mercat tech i professional del Vallès Occidental.</p>
              </div>
            </div>
          </div>
          <div class="group flex flex-col justify-between p-8 sm:p-10 h-full bg-white rounded-3xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden reveal flex-1">
            <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
            <div class="absolute -bottom-6 -right-4 text-9xl font-black text-black/2 group-hover:text-accent/[0.04] transition-all duration-500 select-none">02</div>
            <div class="relative z-10 flex flex-col h-full justify-between">
              <div>
                <div class="p-3 bg-zinc-50 border border-black/5 w-fit rounded-xl mb-6 group-hover:bg-accent/5 transition-colors">
                  <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <h3 class="text-xl sm:text-2xl uppercase mb-3 tracking-tighter group-hover:text-accent font-black text-zinc-900 border-b border-zinc-100 pb-2 w-fit">Pla de Negoci</h3>
                <p class="text-xs sm:text-sm text-zinc-500 leading-relaxed font-light">Identifiquem les palances més rendibles per a la teva empresa de Sant Cugat: canals premium, missatges diferenciadors i pressupost optimitzat per al mercat local.</p>
              </div>
            </div>
          </div>
          <div class="group flex flex-col justify-between p-8 sm:p-10 h-full bg-white rounded-3xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden reveal flex-1">
            <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
            <div class="absolute -bottom-6 -right-4 text-9xl font-black text-black/2 group-hover:text-accent/[0.04] transition-all duration-500 select-none">03</div>
            <div class="relative z-10 flex flex-col h-full justify-between">
              <div>
                <div class="p-3 bg-zinc-50 border border-black/5 w-fit rounded-xl mb-6 group-hover:bg-accent/5 transition-colors">
                  <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                </div>
                <h3 class="text-xl sm:text-2xl uppercase mb-3 tracking-tighter group-hover:text-accent font-black text-zinc-900 border-b border-zinc-100 pb-2 w-fit">Implementació</h3>
                <p class="text-xs sm:text-sm text-zinc-500 leading-relaxed font-light">Executem l'estratègia amb el teu equip perquè Sant Cugat, Volpelleres i Can Bellet es converteixin en el teu territori de clients dominant.</p>
              </div>
            </div>
          </div>
          <div class="group flex flex-col justify-between p-8 sm:p-10 h-full bg-white rounded-3xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden reveal flex-1">
            <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
            <div class="absolute -bottom-6 -right-4 text-9xl font-black text-black/2 group-hover:text-accent/[0.04] transition-all duration-500 select-none">04</div>
            <div class="relative z-10 flex flex-col h-full justify-between">
