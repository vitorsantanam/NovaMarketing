---
/**
 * src/pages/ca/index.astro
 * Versió en Català de la Home
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../lib/i18n';
import FaqHome from '../../components/sections/FaqHome.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/', '/', SITE_URL);

const faqItems = [
    {
        question: "En què es diferencia Nova de altres agències per a pimes?",
        answer: "Ens allunyem del model de \"agència impersonal\". A Nova oferim a cada pyme un tracte directe i humà (via WhatsApp) i una transparència total en els informes de la teva petita empresa, sense tecnicismes rars. No només busquem clics; apliquem tecnologia i IA perquè les petites i mitjanes empreses competeixin al més alt nivell, enfocant-nos sempre que la teva inversió es traduiixi en vendes reals i no només en visites."
    },
    {
        question: "Per què hauria de contractar una agència per a pimes en lloc de que algú de la meva empresa porti el marketing?",
        answer: "Delegar en una agència especialitzada permet que la teva pyme accedeixi a un equip expert i a eines professionals que, de forma interna, serien molt costoses. A Nova ens encarreguem que tu puguis centrar-te en gestionar el teu negoci mentre nosaltres apliquem estratègies que ja han funcionat en altres petites i mitjanes empreses, estalviant-te temps i errors costosos."
    },
    {
        question: "Com sé si la meva empresa és \"massa petita\" per treballar amb vosaltres?",
        answer: "A Nova Marketing ens especialitzem precisament en pimes i petites empreses. No creiem que la mida del negoci hagi de limitar la seva capacitat de creixement. Adaptem la nostra metodologia perquè qualsevol petita i mitjana empresa, sigui quina sigui el seu punt de partida, pugui competir en l'entorn digital amb garanties."
    },
    {
        question: "Hauré de parlar amb un contestador o tindré contacte directe amb algú de l'agència?",
        answer: "Sabem que per a l'amo d'una pyme la proximitat és vital. Per això, a nova apostem pel tracte humà. Tindràs contacte directe amb nosaltres, inclús per WhatsApp, perquè la comunicació sigui fluida. No som una plataforma automatizada, som persones ajudant a que altres pimes arribin als seus objectius."
    },
    {
        question: "He de signar un contracte de permanència obligatori amb l'agència?",
        answer: "Creiem en els resultats, no en els lligams. A Nova treballem perquè et quedis amb nosaltres perquè veus que la teva pyme creix, no perquè un paper t'obligui. Oferim flexibilitat perquè cada petita empresa se senti còmoda i segura amb la inversió que està realitzant en el seu futur digital."
    },
    {
        question: "Què passa si el meu sector és molt específic? Podeu ayudar la meva pyme igualment?",
        answer: "Encara que cada petita i mitjana empresa és un món, els principis del marketing eficaç són universals. La nostra metodologia es basa en analitzar a fons el teu nínxol i la teva competència abans de moure un sol dit. Hem treballat amb sectors molt diversos, ayudant pimes de tot tipus a trobar el seu lloc i destacar en el mercat."
    },
    {
        question: "Quant temps n'haig de dedicar jo al marketing de la meva petita empresa?",
        answer: "El teu temps és or. El nostre objectiu és que tu només hagis de validar les línies generals i atendre els nous clients que et aconseguim. Ens encarreguem de l'execució pesada perquè el marketing de la teva pyme funcioni de forma semiautomàtica sense que et robi hores de son o de gestió interna."
    }
];

// Definicions de serveis en català
const services = [
    { 
        title: 'Posicionament SEO', 
        desc: 'Optimitzem la teva presència a Google perquè els clients de la teva zona et trobin abans que a la competència, multiplicant les teves visites de negoci.', 
        icon: 'Search'
    },
    { 
        title: 'Google Ads', 
        desc: 'Campanyes de publicitat de pagament per clic (SEM) dissenyades per generar contactes qualificats i vendes immediates. L\'impuls que la teva pyme necessita avui.', 
        icon: 'TrendingUp'
    },
    { 
        title: 'Disseny de pàgines web', 
        desc: 'Llocs web desenvolupats a mida per a cada client. Atractius, ultraràpids i 100% enfocats a la conversió per convertir visites en clients finals.', 
        icon: 'Settings'
    },
    { 
        title: 'Consultoria de marketing', 
        desc: 'Estratègia contínua per optimitzar la teva inversió. T\'ajudem a prendre les decisions empresarials correctes pel creixement del teu negoci.', 
        icon: 'Target'
    },
];

const icons: Record<string, any> = {
  Search: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" class="w-7 h-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>`,
  TrendingUp: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" class="w-7 h-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg>`,
  Settings: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" class="w-7 h-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33 1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82 1.65 1.65 0 0 0 1.51 1z"></path></svg>`,
  Target: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" class="w-7 h-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="6"></circle><circle cx="12" cy="12" r="2"></circle></svg>`
}

const homeSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Nova Marketing",
  "legalName": "Nova Marketing",
  "url": "https://novamarketing.es/ca/",
  "logo": "https://novamarketing.es/agencia-marketing-pymes-nova-marketing-logo.png",
  "image": "https://novamarketing.es/agencia-marketing-pymes-nova-marketing-logo.png",
  "description": "El departament de marketing que tota pyme necessita. Agència de marketing digital especialitzada en pimes.",
  "slogan": "El departament de marketing que tota pyme necessita",
  "founder": {
    "@type": "Person",
    "name": "Sergio García"
  },
  "foundingDate": "2020",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Carrer de Bilbao 1",
    "addressLocality": "Sabadell",
    "addressRegion": "Barcelona",
    "postalCode": "08202",
    "addressCountry": "ES"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 41.5492150198795,
    "longitude": 2.1150599711651217
  },
  "telephone": "+34644738270",
  "email": "hola@novamarketing.es",
  "openingHours": "Mo-Fr 08:00-20:00",
  "areaServed": [
    {
      "@type": "Country",
      "name": "Spain"
    },
    {
      "@type": "City",
      "name": "Sabadell"
    },
    {
      "@type": "City",
      "name": "Barcelona"
    }
  ],
  "sameAs": [
    "https://www.linkedin.com/company/nova-marketing-pymes/",
    "https://www.instagram.com/nova_marketing_pymes/"
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Serveis de Marketing Digital",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Posicionament SEO",
          "url": "https://novamarketing.es/ca/agencia-seo-per-pimes/"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Google Ads",
          "url": "https://novamarketing.es/ca/agencia-sem-per-pimes/"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Disseny web",
          "url": "https://novamarketing.es/ca/disseny-web-per-pimes/"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Consultoria de marketing",
          "url": "https://novamarketing.es/ca/consultoria-marketing-per-pimes/"
        }
      }
    ]
  }
};
---

<BaseLayout
  title="Nova Marketing | Agència de marketing digital per a PIMES"
  description="Multipliquem el trànsit i les vendes de la teva pime amb marketing digital avançat. Especialistes en SEO, SEM i Consultoria."
  locale="ca"
  alternates={alternates}
  schemas={[homeSchema]}
>

    <!-- ═══ HERO ════════════════════════════════════════════════════════════ -->
    <section class="pt-24 sm:pt-40 pb-20 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <!-- Background Grid Mesh -->
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>

        <!-- Glow Orbs -->
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-7xl mx-auto w-full text-center">
            <div class="reveal">
                <h2 class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-8 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Especialistes en marketing per a pimes</h2>
                
                <h1 class="text-4xl sm:text-6xl md:text-7xl lg:text-8xl uppercase font-black tracking-tighter leading-[0.82] mb-6 text-zinc-900 flex flex-col items-center text-center">
                    <span>Agència de</span>
                    <span>Marketing Digital</span>
                    <span class="text-mktg-gradient px-4 overflow-visible inline-block">per a Pymes</span>
                </h1>
                
                <p class="text-base sm:text-xl text-zinc-500 font-light leading-relaxed max-w-2xl mx-auto mb-10 whitespace-normal sm:whitespace-nowrap">
                    Som el departament de marketing que tota empresa necessita.
                </p>
                
                <div class="flex flex-col sm:flex-row justify-center gap-3 sm:gap-6 mt-4">
                    <a href="#contact" class="btn-mktg-v5 shadow-[0_10px_30px_rgba(0,0,0,0.1)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                        ESTRATÈGIES PER A PIMES
                    </a>
                    <button class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(0,0,0,0.1)] sm:!bg-transparent sm:!text-black border-2 border-black sm:border-black/10 hover:border-black hover:!bg-zinc-50 sm:shadow-none !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black cursor-pointer hidden md:inline-flex justify-center items-center">
                        PARLEM DEL TEU PROJECTE
                    </button>
                    <div class="md:hidden w-full sm:w-auto">
                        <a href="https://wa.me/34644738270" class="btn-mktg-v5 shadow-[0_10px_30px_rgba(0,0,0,0.1)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black w-full text-center flex justify-center">
                            📲 WHATSAPP
                        </a>
                    </div>
                </div>


            </div>
        </div>
    </section>

    <!-- ═══ GRID: SERVEIS 360 ══════════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 border-y border-black/5 relative overflow-hidden px-4 sm:px-6">
        <div class="max-w-7xl mx-auto">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-16 sm:mb-24 gap-6 md:gap-12">
                <div class="reveal">
                    <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Serveis de marketing per a pimes</span>
                    <h2 class="text-3xl sm:text-6xl lg:text-7xl uppercase font-black tracking-tighter mb-2">Marketing 360º</h2>
                </div>
                <p class="text-zinc-500 max-w-md font-light text-sm sm:text-base tracking-wide leading-relaxed reveal">
                   Les millors estratègies de marketing per a pimes <br class="hidden md:inline" /> implementades pel teu departament de marketing.
                </p>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 items-stretch">
                {services.map((s, i) => (
                    <div class="group flex flex-col justify-between p-8 sm:p-12 service-card h-full bg-white rounded-3xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden reveal flex-1" style={`transition-delay: ${i * 100}ms`}>
                        <!-- Hover Gradient Overlay -->
                        <div class="absolute inset-0 bg-gradient-to-br from-transparent via-transparent to-accent/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

                        <!-- Number Overlay Background -->
                        <div class="absolute -bottom-6 -right-4 text-9xl font-black text-black/2 group-hover:text-accent/[0.04] transition-all duration-500 select-none">
                            0{i + 1}
                        </div>

                        <div class="relative z-10 flex flex-col h-full justify-between">
                            <div>
                                <div class="flex justify-between items-start mb-8 sm:mb-12">
                                    <div class="w-14 h-14 bg-zinc-50 border border-black/5 rounded-2xl flex items-center justify-center transition-all duration-300 group-hover:bg-accent group-hover:border-accent group-hover:text-white text-accent shadow-sm">
                                        <Fragment set:html={icons[s.icon]} />
                                    </div>
                                </div>
                                <h3 class="text-xl sm:text-2xl uppercase mb-4 tracking-tighter group-hover:text-accent transition-colors font-black text-zinc-900 border-b border-zinc-100 group-hover:border-accent/20 pb-2 w-fit">
                                    {s.title}
                                </h3>
                                <p class="text-xs sm:text-sm text-zinc-500 leading-relaxed font-light">{s.desc}</p>
                            </div>

                            <div class="mt-8 pt-6 border-t border-zinc-50 flex items-center justify-between">
                                <span class="text-[9px] font-black tracking-widest text-accent flex items-center gap-1 group-hover:gap-2 transition-all">
                                    SABER MÁS <span class="text-sm">→</span>
                                </span>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ═══ SECCIÓ PYME: DIFERENCIACIÓ ═════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <h2 class="text-2xl sm:text-5xl lg:text-7xl font-black tracking-tighter uppercase mb-4">
                    <span class="block">Nova, l'Agència de Marketing</span><span class="block">de la teva Pime</span>
                </h2>

                <p class="text-zinc-500 max-w-2xl mx-auto font-light text-base sm:text-lg tracking-wide leading-relaxed">
                    La confiança es construeix amb fets. Treballem amb total transparència i comunicació directa perquè sentis que som una extensió real del teu negoci.
                </p>

            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="group p-8 bg-white border border-zinc-100 rounded-2xl hover:border-accent/10 hover:shadow-xl hover:-translate-y-1 transition-all duration-500 hover:border-black/20 hover:shadow-[0_20px_50px_rgba(0,0,0,0.03)] transition-all duration-500 reveal">
                    <div class="h-1 bg-black w-12 group-hover:w-full transition-all duration-500 mb-6"></div>
                    <h3 class="text-xl sm:text-2xl font-black uppercase tracking-tighter mb-4 text-zinc-900">Tracte personalitzat i proper</h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed">No ets una compte més. El teu negoci és la nostra prioritat absoluta. Parlem el teu idioma i ens impliquem en el teu creixement diari.</p>
                </div>
                <div class="group p-8 bg-white border border-zinc-100 rounded-2xl hover:border-accent/10 hover:shadow-xl hover:-translate-y-1 transition-all duration-500 hover:border-black/20 hover:shadow-[0_20px_50px_rgba(0,0,0,0.03)] transition-all duration-500 reveal" style="transition-delay: 100ms">
                    <div class="h-1 bg-black w-12 group-hover:w-full transition-all duration-500 mb-6"></div>
                    <h3 class="text-xl sm:text-2xl font-black uppercase tracking-tighter mb-4 text-zinc-900">Plans escalables i pressupost ajustat</h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed">Creixem amb tu. Inversió intel·ligent dissenyada per maximitzar el retorn (ROI) sense comprometre la salut financera del teu negoci.</p>
                </div>
                <div class="group p-8 bg-white border border-zinc-100 rounded-2xl hover:border-accent/10 hover:shadow-xl hover:-translate-y-1 transition-all duration-500 hover:border-black/20 hover:shadow-[0_20px_50px_rgba(0,0,0,0.03)] transition-all duration-500 reveal" style="transition-delay: 200ms">
                    <div class="h-1 bg-black w-12 group-hover:w-full transition-all duration-500 mb-6"></div>
                    <h3 class="text-xl sm:text-2xl font-black uppercase tracking-tighter mb-4 text-zinc-900">Reports clars: Entén cada euro</h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed">Transparència total. Sense argots tècnics incomprensibles. Sol mètriques de negoci, contactes generats i vendes aconseguides.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ SECCIÓ CASOS D'ÈXIT ════════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 border-t border-black/5 px-4 sm:px-6 relative overflow-hidden">
        <div class="max-w-7xl mx-auto">
            <div class="mb-16 sm:mb-24 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Resultats provats</span>
                <h2 class="text-3xl sm:text-5xl lg:text-7xl uppercase tracking-tighter font-extrabold mb-2">
                    Casos d'Èxit de Pimes <br class="hidden md:inline" /> que ja creixen amb nosaltres
                </h2>
            </div>

            <!-- Carousel-style Container -->
            <div class="flex overflow-x-auto snap-x snap-mandatory md:grid md:grid-cols-4 gap-6 pb-8 md:pb-0 scrollbar-hide">
                
                <div class="min-w-[280px] sm:min-w-[320px] md:min-w-0 snap-center bg-white p-8 border border-black/5 flex flex-col justify-between h-full group hover:shadow-[0_20px_60px_rgba(0,0,0,0.05)] transition-all reveal">
                    <div>
                        <span class="text-[10px] font-black uppercase tracking-widest text-accent mb-4 block">SEO + ADS</span>
                        <h3 class="text-xl font-black uppercase tracking-tighter mb-4 group-hover:text-accent transition-colors">Clínica Dental Martínez</h3>
                        <p class="text-xs text-zinc-500 font-light leading-relaxed mb-6">Multipliquem la captació de pacients locals optimitzant Google Business i campanyes hiper-segmentades.</p>
                    </div>
                    <div class="text-2xl font-black tracking-tighter text-black mt-4">+150% Leads</div>
                </div>

                <div class="min-w-[280px] sm:min-w-[320px] md:min-w-0 snap-center bg-white p-8 border border-black/5 flex flex-col justify-between h-full group hover:shadow-[0_20px_60px_rgba(0,0,0,0.05)] transition-all reveal" style="transition-delay: 100ms">
                    <div>
                        <span class="text-[10px] font-black uppercase tracking-widest text-accent mb-4 block">E-COMMERCE</span>
                        <h3 class="text-xl font-black uppercase tracking-tighter mb-4 group-hover:text-accent transition-colors">Ferreteria El Tornillo</h3>
                        <p class="text-xs text-zinc-500 font-light leading-relaxed mb-6">Desenvolupament de botiga online connectada a estoc real. Vendes recurrentes a nivell nacional des del primer mes.</p>
                    </div>
                    <div class="text-2xl font-black tracking-tighter text-black mt-4">x3 Vendes</div>
                </div>

                <div class="min-w-[280px] sm:min-w-[320px] md:min-w-0 snap-center bg-white p-8 border border-black/5 flex flex-col justify-between h-full group hover:shadow-[0_20px_60px_rgba(0,0,0,0.05)] transition-all reveal" style="transition-delay: 200ms">
                    <div>
                        <span class="text-[10px] font-black uppercase tracking-widest text-accent mb-4 block">LOCAL SEO</span>
                        <h3 class="text-xl font-black uppercase tracking-tighter mb-4 group-hover:text-accent transition-colors">Restaurante El Sabor</h3>
                        <p class="text-xs text-zinc-500 font-light leading-relaxed mb-6">Posicionament en "restaurants a prop meu". Ple garantit cada cap de setmana sense inversió en ADS.</p>
                    </div>
                    <div class="text-2xl font-black tracking-tighter text-black mt-4">100% Ocupació</div>
                </div>

                <div class="min-w-[280px] sm:min-w-[320px] md:min-w-0 snap-center bg-white p-8 border border-black/5 flex flex-col justify-between h-full group hover:shadow-[0_20px_60px_rgba(0,0,0,0.05)] transition-all reveal" style="transition-delay: 300ms">
                    <div>
                        <span class="text-[10px] font-black uppercase tracking-widest text-accent mb-4 block">SOCIAL ADS</span>
                        <h3 class="text-xl font-black uppercase tracking-tighter mb-4 group-hover:text-accent transition-colors">Moda Joven Lara</h3>
