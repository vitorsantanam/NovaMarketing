const steps = [
  { title: "Estudi de Keywords", desc: "Analitzem les paraules clau amb major intenció de compra per atreure clients llestos per adquirir els teus productes o serveis." },
  { title: "Optimització de Landings", desc: "Adaptem l'estructura de la teva web perquè cada visita es tradueixi en una conversió, maximitzant la teva inversió publicitaria." },
  { title: "Creació d'Anuncis", desc: "Redactem anuncis de cerca d'alt impacte i dissenyem banners atractius de Display i Shopping per captar l'atenció." },
  { title: "Test A/B i Optimització", desc: "Provem contínuament diferents versions d'anuncis per abaixar el CPC (cost per clic) i elevar la rentabilitat." }
];

const benefits = [
  { title: "Control total del teu pressupost", desc: "Tu decideixes quant invertir cada dia. Gestió de campanyes sense sorpreses, sense costos ocults i adaptat a la teva PIME." },
  { title: "Segmentación Avanzada", desc: "Arribem només a qui busca els teus serveis a la teva zona i horari. No disparem a cegues, apuntem al teu client ideal." },
  { title: "Medició exacta del ROI", desc: "Sabràs exactament quants euros de venda ha generat cada euro invertit. Resultats mesurables amb informes transparents." }
];
---

<BaseLayout
  title="Agència Google Ads per a PYMES | Nova Marketing"
  description="Gestió de campanyes de Google Ads orientades a vendes per a pimes. Rentabilitza la teva inversió des del primer dia amb anuncis optimitzats."
  locale="ca"
  alternates={alternates}
  schemas={[semServiceSchema]}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="min-h-[88vh] flex items-center justify-center pt-24 pb-16 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-7xl mx-auto reveal relative z-10">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-6 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Especialistes en Google Ads
            </span>

            <h1 class="text-4xl sm:text-6xl md:text-7xl lg:text-7xl xl:text-8xl uppercase font-black tracking-tighter leading-[0.85] mb-6 text-zinc-900 flex flex-col items-center text-center">
                <span>Agència de</span>
                <span>Google Ads</span>
                <span class="text-mktg-gradient px-4 overflow-visible inline-block">per a pymes</span>
            </h1>

            <p class="text-base sm:text-lg text-zinc-500 font-light leading-relaxed max-w-2xl mx-auto mb-12">
                Gestió de Campanyes en Google Ads orientades a vendes. Rentabilitzem la teva inversió des del primer segon amb objectius de negoci reals.
            </p>

            <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_20px_40px_-10px_rgba(0,0,0,0.15)] hover:shadow-[0_25px_50px_-12px_rgba(0,0,0,0.25)] hover:-translate-y-1 transition-all duration-300 !py-5 !px-12 !text-[12px] !tracking-wider font-black w-full sm:w-auto">
                    SOL·LICITAR AUDITORIA GRATIS
                </a>
            </div>
        </div>
    </section>

    <!-- ═══ LOGOS CLIENTES (SOCIAL PROOF) ══════════════════════════════════ -->
    <LogoMarquee />

    <!-- ═══ SECCIÓN 1: ESTRATEGIA ═══════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6">
        <div class="max-w-4xl mx-auto text-center reveal">
            <h2 class="text-3xl sm:text-5xl lg:text-7xl font-black tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.82]">
                Campanyes Google Ads que sí Generen Clients
            </h2>
            <p class="text-zinc-500 font-light text-base sm:text-lg leading-relaxed w-[75%] mx-auto">
                No cremem el teu pressupost inflant clics buits. Dirigim els anuncis només a usuaris que demostren una clara intenció de compra dels teus serveis per multiplicar el teu retorn d'inversió.
            </p>
        </div>
    </section>

    <!-- ═══ SECCIÓN 2: TIMELINE (ROADMAP) ═══════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <h2 class="text-2xl sm:text-5xl lg:text-7xl font-black tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.85]">
                    La Nostra Metodologia SEM per a PIMES
                </h2>
                <div class="text-zinc-500 w-[75%] mx-auto font-light text-sm sm:text-base leading-relaxed space-y-4">
                    <p>
                        Dissenyam una estratègia que va més enllà d'un simple anunci. Coordinem la cerca amb les teves pàgines d'aterratge perquè l'embut de vendes sigui fluid i altament rendible.
                    </p>
                </div>
            </div>

            <div id="timeline-container" class="relative">
                <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
                <div id="progress-bar" class="hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100" style="height: 0%;"></div>
                
                <div class="space-y-16 md:space-y-24 flex flex-col items-center">
                    {steps.map((step, index) => (
                        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal" style={`transition-delay: ${index * 100}ms`}>
                            <div class="hidden md:block md:flex-1 text-right md:order-1">
                                {index % 2 === 0 && (
                                    <div class="md:pr-12">
                                        <h3 class="text-xl sm:text-2xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{step.title}</h3>
                                        <p class="text-sm text-zinc-500 font-light max-w-md ml-auto">{step.desc}</p>
                                    </div>
                                )}
                            </div>
                            <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all duration-300">
                                0{index + 1}
                            </div>
                            <div class="flex-1 text-left md:order-3">
                                <div class="md:pl-12">
                                    <h3 class:list={["text-xl sm:text-2xl font-black uppercase tracking-tighter mb-2 text-zinc-900", index % 2 === 0 ? "md:hidden" : ""]}>{step.title}</h3>
                                    <p class:list={["text-sm text-zinc-500 font-light max-w-md mr-auto", index % 2 === 0 ? "md:hidden" : ""]}>{step.desc}</p>
                                </div>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ CONTACTO ═══════════════════════════════════════════════════════ -->
    <section id="contacto" class="py-20 sm:py-40 px-4 sm:px-6 relative bg-accent">
        <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-12 sm:gap-20 items-center">
            <div class="reveal text-white">
                <span class="text-[10px] font-black uppercase tracking-[0.5em] mb-6 sm:mb-12 opacity-70 block">AUDITORIA ADS GRATIS</span>
                <h2 class="text-5xl sm:text-8xl font-black uppercase tracking-tighter leading-[0.8] mb-8 sm:mb-12">
                   ANALITZEM <br>LA TEVA COMPTE <br>SENSE COST
                </h2>
                <p class="font-light max-w-md text-base sm:text-xl">Escriu-nos i et donarem un full de ruta amb millores per rendibilitzar la teva inversió.</p>
            </div>

            <div class="reveal">
                <div class="bg-white p-8 sm:p-16 shadow-[0_40px_100px_rgba(0,0,0,0.1)] rounded-sm">
                    <form class="space-y-8 sm:space-y-12" id="contact-form">
                        <div class="grid sm:grid-cols-2 gap-6 sm:gap-12 text-[9px] sm:text-[10px] font-black tracking-widest uppercase">
                            <div class="flex flex-col gap-3 sm:gap-4">
                                <label class="opacity-30">NOM</label>
                                <input type="text" name="name" aria-label="Nombre" required class="border-b border-black/10 py-2 focus:border-accent outline-none">
                            </div>
                            <div class="flex flex-col gap-3 sm:gap-4">
                                <label class="opacity-30">WEB (URL)</label>
                                <input type="url" name="url" aria-label="Sitio web" required class="border-b border-black/10 py-2 focus:border-accent outline-none">
                            </div>
                        </div>
                        <div class="flex flex-col gap-3 sm:gap-4 text-[9px] sm:text-[10px] font-black tracking-widest uppercase">
                            <label class="opacity-30">EMAIL PROFESSIONAL</label>
                            <input type="email" name="email" aria-label="Correo electrónico" required class="border-b border-black/10 py-2 focus:border-accent outline-none">
                        </div>
                        <div class="flex flex-col gap-3 sm:gap-4 text-[9px] sm:text-[10px] font-black tracking-widest uppercase">
                            <label class="opacity-30">CONSULTA ADS</label>
                            <textarea name="msg" aria-label="Mensaje" rows="3" class="border-b border-black/10 py-2 focus:border-accent outline-none resize-none" placeholder="Quin és el teu objectiu?"></textarea>
                        </div>
                        <button type="submit" class="w-full btn-mktg-v5 !py-6 sm:!py-8">REBRE LA MEVA AUDITORIA</button>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ CASOS D'ÈXIT GOOGLE ADS ════════════════════════════════════════ -->
    {pageCases.length > 0 && (
    <section class="py-20 sm:py-32 bg-zinc-50 border-t border-black/5 px-4 sm:px-6">
        <div class="max-w-7xl mx-auto">
            <div class="mb-16 reveal">
                <span class="text-[10px] font-black uppercase tracking-[0.3em] text-accent mb-4 block">Resultats provats</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl uppercase tracking-tighter font-extrabold text-zinc-900 leading-[0.9]">
                    Casos d'èxit de Google Ads<br class="hidden md:inline" /> en pimes
                </h2>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                {pageCases.map((cs: any, i: number) => {
                  const catName = (cs.categories || []).map((c: any) => c.name || c.attributes?.name).filter(Boolean).join(' | ');
                  const caseUrl = cs.isPublic && cs.slug ? `/ca/casos-exit/${cs.slug}/` : null;
                  return (
                    <div class="bg-white p-8 border border-black/5 flex flex-col justify-between group hover:shadow-xl hover:-translate-y-1 transition-all duration-300 rounded-2xl reveal" style={`transition-delay: ${i * 80}ms`}>
                      <div>
                        {catName && <span class="text-[10px] font-black uppercase tracking-widest text-accent mb-4 block">{catName}</span>}
                        <h3 class="text-base font-black uppercase tracking-tight text-zinc-900 mb-3 group-hover:text-accent transition-colors leading-tight">{cs.title}</h3>
                        <p class="text-xs text-zinc-500 font-light leading-relaxed">{cs.description}</p>
                      </div>
                      {caseUrl && (
                        <a href={caseUrl} class="mt-6 text-[9px] font-black tracking-[0.25em] text-accent flex items-center gap-1.5 hover:gap-3 transition-all uppercase">
                          VEURE MÉS <span class="text-sm">→</span>
                        </a>
                      )}
                    </div>
                  );
                })}
            </div>
        </div>
    </section>
    )}

    <!-- ═══ FAQ ════════════════════════════════════════════════════════════ -->
    <FaqHome
        items={faqItems}
        title="Preguntes sobre Google Ads <br /> que ens fan altres pimes"
    />

</BaseLayout>

<script is:inline>
    function initTimeline() {
        const progressBar = document.getElementById('progress-bar');
        const timeline = document.getElementById('timeline-container');
        if (!progressBar || !timeline) return;

        function updateProgress() {
            const rect = timeline.getBoundingClientRect();
            const winHeight = window.innerHeight;
            const topPassed = (winHeight / 2) - rect.top;
            let percentage = (topPassed / rect.height) * 100;
            percentage = Math.max(0, Math.min(100, percentage));
            progressBar.style.height = `${percentage}%`;

            const nodes = timeline.querySelectorAll('.node-circle');
            nodes.forEach((node) => {
                const nodeTop = node.getBoundingClientRect().top;
                if (nodeTop < winHeight / 2) {
                    node.classList.add('!border-accent', '!bg-accent', '!text-white');
                } else {
                    node.classList.remove('!border-accent', '!bg-accent', '!text-white');
                }
            });
        }

        window.addEventListener('scroll', updateProgress);
        document.addEventListener('astro:page-load', updateProgress);
        updateProgress();
    }
    document.addEventListener('DOMContentLoaded', initTimeline);
    document.addEventListener('astro:page-load', initTimeline);
</script>
