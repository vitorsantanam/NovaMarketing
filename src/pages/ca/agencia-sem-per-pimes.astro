---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../lib/i18n';
import { strapiClient } from '../../lib/strapi';
import LogoMarquee from '../../components/sections/LogoMarquee.astro';
import FaqHome from '../../components/sections/FaqHome.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-sem-para-pymes', '/agencia-sem-per-pimes', SITE_URL);

let pageCases: any[] = [];
try {
  const res = await strapiClient.getCaseStudies('ca');
  pageCases = res.data.map((i: any) => i.attributes ?? i).filter((c: any) => {
    const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
    return cats.some((s: string) => s.includes('google-ads') || s.includes('ads'));
  });
} catch {}

const faqItems = [
    {
        question: "Quant de temps triga la meva petita empresa a aparèixer a Google amb els anuncis?",
        answer: "A diferència d'altres estratègies, la publicitat a Google és gairebé immediata. Un cop configurem i activem la campanya de la teva pyme, els teus anuncis poden començar a mostrar-se en qüestió d'hores. És la forma més ràpida de que una petita empresa aconsegueixi visibilitat i contactes nous des del primer dia."
    },
    {
        question: "Cal invertir milers d'euros perquè la meva pyme obtingui resultats?",
        answer: "No, aquesta és la gran avantatge de Google Ads per a les petites i mitjanes empreses. Tu decideixes quant vols invertir al dia. A Nova ens encarreguem d'esprémer cada euro del teu pressupost, optimitzant les campanyes perquè la teva pyme competeixi només en les cerques que realment tenen probabilitat de convertir-se en una venda."
    },
    {
        question: "Què passa si deixo d'invertir en publicitat per a la meva petita empresa?",
        answer: "En ser un sistema de \"pagament per clic\", en el moment en què s'atura la inversió, els anuncis deixen de mostrar-se. Per això, per a les pimes, recomanem combinar Google Ads amb una bona estratègia de captació a llarg termini. No obstant això, mentre la campanya estigui activa, t'assegures un flux constant de clients potencials per a la teva petita empresa."
    },
    {
        question: "Com sabré si els anuncis de mi pyme estan funcionant realment?",
        answer: "La transparència és clau per a nosaltres. Tindràs accés a informes clars on veuràs quantes persones han fet clic, quant ha costat cada contacte i, lo més important, quantes vendes o trucades ha generat la inversió de la teva petita i mitjana empresa. Sabràs exactament quin retorn estàs obtenint pels teus diners."
    },
    {
        question: "Els meus anuncis sortiran només en el cercador o també a Google Maps?",
        answer: "Podem configurar les campanyes de la teva pyme perquè apareguin on més t'interessi: en els resultats de cerca, a Google Maps (ideal per a petites empreses locals) o fins i tot a YouTube. Analitzem on són els teus clients perquè la teva petita i mitjana empresa estigui present just quan ells necessiten el teu servei."
    },
    {
        question: "Per què hauria de contractar una agència en lloc de gestionar jo mateix els anuncis de la meva pyme?",
        answer: "Google Ads és una eina potent però complexa. Un error en la configuració pot fer que una petita empresa gasti el seu pressupost en clics que no compren. A Nova utilitzem la nostra experiència i tecnologia per triar la KW exacta i redactar anuncis que converteixin, evitant que la teva pyme malgasti diners en proves innecessàries."
    }
];

const semServiceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Agència de Google Ads i SEM",
  "name": "Gestió de Campanyes de Google Ads per a Pimes a Catalunya",
  "description": "Agència especialitzada en SEM i Google Ads per a pimes. Maximitza el teu ROI amb campanyes de cerca, display i shopping a Barcelona, el Vallès i tota Catalunya.",
  "provider": {
    "@type": "ProfessionalService",
    "name": "Nova Marketing",
    "url": "https://novamarketing.es",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Carrer de Bilbao 1",
      "addressLocality": "Sabadell",
      "addressRegion": "Barcelona",
      "postalCode": "08202",
      "addressCountry": "ES"
    }
  },
  "areaServed": [
