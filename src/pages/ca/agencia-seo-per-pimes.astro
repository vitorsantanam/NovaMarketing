---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../lib/i18n';
import { strapiClient } from '../../lib/strapi';
import LogoMarquee from '../../components/sections/LogoMarquee.astro';
import FaqHome from '../../components/sections/FaqHome.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-seo-para-pymes', '/agencia-seo-per-pimes', SITE_URL);

const faqItems = [
    {
        question: "Com puc fer que la meva petita empresa aparegui la primera a Google quan algú busca el meu servei?",
        answer: "Perquè la teva pyme pugi llocs, treballem el posicionament analitzant què busca exactament el teu client. Identificem la KW amb major intenció de compra per al teu sector i optimitzem la teva web perquè Google la consideri la millor resposta. L'objectiu és que la teva petita empresa deixi de ser invisible i comenci a captar trànsit de qualitat que realment vulgui contractar-te."
    },
    {
        question: "El meu negoci és local, com m'ajuda el SEO local a atraure clients de la meva ciutat o barri?",
        answer: "Aquí és on entra en joc el SEO Local. Optimizem la teva Google Business Profile (antic Google My Business) perquè, quan algú proper busqui el que ofereixes, la teva petita i mitjana empresa aparegui al mapa amb fotos, horari i ressenyes. És la forma més ràpida i efectiva de que una pyme atregui clients que estan físicament a prop del seu local o oficina."
    },
    {
        question: "Quant de temps trigarà la meva pyme a veure resultats reals amb el posicionament?",
        answer: "El posicionament és una estratègia a mitjà i llarg termini, però molt rentable per a les petites empreses perquè no pagues per cada clic. Normalment, una pyme comença a notar una millora en la seva visibilitat i volum de contactes a partir dels 3 o 6 mesos. És una inversió que construeix un actiu propi per a la teva petita i mitjana empresa que perdura en el temps."
    },
    {
        question: "És necessari tenir una fitxa de Google Business Profile ben gestionada?",
        answer: "És fonamental per a qualsevol petita i mitjana empresa. Una fitxa descuidada o amb mala informació espanta els clients. Nosaltres ens encarreguem de que el perfil de la teva pyme estigui impecable, actualitzat i optimitzat perquè els clients confiïn en tu abans fins i tot d'entrar a la teva web, destacant les teves millors ressenyes i serveis locals."
    },
    {
        question: "La meva petita empresa pot competir amb grans marques a Google?",
        answer: "I tant que sí! L'avantatge de ser una pyme és que pots ser molt més específic i àgil. Mentre les grans empreses van a per tot el mercat, nosaltres enfoquem la teva petita empresa cap a nichos i zones geogràfiques concretes on la competència és menor. Amb una bona estratègia de KW locals, la teva pyme pot guanyar la partida a marques molt més grans en la seva pròpia zona."
    }
];

const seoServiceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Posicionamiento SEO",
  "name": "Servei de SEO Integral per a Pimes a Catalunya",
  "description": "Estratègies avançades de SEO per a pimes. Especialistes en auditoria tècnica, SEO local i posicionament nacional amb cobertura a les principals ciutats de Catalunya.",
  "provider": {
    "@type": "ProfessionalService",
    "name": "Nova Marketing",
    "url": "https://novamarketing.es",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Carrer de Bilbao 1",
      "addressLocality": "Sabadell",
