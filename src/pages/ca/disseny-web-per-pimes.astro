---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../lib/i18n';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/diseno-web-para-pymes', '/disseny-web-per-pimes', SITE_URL);

const steps = [
  { title: "Disseny 100% Responsive", desc: "Adaptem la teva web a qualsevol dispositiu mòbil. Més del 70% dels teus clients potencials et buscaran des d'un smartphone." },
  { title: "Gestor Autogestionable", desc: "Pren el control del teu contingut. Puja imatges, actualitza textos o afegeix serveis tu mateix sense dependre de tècnics." },
  { title: "Optimització de Càrrega", desc: "Webs ultraràpides. Google premia la velocitat i els usuaris detesten esperar. No perdràs cap venda per lentitud." },
  { title: "Estructura SEO-Friendly", desc: "Dissenyam bases netes. El teu codi estarà preparat perquè el posicionament de la teva web a Google sigui molt més àgil." }
];

const benefits = [
  { title: "Tot Inclòs", desc: "Domini, Allotjament SSD d'alta velocitat i correus corporatius configurats des del primer moment sense costos ocults." },
  { title: "WhatsApp i Xarxes Unides", desc: "Integració nativa amb els teus canals de comunicació perquè les visites puguin contactar amb un sol clic." },
  { title: "Màxima Seguretat Legal", desc: "Certificat de seguretat SSL encriptat i adaptació completa a la Llei de Protecció de Dades (RGPD) europea." },
  { title: "Desenvolupament web propi", desc: "Desenvolupem la pàgina web a mida perquè compleixi amb totes les teves necessitats i estigui optimitzada per al SEO." }

];
---

<BaseLayout
  title="Disseny de Pàgines Web per a Pimes | Web Professional | Nova Marketing"
  description="Creamos la web profesional que la tuva empresa necesita para crecer. Diseños adaptables, ultrarrápidos y 100% enfocados a captar clientes."
  locale="ca"
  alternates={alternates}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="pt-24 sm:pt-40 pb-20 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <!-- Background Grid Mesh -->
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>

        <!-- Glow Orbs -->
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-5xl mx-auto reveal">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-8 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Especialistes en Disseny Web
            </span>
            <h1 class="text-3xl sm:text-5xl md:text-7xl lg:text-8xl uppercase font-extrabold tracking-tighter leading-[0.88] mb-8 text-gradient flex flex-col items-center text-center">
                Disseny de Pàgines <br /> Web per a Pimes
            </h1>

            <p class="text-lg sm:text-xl text-zinc-500 font-light leading-relaxed w-[75%] mx-auto mb-10">
                Creamos la web profesional que la teva empresa necessita per a créixer. Dissenys adaptables, ultraràpids i 100% enfocats a captar clients.
            </p>
            <div class="flex justify-center mt-4">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(0,0,0,0.1)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    SOL·LICITAR PRESSUPOST WEB
                </a>
            </div>
        </div>
    </section>

    <!-- ═══ SECCIÓN 1: ESTRATEGIA ═══════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6">
        <div class="max-w-4xl mx-auto text-center reveal">
            <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                El teu aparador digital 24/7 sense problemes
            </h2>
            <p class="text-zinc-500 font-light text-base sm:text-lg leading-relaxed w-[75%] mx-auto">
                No fem webs per omplir espai. Dissenyam pàgines pensades per a l'usuari d'avui, resolent els seus dubtes de forma visual, transmetent confiança i aconseguint un embut de conversió net.
            </p>
        </div>
    </section>

    <!-- ═══ SECCIÓN 2: CÓMO TRABAJAMOS (ROADMAP) ════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Característiques de la tèva nova web
                </h2>
                <div class="text-zinc-500 w-[75%] mx-auto font-light text-sm sm:text-base leading-relaxed space-y-4">
                    <p>
                        Cuidem cada detall tècnic perquè no hagis de preocupar-te de res. Rendiment, estructura i usabilitat garantits.
                    </p>
                </div>
            </div>

            <div id="timeline-container" class="relative">
                <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
                <div id="progress-bar" class="hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100" style="height: 0%;"></div>
                
                <div class="space-y-16 md:space-y-24 flex flex-col items-center">
                    {steps.map((step, index) => (
                        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal" style={`transition-delay: ${index * 100}ms`}>
                            
                            <div class="hidden md:block md:flex-1 text-right md:order-1">
                                {index % 2 === 0 && (
                                    <div class="md:pr-12">
                                        <h3 class="text-xl sm:text-2xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{step.title}</h3>
                                        <p class="text-sm text-zinc-500 font-light max-w-md ml-auto">{step.desc}</p>
                                    </div>
                                )}
                            </div>
                            
                            <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all duration-300">
                                0{index + 1}
                            </div>

                            <div class="flex-1 text-left md:order-3">
                                <div class="md:pl-12">
                                    <h3 class:list={["text-xl sm:text-2xl font-black uppercase tracking-tighter mb-2 text-zinc-900", index % 2 === 0 ? "md:hidden" : ""]}>{step.title}</h3>
                                    <p class:list={["text-sm text-zinc-500 font-light max-w-md mr-auto", index % 2 === 0 ? "md:hidden" : ""]}>{step.desc}</p>
                                </div>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ SECCIÓN 3: BENEFICIOS (CARDS) ══════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50/50 px-4 sm:px-6 relative overflow-hidden border-t border-black/5">
        <!-- Deco meshes -->
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808005_1px,transparent_1px),linear-gradient(to_bottom,#80808005_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_50%,#000_80%,transparent_100%)]"></div>
        <div class="absolute -top-40 right-1/4 w-96 h-96 bg-accent/10 rounded-full blur-3xl opacity-20 animate-pulse"></div>
        <div class="absolute -bottom-40 left-1/4 w-96 h-96 bg-purple-500/10 rounded-full blur-3xl opacity-10"></div>
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-4 text-zinc-900 leading-[0.9]">
                    Què inclou el nostre servei de Disseny Web?
                </h2>
                <p class="text-zinc-500 w-[75%] mx-auto font-light text-sm sm:text-base">Transparència total per al creixement de la teva petita empresa.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                {benefits.map((benefit, i) => (
                    <div class="group p-8 border border-black/5 bg-white rounded-sm hover:border-black/20 hover:shadow-[0_20px_50px_rgba(0,0,0,0.03)] transition-all duration-500 reveal" style={`transition-delay: ${i * 100}ms`}>
                        <div class="h-1 bg-black w-12 group-hover:w-full transition-all duration-500 mb-6"></div>
                        <h3 class="text-xl sm:text-2xl font-black uppercase tracking-tighter mb-4 text-zinc-900 h-14 sm:h-16">{benefit.title}</h3>
                        <p class="text-sm text-zinc-500 font-light leading-relaxed">{benefit.desc}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ═══ SECCIÓN 4: PORTFOLIO / CASOS ══════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
        <div class="max-w-7xl mx-auto">
            <div class="mb-16 sm:mb-24 reveal">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Nuestro Portafolio</span>
                <h2 class="text-3xl sm:text-5xl lg:text-7xl uppercase tracking-tighter font-extrabold mb-2 text-zinc-900 leading-[0.9]">
                    Proyectes de disseny web reals
                </h2>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 reveal">
                <div class="bg-zinc-50 p-8 border border-black/5 flex flex-col justify-between h-full group hover:shadow-[0_20px_60px_rgba(0,0,0,0.05)] transition-all">
                    <div>
                        <span class="text-[10px] font-black uppercase tracking-widest text-accent mb-4 block">WEB CORPORATIVA</span>
                        <h3 class="text-xl font-black uppercase tracking-tighter mb-4 group-hover:text-accent transition-colors">Estudi Arquitectura</h3>
                        <p class="text-xs text-zinc-500 font-light leading-relaxed mb-6">Disseny minimalista i net optimitzat per a resoldre dubtes visuals i captar leads.</p>
                    </div>
                    <div class="text-2xl font-black tracking-tighter text-black mt-4">Redissenyo Pro</div>
                </div>

                <div class="bg-zinc-50 p-8 border border-black/5 flex flex-col justify-between h-full group hover:shadow-[0_20px_60px_rgba(0,0,0,0.05)] transition-all" style="transition-delay: 100ms">
                    <div>
                        <span class="text-[10px] font-black uppercase tracking-widest text-accent mb-4 block">E-COMMERCE Venda</span>
                        <h3 class="text-xl font-black uppercase tracking-tighter mb-4 group-hover:text-accent transition-colors">Botiga de Moda Calçat</h3>
                        <p class="text-xs text-zinc-500 font-light leading-relaxed mb-6">Augment de conversions un 55% gràcies a una experiència de checkout ágil.</p>
                    </div>
                    <div class="text-2xl font-black tracking-tighter text-black mt-4">+55% Conversió</div>
                </div>

                <div class="bg-zinc-50 p-8 border border-black/5 flex flex-col justify-between h-full group hover:shadow-[0_20px_60px_rgba(0,0,0,0.05)] transition-all" style="transition-delay: 200ms">
                    <div>
                        <span class="text-[10px] font-black uppercase tracking-widest text-accent mb-4 block">LANDING PAGE</span>
                        <h3 class="text-xl font-black uppercase tracking-tighter mb-4 group-hover:text-accent transition-colors">Serveis Consultoria</h3>
                        <p class="text-xs text-zinc-500 font-light leading-relaxed mb-6">Estructura d'una sola pàgina enllaçada a campanyes per captació de leads rècord.</p>
                    </div>
                    <div class="text-2xl font-black tracking-tighter text-black mt-4">Multiplica Captació</div>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ CONTACTO (v6 Form) ════════════════════════════════════════════ -->
    <section id="contacto" class="py-20 sm:py-40 px-4 sm:px-6 relative bg-accent">
        <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-12 sm:gap-20 items-center">
            
            <div class="reveal text-white">
                <span class="text-[10px] font-black uppercase tracking-[0.5em] mb-6 sm:mb-12 opacity-70 block">PRESSUPOST SENSE COMPROMÍS</span>
                <h2 class="text-5xl sm:text-8xl font-black uppercase tracking-tighter leading-[0.8] mb-8 sm:mb-12">
                   ESTRENA <br>LA TEVA <br>WEB AVUI
                </h2>
                <p class="font-light max-w-md text-base sm:text-xl">Escriu-nos i et donarem una proposta a mida per a la teva petita empresa.</p>
            </div>

            <div class="reveal">
                <div class="bg-white p-8 sm:p-16 shadow-[0_40px_100px_rgba(0,0,0,0.1)] rounded-sm">
                    <form class="space-y-8 sm:space-y-12" id="contact-form">
                        <div class="grid sm:grid-cols-2 gap-6 sm:gap-12 text-[9px] sm:text-[10px] font-black tracking-widest uppercase">
                            <div class="flex flex-col gap-3 sm:gap-4">
                                <label class="opacity-30">NOM</label>
                                <input type="text" name="name" aria-label="Nombre" required class="border-b border-black/10 py-2 focus:border-accent outline-none">
                            </div>
                            <div class="flex flex-col gap-3 sm:gap-4">
                                <label class="opacity-30">TELÈFON</label>
                                <input type="tel" name="phone" class="border-b border-black/10 py-2 focus:border-accent outline-none">
                            </div>
                        </div>
                        <div class="flex flex-col gap-3 sm:gap-4 text-[9px] sm:text-[10px] font-black tracking-widest uppercase">
                            <label class="opacity-30">EMAIL PROFESSIONAL</label>
                            <input type="email" name="email" aria-label="Correo electrónico" required class="border-b border-black/10 py-2 focus:border-accent outline-none">
                        </div>
                        <div class="flex flex-col gap-3 sm:gap-4 text-[9px] sm:text-[10px] font-black tracking-widest uppercase">
                            <label class="opacity-30">TIPUS DE PROJECTE</label>
                            <textarea name="msg" aria-label="Mensaje" rows="3" class="border-b border-black/10 py-2 focus:border-accent outline-none resize-none" placeholder="Què necessites per a la teva web?"></textarea>
                        </div>
                        <button type="submit" class="w-full btn-mktg-v5 !py-6 sm:!py-8">REBRE PRESSUPOST</button>
                    </form>
                </div>
            </div>
        </div>
    </section>

</BaseLayout>

<script>
    document.getElementById('contact-form')?.addEventListener('submit', (e) => {
        e.preventDefault();
        const btn = (e.target as HTMLFormElement).querySelector('button');
        if (btn) {
            btn.innerHTML = '¡SOL·LICITUD ENVIADA!';
            btn.style.background = '#000000';
        }
    });

    function initTimeline() {
        const progressBar = document.getElementById('progress-bar');
        const timeline = document.getElementById('timeline-container');
        if (!progressBar || !timeline) return;

        function updateProgress() {
            const rect = timeline.getBoundingClientRect();
            const winHeight = window.innerHeight;
            const topPassed = (winHeight / 2) - rect.top;
            let percentage = (topPassed / rect.height) * 100;
            percentage = Math.max(0, Math.min(100, percentage));
            progressBar.style.height = `${percentage}%`;

            const nodes = timeline.querySelectorAll('.node-circle');
            nodes.forEach((node) => {
                const nodeTop = node.getBoundingClientRect().top;
                if (nodeTop < winHeight / 2) {
                    node.classList.add('!border-accent', '!bg-accent', '!text-white');
                } else {
                    node.classList.remove('!border-accent', '!bg-accent', '!text-white');
                }
            });
        }

        window.addEventListener('scroll', updateProgress);
        document.addEventListener('astro:page-load', updateProgress);
        updateProgress();
    }
    document.addEventListener('DOMContentLoaded', initTimeline);
    document.addEventListener('astro:page-load', initTimeline);
</script>
