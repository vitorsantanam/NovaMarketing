  "@type": "Service",
  "serviceType": "Disseny Web per a Pimes",
  "name": "Disseny de Pàgines Web i Botigues Online per a Pimes a Catalunya",
  "description": "Agència de disseny web especialitzada en pimes i autònoms. Creem webs corporatives, landing pages i ecommerce optimitzats per a Google a tota Catalunya.",
  "provider": {
    "@type": "ProfessionalService",
    "name": "Nova Marketing",
    "url": "https://novamarketing.es",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Carrer de Bilbao 1",
      "addressLocality": "Sabadell",
      "addressRegion": "Barcelona",
      "postalCode": "08202",
