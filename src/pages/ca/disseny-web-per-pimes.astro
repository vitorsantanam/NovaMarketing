---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../lib/i18n';
import { strapiClient } from '../../lib/strapi';
import LogoMarquee from '../../components/sections/LogoMarquee.astro';
import FaqHome from '../../components/sections/FaqHome.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/diseno-web-para-pymes', '/disseny-web-per-pimes', SITE_URL);

let pageCases: any[] = [];
try {
  const res = await strapiClient.getCaseStudies('ca');
  pageCases = res.data.map((i: any) => i.attributes ?? i).filter((c: any) => {
    const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
    return cats.some((s: string) => s.includes('diseno-web') || s.includes('web') || s.includes('disseny'));
  });
} catch {}

const faqItems = [
    {
        question: "Quin tipus de pàgina web necessita la meva pyme per començar?",
        answer: "Tot depèn del teu objectiu. Si busques donar una imatge professional i explicar els teus serveis, una web corporativa és ideal per a la teva petita empresa. Si el que vols és vendre productes directament, necessites un ecommerce o botiga online. A Nova analitzem el teu model de negoci per recomanar-te l'opció que millor retorn d'inversió ofereixi a la teva petita i mitjana empresa."
    },
    {
        question: "Què és una landing page i per què la meva petita empresa podria necessitar-ne una?",
        answer: "Una landing page (o pàgina d'aterratge) és una web d'una sola pàgina dissenyada exclusivament perquè l'usuari realitzi una acció, com trucar o omplir un formulari. És l'eina més potent per a les pimes que fan campanyes de publicitat, ja que eliminen distraccions i multipliquen les possibilitats d'aconseguir clients per a la teva petita empresa."
    },
    {
        question: "Podré gestionar jo mateix la botiga online o la web de la meva pyme?",
        answer: "Sí, totalment. Dissenyam pàgines web per a petites i mitjanes empreses que són fàcils d'usar i autogestionables. Un cop acabem el projecte, la teva pyme tindrà total autonomia per pujar nous productes al teu ecommerce, canviar textos o pujar notícies sense dependre de nosaltres per a cada petit canvi."
    },
    {
        question: "La web de la meva petita empresa estarà preparada per aparèixer a Google?",
        answer: "Des del primer minut. No només creem webs boniques, sinó que les optimitzem tècnicament perquè Google les vegi amb bons ulls. Realitzem una estructura basada en la KW més important del teu sector perquè la teva petita i mitjana empresa tingui una base sòlida des de la qual començar a treballar el seu posicionament orgànic."
    },
    {
        question: "Es veurà bé la pàgina de la meva pyme en telèfons mòbils?",
        answer: "Avui dia, la majoria dels clients d'una petita empresa accedeixen des del mòbil. Per això, tots els nostres dissenys són \"responsive\", el que significa que la web de la teva pyme s'adaptarà perfectament a qualsevol dispositiu (mòbil, tauleta o ordinador), garantint una experiència d'usuari professional i ràpida."
    },
    {
        question: "Quant de temps triga a estar llista la web de la meva petita i mitjana empresa?",
        answer: "Els temps varien segons la complexitat. Una landing page pot estar llista en pocs dies, mentre que una web corporativa completa o un ecommerce amb molts productes requereix més temps de desenvolupament. En qualsevol cas, a la nostra agència treballem amb terminis ajustats perquè sabem que la teva pyme no pot permetre's perdre oportunitats de negoci."
    }
];

const webDesignServiceSchema = {
