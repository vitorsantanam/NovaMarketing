---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../lib/i18n';
import { strapiClient } from '../../lib/strapi';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-diseno-web-sabadell/', '/ca/agencia-disseny-web-sabadell/', SITE_URL);

const faqItems = [
  {
    question: "Per què necessita la meva empresa de Sabadell una web professional?",
    answer: "A Sabadell, el 87% dels consumidors cerca empreses locals a Google abans de contactar. Si la teva web no és professional, ràpida i orientada a convertir, estàs perdent clients davant de competidors de l'Eix Macià o el centre que sí que tenen una presència digital sòlida. Una web ben dissenyada és el teu millor venedor disponible 24/7."
  },
  {
    question: "Quant costa dissenyar una web per a una empresa de Sabadell?",
    answer: "El preu varia segons el tipus de projecte: una web corporativa per a una pime del Vallès part des de 1.500€, mentre que una botiga online completa pot oscil·lar entre 3.000€ i 8.000€. Treballem amb empreses de totes les mides a Sabadell, des d'autònoms del centre fins a industrials de Can Roqueta, adaptant cada proposta al pressupost i els objectius reals."
  },
  {
    question: "Què diferencia una web que ven d'una que no converteix al mercat de Sabadell?",
    answer: "Una web que converteix a Sabadell està dissenyada amb el perfil del client local al cap: carrega ràpid al mòbil, té trucades a l'acció clares, transmet confiança i està optimitzada perquè Google la mostri quan algú cerca el teu servei al Vallès. No n'hi ha prou amb tenir una web bonica; necessita estar orientada a resultats mesurables."
  },
  {
    question: "Quant temps tarda el disseny d'una web per a una pime de l'Eix Macià o el centre de Sabadell?",
    answer: "Un projecte web estàndard per a una pime de Sabadell tarda entre 3 i 6 setmanes des del briefing fins al llançament. Projectes més complexos, com botigues online o webs amb integració de sistemes, poden requerir 8-12 setmanes. Des de l'inici t'assignem un Account Manager dedicat que et manté informat de cada avenç."
  },
  {
    question: "Poden les empreses industrials dels polígons de Sabadell beneficiar-se d'una web ben dissenyada?",
    answer: "Absolutament. Les empreses B2B dels polígons industrials de Can Roqueta, Can Feu i la zona del Vallès Occidental tenen molt a guanyar amb una web professional. Els seus clients —altres empreses— també cerquen proveïdors a Google. Una web dissenyada per al sector industrial genera pressupostos i contractes, no només visites."
  },
  {
    question: "Incloeu optimització SEO en el disseny web per a Sabadell?",
    answer: "Sí. Totes les nostres webs per a empreses de Sabadell es construeixen des del primer dia amb les bases tècniques del SEO: estructura d'URLs neta, velocitat de càrrega optimitzada, dades estructurades, etiquetes correctes i contingut orientat a les cerques reals dels teus clients al Vallès. Això et dóna avantatge a Google des del dia del llançament."
  },
  {
    question: "Dissenyeu botigues online per a comerços del centre de Sabadell?",
    answer: "Sí. Dissenyem e-commerce per a comerços de Sabadell —ja sigui al carrer de Gràcia, la zona del Mercat Central o l'Eix Macià— integrant passarel·les de pagament, gestió d'inventari i experiències de compra optimitzades per a mòbil. Molts negocis locals de Sabadell han multiplicat les seves vendes en unir botiga física i presència digital."
  },
  {
    question: "Com us diferenciàreu d'altres agències de disseny web a Sabadell?",
    answer: "A diferència de moltes agències que només entreguen una web bonica, nosaltres dissenyem orientats a conversió i resultat. Coneixem el mercat del Vallès Occidental —els seus sectors industrials, el seu teixit comercial, el perfil del consumidor de Sabadell— i construïm webs que no només agraden, sinó que generen clients reals. A més, oferim seguiment i millora contínua post-llançament."
  },
  {
    question: "Podeu redissenyar la meva web actual per captar més clients a Sabadell?",
    answer: "Sí. Si tens una web que no converteix, fem una anàlisi UX i de rendiment per identificar els punts de fuga. Moltes empreses de Sabadell ens contacten perquè la seva web existeix però no genera resultats. El redisseny orientat a conversió pot transformar una web invisible en la principal font de leads del teu negoci al Vallès."
  },
  {
    question: "Funciona el disseny web per a empreses B2B del Vallès Occidental?",
    answer: "Sí, i molt més del que molts pensen. Les empreses industrials i de serveis B2B de Sabadell i el Vallès Occidental que inverteixen en una web professional aconsegueixen més sol·licituds de pressupost, milloren la seva imatge davant de clients de fora del Vallès i redueixen el cicle de venda perquè la web ja fa part de la feina de presentació i credibilitat."
  }
];

let webCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('ca');
  webCases = casesRes.data
    .map((i: any) => i.attributes ?? i)
    .filter((c: any) => {
      const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
      return cats.some((s: string) => s.includes('web') || s.includes('dise') || s.includes('disse'));
    });
} catch {}

const steps = [
  { title: "Anàlisi i Estratègia Web a Sabadell", desc: "Estudiem el teu negoci i el teu mercat local al Vallès Occidental. Tant si estàs a l'Eix Macià com als polígons industrials de Can Roqueta, definim una arquitectura web orientada a captar exactament els teus clients a Sabadell." },
  { title: "Disseny UX Personalitzat", desc: "Creem prototips i dissenys adaptats al perfil del client de Sabadell. L'experiència d'usuari flueix tan naturalment com un passeig per la Rambla: sense friccions, clara i amb objectius definits a cada pantalla." },
  { title: "Desenvolupament i Maquetació", desc: "Construïm la teva web amb tecnologia moderna, ràpida i segura. Cada línia de codi està pensada perquè el teu negoci destaqui a Google tant a Sabadell com a tota la comarca del Vallès Occidental i més enllà." },
  { title: "Optimització SEO i Velocitat", desc: "Abans de llançar, auditem velocitat, SEO tècnic i compatibilitat mòbil. La teva web sortirà preparada per competir a Google des del primer dia, visible per als clients que cerquen els teus serveis a Creu Alta, Can Feu o el centre de Sabadell." },
  { title: "Llançament i Millora Contínua", desc: "El llançament és l'inici, no el final. Analitzem el comportament dels teus visitants del Vallès i millorem contínuament la teva web per maximitzar les conversions i el retorn de la inversió mes a mes." }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Agència de Disseny Web per a Pimes",
  "provider": {
    "@type": "ProfessionalService",
    "@id": "https://novamarketing.es/#organization",
    "name": "Nova Marketing",
    "image": "https://novamarketing.es/agencia-marketing-pymes-nova-marketing-logo.png",
    "telephone": "+34644738270",
    "priceRange": "€€",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Carrer de Bilbao 1",
      "addressLocality": "Sabadell",
      "addressRegion": "Barcelona",
      "postalCode": "08202",
      "addressCountry": "ES"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "31"
    }
  },
  "areaServed": {
    "@type": "City",
    "name": "Sabadell",
    "sameAs": "https://www.wikidata.org/wiki/Q12258"
  },
  "description": "Experts en disseny de pàgines web i desenvolupament orientat a conversió per a petites i mitjanes empreses a Sabadell. Creem llocs web moderns, ràpids i optimitzats per captar clients al Vallès Occidental.",
  "offers": {
    "@type": "Offer",
    "priceRange": "€€"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Serveis de Disseny i Desenvolupament Web",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Disseny Web Corporatiu" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Desenvolupament de Botigues Online (E-commerce)" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Optimització de Velocitat i WPO" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Manteniment Web i Seguretat" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Redisseny i UX (Experiència d'Usuari)" } }
    ]
  }
};
---

<BaseLayout
  title="Agència de Disseny Web a Sabadell | Nova Marketing"
  description="Dissenyem pàgines web que converteixen per a empreses de Sabadell. Webs ràpides, optimitzades i orientades a captar clients al Vallès Occidental. Sol·licita pressupost."
  locale="ca"
  alternates={alternates}
  schemas={[serviceSchema, faqSchema]}
>

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[88vh] flex items-center justify-center pt-24 pb-16 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
    <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
    <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>
    <div class="max-w-7xl mx-auto reveal relative z-10">
      <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-6 shadow-sm">
        <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
        Especialistes en Disseny Web a Sabadell
      </span>
      <h1 class="text-4xl sm:text-6xl md:text-7xl lg:text-[5.5rem] uppercase font-black tracking-tighter leading-[0.82] mb-8 text-zinc-900 flex flex-col items-center text-center">
        <span>Agència de</span>
        <span>Disseny Web a</span>
        <span class="text-mktg-gradient px-4 overflow-visible inline-block">Sabadell</span>
      </h1>
      <p class="text-base sm:text-lg text-zinc-500 font-light leading-relaxed max-w-2xl mx-auto mb-12">
        Dissenyem pàgines web que converteixen visites en clients per a empreses de Sabadell. Des de l'Eix Macià fins als polígons industrials de Can Roqueta, creem webs modernes, ràpides i orientades a resultats reals al Vallès Occidental.
      </p>
      <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
        <button class="contact-modal-trigger btn-mktg-v5 shadow-[0_20px_40px_-10px_rgba(0,0,0,0.15)] hover:shadow-[0_25px_50px_-12px_rgba(0,0,0,0.25)] hover:-translate-y-1 transition-all duration-300 !py-5 !px-12 !text-[12px] !tracking-wider font-black w-full sm:w-auto">
          SOL·LICITAR PRESSUPOST GRATIS
        </button>
      </div>
    </div>
  </section>

  <!-- ═══ LOGOS CLIENTS ═══ -->
  <section class="py-12 border-b border-black/5 bg-zinc-50/40 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="text-[9px] sm:text-[10px] uppercase font-black tracking-widest text-zinc-400 text-center mb-8">Pimes que ja estrenen web amb Nova</p>
      <div class="overflow-hidden w-full relative [mask-image:linear-gradient(to_right,transparent,white_10%,white_90%,transparent)]">
        <div id="logos-marquee-ca-sab" class="flex items-center gap-16 w-max animate-scroll-logo-ca-sab"></div>
      </div>
    </div>
  </section>
  <style>
    @keyframes scrollMarqueeLogoCASab { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
    .animate-scroll-logo-ca-sab { animation: scrollMarqueeLogoCASab 60s linear infinite; }
  </style>
  <script is:inline>
    (function() {
      var logos = [
        { src: "/clients/bermaq-cliente-novamarketing.webp", alt: "Bermaq" },
        { src: "/clients/cb-lhospitalet-cliente-novamarketing.webp", alt: "CB l'Hospitalet" },
        { src: "/clients/medhs-cliente-novamarketing.webp", alt: "MedHS" },
        { src: "/clients/palacio-del-bebe-cliente-novamarketing.webp", alt: "Palacio del bebé" },
        { src: "/clients/tagtio-cliente-novamarketing.webp", alt: "Tagtio" },
        { src: "/clients/tejados-tapar-cliente-novamarketing.webp", alt: "Tejados Tapar" },
        { src: "/clients/fastpoint-cliente-novamarketing.webp", alt: "FastPoint" },
        { src: "/clients/mundeta-cliente-novamarketing.webp", alt: "Mundeta" },
        { src: "/clients/tattoox-cliente-novamarketing.webp", alt: "TattooX" },
        { src: "/clients/voltura-projects-cliente-novamarketing.webp", alt: "Voltura Projects" }
      ];
      var shuffled = logos.sort(function() { return Math.random() - 0.5; });
      var full = shuffled.concat(shuffled, shuffled, shuffled);
      var c = document.getElementById('logos-marquee-ca-sab');
      if (c) c.innerHTML = full.map(function(l) { return '<img src="' + l.src + '" alt="' + l.alt + '" class="h-[50px] w-auto object-contain filter grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-300 pointer-events-none" style="mix-blend-mode:multiply" />'; }).join('');
    })();
  </script>

  <!-- ═══ EXPERTS EN DISSENY WEB A SABADELL ═══ -->
  <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808005_1px,transparent_1px),linear-gradient(to_bottom,#80808005_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_50%,#000_80%,transparent_100%)]"></div>
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 sm:mb-24 reveal">
        <h2 class="text-3xl sm:text-5xl lg:text-7xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.82]">
          Experts en Disseny Web<br class="hidden sm:inline" /> a Sabadell
        </h2>
        <p class="text-zinc-500 font-light text-base sm:text-lg leading-relaxed max-w-2xl mx-auto">
          No fem webs genèriques. Dissenyem llocs web orientats al mercat del Vallès Occidental, pensats per al tipus de client que cerca el teu negoci a Sabadell i el seu entorn.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 items-stretch">
        {[
          { title: "Webs que Venen", desc: "Creem llocs web orientats a captar clients a Sabadell, optimitzats per convertir visitants en leads reals. Cada element del disseny té un propòsit comercial." },
          { title: "Disseny UX Sabadell", desc: "Experiències digitals pensades per al perfil del client del Vallès, des del comerç del centre de Sabadell fins a l'empresa industrial del polígon de Can Feu." },
          { title: "Rendiment i Velocitat", desc: "Webs ràpides i optimitzades per a Google. En el mercat competitiu de Sabadell i el Vallès Occidental, una web lenta perd clients abans que et coneguin." },
          { title: "SEO des del Primer Dia", desc: "Estructures web preparades per posicionar a Google des del primer clic, captant clients que cerquen els teus serveis a Sabadell, Creu Alta, Can Feu i tota la comarca." }
        ].map((s, i) => (
          <div class="group flex flex-col justify-between p-8 sm:p-10 h-full bg-white rounded-3xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden reveal flex-1">
            <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
            <div class="absolute -bottom-6 -right-4 text-9xl font-black text-black/2 group-hover:text-accent/[0.04] transition-all duration-500 select-none">0{i + 1}</div>
            <div class="relative z-10 flex flex-col h-full justify-between">
              <div>
                <div class="p-3 bg-zinc-50 border border-black/5 w-fit rounded-xl mb-6 group-hover:bg-accent/5 transition-colors">
                  <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                </div>
                <h3 class="text-xl sm:text-2xl uppercase mb-3 tracking-tighter group-hover:text-accent font-black text-zinc-900 border-b border-zinc-100 pb-2 w-fit">{s.title}</h3>
                <p class="text-xs sm:text-sm text-zinc-500 leading-relaxed font-light">{s.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ TIMELINE / PROCÉS ═══ -->
  <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16 sm:mb-24 reveal">
        <h2 class="text-2xl sm:text-5xl lg:text-7xl font-black tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.85]">
          Com dissenyem la teva web a Sabadell
        </h2>
        <div class="text-zinc-500 w-[75%] mx-auto font-light text-sm sm:text-base leading-relaxed">
          <p>Un procés clar i transparent amb un <strong>Account Manager dedicat</strong> que treballa mà a mà amb el teu equip. Cada fase està pensada perquè el teu negoci a Sabadell tingui una web que generi resultats reals des del primer dia.</p>
        </div>
      </div>
      <div id="timeline-container" class="relative timeline-container">
        <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
        <div class="progress-bar hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100" style="height: 0%;"></div>
        <div class="space-y-16 md:space-y-24 flex flex-col items-center">
          {steps.map((step, index) => (
            <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal" style={`transition-delay: ${index * 100}ms`}>
              <div class="hidden md:block md:flex-1 text-right md:order-1">
                {index % 2 === 0 && (
                  <div class="md:pr-12">
                    <h3 class="text-xl sm:text-2xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{step.title}</h3>
                    <p class="text-sm text-zinc-500 font-light max-w-md ml-auto">{step.desc}</p>
                  </div>
                )}
              </div>
              <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all duration-300">0{index + 1}</div>
              <div class="flex-1 text-left md:order-3">
                <div class="md:pl-12">
                  <h3 class:list={["text-xl sm:text-2xl font-black uppercase tracking-tighter mb-2 text-zinc-900", index % 2 === 0 ? "md:hidden" : ""]}>{step.title}</h3>
                  <p class:list={["text-sm text-zinc-500 font-light max-w-md mr-auto", index % 2 === 0 ? "md:hidden" : ""]}>{step.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
  <style>
    .timeline-container .reveal { opacity: 0; transform: translateY(20px); transition: all 0.6s cubic-bezier(0.165, 0.84, 0.44, 1); }
    .timeline-container .reveal.active { opacity: 1; transform: translateY(0); }
  </style>
  <script is:inline>
    function initTimeline() {
      var timeline = document.getElementById('timeline-container');
      var progressBar = timeline && timeline.querySelector('.progress-bar');
      function updateProgress() {
        if (!timeline || !progressBar) return;
        var rect = timeline.getBoundingClientRect();
        var winHeight = window.innerHeight;
        var topPassed = (winHeight / 2) - rect.top;
        var percentage = Math.max(0, Math.min(100, (topPassed / rect.height) * 100));
        progressBar.style.height = percentage + '%';
        timeline.querySelectorAll('.node-circle').forEach(function(node) {
          if (node.getBoundingClientRect().top < winHeight / 2) { node.classList.add('!border-accent', '!bg-accent', '!text-white'); }
          else { node.classList.remove('!border-accent', '!bg-accent', '!text-white'); }
        });
      }
      window.addEventListener('scroll', updateProgress);
      document.addEventListener('astro:page-load', updateProgress);
      updateProgress();
    }
    document.addEventListener('DOMContentLoaded', initTimeline);
    document.addEventListener('astro:page-load', initTimeline);
  </script>

  <!-- ═══ CONSULTOR DISSENY WEB ═══ -->
  <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
    <div class="max-w-6xl mx-auto reveal">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
        <div class="md:col-span-5 relative group flex justify-center">
          <div class="absolute inset-0 bg-accent/20 rounded-full blur-3xl opacity-30 group-hover:scale-105 transition-transform duration-500"></div>
          <div class="relative w-full max-w-sm">
            <div class="absolute -top-6 -left-6 w-24 h-24 bg-[radial-gradient(#000000_15%,transparent_15%)] bg-[length:12px_12px] opacity-20"></div>
            <div class="overflow-hidden rounded-[2rem] shadow-[0_30px_60px_-15px_rgba(0,0,0,0.1)] border-4 border-white">
              <img src="/img/consultor-de-seo-en-sabadell.webp" alt="Consultor de Disseny Web a Sabadell" class="w-full h-auto object-cover">
            </div>
            <div class="absolute -bottom-4 -right-4 backdrop-blur-md bg-black/90 text-white px-6 py-4 rounded-xl shadow-xl flex items-center gap-3 border border-white/10">
              <div class="w-2 h-2 bg-accent rounded-full animate-pulse"></div>
              <div class="text-[10px] sm:text-xs font-black uppercase tracking-widest">Disseny Web Sabadell</div>
            </div>
          </div>
        </div>
        <div class="md:col-span-7 text-left">
          <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.4em] text-accent mb-4 block">Disseny i Desenvolupament Web</span>
