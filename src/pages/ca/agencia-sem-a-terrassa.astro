---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildAlternates } from '../../lib/i18n';
import { strapiClient } from '../../lib/strapi';
import LogoMarquee from '../../components/sections/LogoMarquee.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-sem-en-terrassa', '/ca/agencia-sem-a-terrassa', SITE_URL);

let pageCases: any[] = [];
try {
  const res = await strapiClient.getCaseStudies('ca');
  pageCases = res.data.map((i: any) => i.attributes ?? i).filter((c: any) => {
    const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
    return cats.some((s: string) => s.includes('google-ads') || s.includes('ads'));
  });
} catch {}

const steps = [
  {
    title: "Anàlisi del mercat de Terrassa",
    desc: "Estudiem la competència local a Google Ads dins de Terrassa, des dels comerços de l'Eix del Parc fins a les empreses industrials de Les Arenes i Ca n'Anglada, per trobar els buits d'oportunitat amb menor CPC."
  },
  {
    title: "Configuració de campanyes locals",
    desc: "Creem estructures de campanya segmentades per barri: Sant Pere, Les Fonts, Vallparadís, el centre històric i la zona comercial del Raval. Cada grup d'anuncis apunta al client correcte a l'àrea correcta de Terrassa."
  },
  {
    title: "Redacció d'anuncis per al client terrassenc",
    desc: "Escrivim anuncis que connecten amb el comprador de Terrassa. Missatges directes orientats al perfil del Vallès Occidental, que generen clics de qualitat i no trànsit irrellevant."
  },
  {
    title: "Optimització contínua i reporting",
    desc: "Cada setmana analitzem les mètriques reals: leads generats, cost per conversió, cerques que activen els teus anuncis a Terrassa. Ajustem sense parar per millorar el ROI al mercat del Vallès."
  }
];

const faqItems = [
  {
    question: "Quant costa gestionar Google Ads per al meu negoci a Terrassa?",
    answer: "El cost de gestió a Nova varia segons el volum d'inversió publicitària. Treballem amb pimes de Terrassa des de pressupostos de 300€/mes d'inversió a Google. L'important no és la mida del pressupost, sinó optimitzar-lo al màxim per al mercat local del Vallès Occidental."
  },
  {
    question: "Google Ads funciona per a botigues del centre de Terrassa o l'Eix del Parc?",
    answer: "Absolutament. Els comerços de l'Eix del Parc, la Rambla d'Ègara o el centre històric de Terrassa poden captar clients locals amb alta intenció de compra mitjançant Google Ads local. Segmentem perquè els teus anuncis es mostrin únicament a persones que cerquen prop del teu establiment."
  },
  {
    question: "Pot la meva empresa industrial de Les Arenes o Ca n'Anglada usar Google Ads?",
    answer: "Sí. Les empreses B2B dels polígons industrials de Terrassa —Les Arenes, Ca n'Anglada— tenen un perfil de client que també cerca a Google. Dissenyem campanyes orientades a paraules clau industrials i de serveis B2B que generen pressupostos i contractes reals."
  },
  {
    question: "Quant temps tarda a funcionar Google Ads per a la meva empresa de Terrassa?",
    answer: "A diferència del SEO, Google Ads ofereix visibilitat gairebé immediata. La teva empresa de Terrassa pot aparèixer als primers resultats en qüestió d'hores després d'activar la campanya. Al primer mes ja tens dades reals per optimitzar i millorar el ROI al mercat del Vallès."
  },
  {
    question: "Els meus anuncis poden aparèixer a Google Maps per atraure clients al meu local de Terrassa?",
    answer: "Sí. Configurem campanyes locals amb extensions d'ubicació perquè el teu negoci aparegui a Google Maps quan algú cerca el teu servei prop de la Rambla d'Ègara, el Parc de Vallparadís o qualsevol barri de Terrassa. Ideal per a restaurants, clíniques, tallers i serveis de proximitat."
  },
  {
    question: "Quin pressupost mínim necessito per a Google Ads a Terrassa?",
    answer: "A Terrassa, amb un nivell de competència mitjà-alt, els primers resultats poden veure's amb inversions des de 300-500€/mes en publicitat ben gestionada. Recomanem començar amb un pressupost conservador, mesurar resultats al mercat del Vallès i escalar quan el ROI estigui validat."
  },
  {
    question: "Com es mesura l'èxit de les campanyes de Google Ads a Terrassa?",
    answer: "Mesurem l'èxit en mètriques de negoci reals: leads generats, trucades rebudes, formularis completats i vendes directes. No en clics o impressions. Rebràs informes clars i transparents del rendiment de cada euro invertit en publicitat a Terrassa."
  },
  {
    question: "Es poden segmentar els anuncis només per barris concrets de Terrassa?",
    answer: "Sí. Google Ads permet una segmentació geogràfica molt precisa. Podem mostrar els teus anuncis únicament a zones específiques de Terrassa: Sant Pere, Vallparadís, Les Fonts, el centre històric, l'Eix del Parc o els polígons industrials. Així optimitzem cada euro cap a les àrees més rendibles per al teu negoci."
  },
  {
    question: "Què diferencia Nova Marketing d'altres agències de Google Ads a Terrassa?",
    answer: "A Nova coneixem el mercat del Vallès Occidental. No som una agència genèrica: entenem els sectors industrials de Terrassa, el perfil del consumidor local i la competència a cada barri. Cada campanya es dissenya específicament per al mercat de Terrassa, no s'apliquen plantilles genèriques."
  },
  {
    question: "Puc començar amb Google Ads tot i no haver tingut campanyes abans a Terrassa?",
    answer: "Per descomptat. Per a empreses de Terrassa sense historial previ a Google Ads fem una configuració inicial des de zero: investigació de paraules clau del Vallès, estructura de campanyes, redacció d'anuncis i configuració de conversions. En setmanes tens dades reals per prendre decisions."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Agència de Google Ads per a Pimes",
  "provider": {
    "@type": "ProfessionalService",
    "@id": "https://novamarketing.es/#organization"
  },
  "areaServed": {
    "@type": "City",
    "name": "Terrassa",
    "sameAs": "https://www.wikidata.org/wiki/Q12285"
  },
  "description": "Experts en gestió de campanyes de Google Ads i SEM per a petites i mitjanes empreses a Terrassa. Maximitzem la teva visibilitat i vendes amb estratègies a mida per al mercat del Vallès Occidental.",
  "offers": { "@type": "Offer", "priceRange": "€€" },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "19"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Serveis de Publicitat a Google",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Auditoria de compte de Google Ads" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Configuració inicial de campanyes SEM" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Optimització contínua i gestió de pujades" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Gestió de Google Merchant Center i Shopping" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Campanyes de Remarketing i Display" }}
    ]
  }
};
---

<BaseLayout
  title="Agència Google Ads a Terrassa | Nova Marketing"
  description="Gestió de campanyes de Google Ads per a empreses de Terrassa. Rendibilitza la teva inversió publicitària al Vallès Occidental des del primer dia. Auditoria gratuïta."
  locale="ca"
  alternates={alternates}
  schemas={[serviceSchema, faqSchema]}
>

  <!-- ═══ 1. HERO ═══ -->
  <section class="pt-24 sm:pt-40 pb-20 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
    <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
    <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>
    <div class="max-w-5xl mx-auto reveal relative z-10">
      <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-8 shadow-sm">
        <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
        Publicitat Online Rendible
      </span>
      <h1 class="text-4xl sm:text-6xl md:text-7xl lg:text-8xl uppercase font-black tracking-tighter leading-[0.80] mb-6 text-zinc-900 flex flex-col items-center text-center">
        <span>Agència de</span>
        <span>Google Ads</span>
        <span class="bg-gradient-to-r from-accent via-accent/90 to-purple-600 bg-clip-text text-transparent px-4 overflow-visible inline-block">a Terrassa</span>
      </h1>
      <p class="text-base sm:text-lg text-zinc-500 font-light leading-relaxed max-w-2xl mx-auto mb-12">Maximitzem les teves vendes amb campanyes de pagament per clic hipersegmentades a Terrassa. Des dels comerços de l'Eix del Parc i la Rambla d'Ègara fins a les empreses industrials de Les Arenes, cada clic compta.</p>
      <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
        <button class="contact-modal-trigger btn-mktg-v5 shadow-[0_20px_40px_-10px_rgba(0,0,0,0.15)] hover:shadow-[0_25px_50px_-12px_rgba(0,0,0,0.25)] hover:-translate-y-1 transition-all duration-300 !py-5 !px-12 !text-[12px] !tracking-wider font-black w-full sm:w-auto">
          MULTIPLICAR LA MEVA FACTURACIÓ
        </button>
      </div>
    </div>
  </section>

  <!-- ═══ 2. LOGO MARQUEE ═══ -->
  <LogoMarquee />

  <!-- ═══ 3. DOMINI TOTAL + 4 CARDS ═══ -->
  <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808005_1px,transparent_1px),linear-gradient(to_bottom,#80808005_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_50%,#000_80%,transparent_100%)]"></div>
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 sm:mb-24 reveal">
        <h2 class="text-3xl sm:text-5xl lg:text-7xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.82]">
          Domini Total de <br class="hidden sm:inline" /> Google Ads a Terrassa
        </h2>
        <p class="text-zinc-500 font-light text-base sm:text-lg leading-relaxed max-w-2xl mx-auto">No experimentem amb el pressupost d'empreses de Terrassa. Dissenyem campanyes quirúrgiques per al mercat del Vallès que impacten exactament en el client ideal quan està llest per comprar.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 items-stretch">
        {[
          { title: "Auditoria de Compte", desc: "Analitzem el teu historial a Google Ads detectant fuites de pressupost habituals al mercat de Terrassa. Atenció especial a sectors com la indústria de Les Arenes i el comerç de l'Eix del Parc i la Rambla d'Ègara." },
          { title: "Keyword Research SEM", desc: "Seleccionem cerques amb alta intenció de compra a Terrassa: des de serveis locals a l'Eix del Parc fins a empreses B2B dels polígons industrials. Zero clics de curiosos." },
          { title: "Anuncis d'Impacte", desc: "Redactem textos que connecten amb el client terrassenc. Missatges que ressonen tant per al comprador del centre històric com per a l'industrial de Ca n'Anglada o Les Arenes." },
          { title: "Optimització de Pujada", desc: "Ajustem les pujades perquè la teva empresa de Terrassa pagui el mínim per cada client captat, prioritzant els moments de major intenció comercial al Vallès Occidental." }
        ].map((s, i) => (
          <div class="group flex flex-col justify-between p-8 sm:p-10 h-full bg-white rounded-3xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden reveal flex-1">
            <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
            <div class="absolute -bottom-6 -right-4 text-9xl font-black text-black/2 group-hover:text-accent/[0.04] transition-all duration-500 select-none">0{i + 1}</div>
            <div class="relative z-10 flex flex-col h-full justify-between">
              <div>
                <div class="p-3 bg-zinc-50 border border-black/5 w-fit rounded-xl mb-6 group-hover:bg-accent/5 transition-colors">
                  <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                </div>
                <h3 class="text-xl sm:text-2xl uppercase mb-3 tracking-tighter group-hover:text-accent font-black text-zinc-900 border-b border-zinc-100 pb-2 w-fit">{s.title}</h3>
                <p class="text-xs sm:text-sm text-zinc-500 leading-relaxed font-light">{s.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ 4. TIMELINE ═══ -->
  <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16 sm:mb-24 reveal">
        <h2 class="text-2xl sm:text-5xl lg:text-7xl font-black tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.85]">
          Com treballem el SEM a Terrassa
        </h2>
        <div class="text-zinc-500 w-[75%] mx-auto font-light text-sm sm:text-base leading-relaxed">
          <p>Oblida't del SEM en pilot automàtic. Comptaràs amb un <strong>Account Manager dedicat</strong> que coneix el mercat de Terrassa i treballarà de la mà del teu equip per supervisar avenços i mantenir-te informat amb mètriques reals.</p>
        </div>
      </div>
      <div id="timeline-container" class="relative timeline-container">
        <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
        <div class="progress-bar hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100" style="height: 0%;"></div>
        <div class="space-y-16 md:space-y-24 flex flex-col items-center">
          {steps.map((step, index) => (
            <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal" style={`transition-delay: ${index * 100}ms`}>
              <div class="hidden md:block md:flex-1 text-right md:order-1">
                {index % 2 === 0 && (
                  <div class="md:pr-12">
                    <h3 class="text-xl sm:text-2xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{step.title}</h3>
                    <p class="text-sm text-zinc-500 font-light max-w-md ml-auto">{step.desc}</p>
                  </div>
                )}
              </div>
              <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all duration-300">0{index + 1}</div>
              <div class="flex-1 text-left md:order-3">
                <div class="md:pl-12">
                  <h3 class:list={["text-xl sm:text-2xl font-black uppercase tracking-tighter mb-2 text-zinc-900", index % 2 === 0 ? "md:hidden" : ""]}>{step.title}</h3>
                  <p class:list={["text-sm text-zinc-500 font-light max-w-md mr-auto", index % 2 === 0 ? "md:hidden" : ""]}>{step.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
  <style>
    .timeline-container .reveal { opacity: 0; transform: translateY(20px); transition: all 0.6s cubic-bezier(0.165, 0.84, 0.44, 1); }
    .timeline-container .reveal.active { opacity: 1; transform: translateY(0); }
  </style>
  <script is:inline>
    function initTimeline() {
      const timeline = document.getElementById('timeline-container');
      const progressBar = timeline?.querySelector('.progress-bar');
      function updateProgress() {
        if (!timeline || !progressBar) return;
        const rect = timeline.getBoundingClientRect();
        const winHeight = window.innerHeight;
        const topPassed = (winHeight / 2) - rect.top;
        let percentage = (topPassed / rect.height) * 100;
        percentage = Math.max(0, Math.min(100, percentage));
        progressBar.style.height = `${percentage}%`;
        const nodes = timeline.querySelectorAll('.node-circle');
        nodes.forEach((node) => {
          const nodeTop = node.getBoundingClientRect().top;
          if (nodeTop < winHeight / 2) { node.classList.add('!border-accent', '!bg-accent', '!text-white'); }
          else { node.classList.remove('!border-accent', '!bg-accent', '!text-white'); }
        });
      }
      window.addEventListener('scroll', updateProgress);
      document.addEventListener('astro:page-load', updateProgress);
      updateProgress();
    }
    document.addEventListener('DOMContentLoaded', initTimeline);
    document.addEventListener('astro:page-load', initTimeline);
  </script>

  <!-- ═══ 5. CONSULTOR ═══ -->
  <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
    <div class="max-w-6xl mx-auto reveal">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
        <div class="md:col-span-5 relative group flex justify-center">
          <div class="absolute inset-0 bg-accent/20 rounded-full blur-3xl opacity-30 group-hover:scale-105 transition-transform duration-500"></div>
          <div class="relative w-full max-w-sm">
            <div class="absolute -top-6 -left-6 w-24 h-24 bg-[radial-gradient(#000000_15%,transparent_15%)] bg-[length:12px_12px] opacity-20"></div>
            <div class="overflow-hidden rounded-[2rem] shadow-[0_30px_60px_-15px_rgba(0,0,0,0.1)] border-4 border-white">
              <img src="/img/consultor-de-google-ads-en-terrassa.webp" alt="Consultor de Google Ads a Terrassa" class="w-full h-auto object-cover">
            </div>
            <div class="absolute -bottom-4 -right-4 backdrop-blur-md bg-black/90 text-white px-6 py-4 rounded-xl shadow-xl flex items-center gap-3 border border-white/10">
              <div class="w-2 h-2 bg-accent rounded-full animate-pulse"></div>
              <div class="text-[10px] sm:text-xs font-black uppercase tracking-widest">Estratègia SEM</div>
            </div>
          </div>
        </div>
        <div class="md:col-span-7 text-left">
          <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.4em] text-accent mb-4 block">Rendibilitat PPC</span>
          <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.85]">
            Consultor de Google Ads a Terrassa
          </h2>
          <p class="text-zinc-500 font-light text-base sm:text-lg leading-relaxed mb-8">Com a consultor expert en Google Ads a Terrassa, configuro i optimitzo campanyes perquè cap euro de pressupost es perdi en clics irrellevants. Conec el mercat local del Vallès Occidental —des de la Rambla d'Ègara i el Parc de Vallparadís fins als polígons industrials de Les Arenes— i dissenyo estratègies orientades a atraure compradors d'alta intenció.</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="p-6 bg-zinc-50 border border-black/5 rounded-xl hover:bg-zinc-100 transition-colors">
              <div class="text-sm font-black uppercase tracking-wider text-black mb-2">Auditoria</div>
              <p class="text-xs text-zinc-400 font-light">Control de pressupost de clics.</p>
            </div>
            <div class="p-6 bg-zinc-50 border border-black/5 rounded-xl hover:bg-zinc-100 transition-colors">
              <div class="text-sm font-black uppercase tracking-wider text-black mb-2">ROI Directe</div>
              <p class="text-xs text-zinc-400 font-light">Enfocament a benefici local.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ 6. RENDIBILITAT + STATS + TESTIMONIS ═══ -->
  <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16 sm:mb-24 reveal">
        <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
          Rendibilitat de campanyes de Google Ads a Terrassa
        </h2>
        <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
          No mesurem l'èxit en clics. Mesurem el cost per adquisició i el marge de benefici generat. Obtindràs un panell de mètriques transparents alineades amb les vendes reals del teu negoci a Terrassa.
        </p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16 reveal text-center">
        <div class="p-8 bg-white rounded-2xl border border-black/5 shadow-sm hover:shadow-xl hover:-translate-y-1 hover:border-accent/10 transition-all duration-300"><div class="text-4xl sm:text-5xl font-black text-accent mb-2 tracking-tighter">+40%</div><div class="text-xs text-zinc-400 font-black tracking-widest uppercase">Mitjana de Conversió</div></div>
        <div class="p-8 bg-white rounded-2xl border border-black/5 shadow-sm hover:shadow-xl hover:-translate-y-1 hover:border-accent/10 transition-all duration-300"><div class="text-4xl sm:text-5xl font-black text-accent mb-2 tracking-tighter">-35%</div><div class="text-xs text-zinc-400 font-black tracking-widest uppercase">Reducció Cost / Clic</div></div>
        <div class="p-8 bg-white rounded-2xl border border-black/5 shadow-sm hover:shadow-xl hover:-translate-y-1 hover:border-accent/10 transition-all duration-300"><div class="text-4xl sm:text-5xl font-black text-accent mb-2 tracking-tighter">x4.5</div><div class="text-xs text-zinc-400 font-black tracking-widest uppercase">Retorn Inversió (ROI)</div></div>
        <div class="p-8 bg-white rounded-2xl border border-black/5 shadow-sm hover:shadow-xl hover:-translate-y-1 hover:border-accent/10 transition-all duration-300"><div class="text-4xl sm:text-5xl font-black text-accent mb-2 tracking-tighter">x3</div><div class="text-xs text-zinc-400 font-black tracking-widest uppercase">Leads Qualificats/Mes</div></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 reveal">
