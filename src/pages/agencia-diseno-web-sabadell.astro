          {webCases.map((cs: any) => {
            const catName = (cs.categories || []).map((c: any) => c.name || c.attributes?.name).filter(Boolean).join(' | ');
            const caseUrl = cs.isPublic && cs.slug ? `/casos-exito/${cs.slug}/` : null;
            return (
              <div class="cases-slide flex-none w-full sm:w-[calc(50%-12px)] lg:w-[calc(25%-18px)] bg-white p-8 border border-black/5 flex flex-col justify-between group hover:shadow-xl hover:-translate-y-1 transition-all duration-300 rounded-2xl">
                <div>
                  {catName && <span class="text-[10px] font-black uppercase tracking-widest text-accent mb-4 block">{catName}</span>}
                  <h3 class="text-base font-black uppercase tracking-tight text-zinc-900 mb-3 transition-colors leading-tight">
                    {caseUrl ? (
                      <a href={caseUrl} class="hover:text-accent transition-colors">{cs.title}</a>
                    ) : (
                      <span class="group-hover:text-accent transition-colors">{cs.title}</span>
                    )}
                  </h3>
                  <p class="text-xs text-zinc-500 font-light leading-relaxed">{cs.description}</p>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </section>
  )}
  <script is:inline>
    function initCasesCarousel() {
      var track = document.querySelector('.cases-track');
      if (!track) return;
      var slides = track.querySelectorAll('.cases-slide');
      if (slides.length <= 4) return;
      var current = 0;
      var total = slides.length;
      function getVisible() { return window.innerWidth >= 1024 ? 4 : window.innerWidth >= 640 ? 2 : 1; }
      function next() {
        var visible = getVisible();
        var maxIndex = total - visible;
        current = current >= maxIndex ? 0 : current + 1;
        track.style.transform = 'translateX(-' + (current * (slides[0].offsetWidth + 24)) + 'px)';
      }
      var interval = setInterval(next, 5000);
      document.addEventListener('astro:before-preparation', function() { clearInterval(interval); });
    }
    document.addEventListener('DOMContentLoaded', initCasesCarousel);
    document.addEventListener('astro:page-load', initCasesCarousel);
  </script>

