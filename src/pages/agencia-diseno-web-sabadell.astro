---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildAlternates } from '../lib/i18n';
import { strapiClient } from '../lib/strapi';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-diseno-web-sabadell/', '/ca/agencia-disseny-web-sabadell/', SITE_URL);

const faqItems = [
  {
    question: "¿Por qué necesita mi empresa de Sabadell una web profesional?",
    answer: "En Sabadell, el 87% de los consumidores busca empresas locales en Google antes de contactar. Si tu web no es profesional, rápida y orientada a convertir, estás perdiendo clientes frente a competidores del Eix Macià o el centre que sí tienen una presencia digital sólida. Una web bien diseñada es tu mejor vendedor disponible 24/7."
  },
  {
    question: "¿Cuánto cuesta diseñar una página web para una empresa de Sabadell?",
    answer: "El precio varía según el tipo de proyecto: una web corporativa para una pyme del Vallès parte desde 1.500€, mientras que una tienda online completa puede oscilar entre 3.000€ y 8.000€. Trabajamos con empresas de todos los tamaños en Sabadell, desde autónomos del centre hasta industriales de Can Roqueta, adaptando cada propuesta a tu presupuesto y objetivos reales."
  },
  {
    question: "¿Qué diferencia una web que vende de una que no convierte en el mercado de Sabadell?",
    answer: "Una web que convierte en Sabadell está diseñada con el perfil del cliente local en mente: carga rápido en móvil, tiene llamadas a la acción claras, transmite confianza y está optimizada para que Google la muestre cuando alguien busca tu servicio en el Vallès. No basta con tener una web bonita; necesita estar orientada a resultados medibles."
  },
  {
    question: "¿Cuánto tiempo tarda el diseño de una web para una pyme del Eix Macià o el centre de Sabadell?",
    answer: "Un proyecto web estándar para una pyme de Sabadell tarda entre 3 y 6 semanas desde el briefing hasta el lanzamiento. Proyectos más complejos, como tiendas online o webs con integración de sistemas, pueden requerir 8-12 semanas. Desde el inicio te asignamos un Account Manager dedicado que te mantiene informado de cada avance."
  },
  {
    question: "¿Pueden las empresas industriales de los polígons de Sabadell beneficiarse de una web bien diseñada?",
    answer: "Absolutamente. Las empresas B2B de los polígons industrials de Can Roqueta, Can Feu y la zona del Vallès Occidental tienen mucho que ganar con una web profesional. Sus clientes —otras empresas— también buscan proveedores en Google. Una web diseñada para el sector industrial genera presupuestos y contratos, no solo visitas."
  },
  {
    question: "¿Incluís optimización SEO en el diseño web para Sabadell?",
    answer: "Sí. Todas nuestras webs para empresas de Sabadell se construyen desde el primer día con las bases técnicas del SEO: estructura de URLs limpia, velocidad de carga optimizada, datos estructurados, etiquetas correctas y contenido orientado a las búsquedas reales de tus clientes en el Vallès. Esto te da ventaja en Google desde el día del lanzamiento."
  },
  {
    question: "¿Diseñáis tiendas online para comercios del centre de Sabadell?",
    answer: "Sí. Diseñamos e-commerce para comercios de Sabadell —ya sea en el carrer de Gràcia, la zona del Mercat Central o el Eix Macià— integrando pasarelas de pago, gestión de inventario y experiencias de compra optimizadas para móvil. Muchos negocios locales de Sabadell han multiplicado sus ventas al unir tienda física y presencia digital."
  },
  {
    question: "¿Cómo os diferenciáis de otras agencias de diseño web en Sabadell?",
    answer: "A diferencia de muchas agencias que solo entregan una web bonita, nosotros diseñamos orientados a conversión y resultado. Conocemos el mercado del Vallès Occidental —sus sectores industriales, su tejido comercial, el perfil del consumidor de Sabadell— y construimos webs que no solo gustan, sino que generan clientes reales. Además, ofrecemos seguimiento y mejora continua post-lanzamiento."
  },
  {
    question: "¿Podéis rediseñar mi web actual para captar más clientes en Sabadell?",
    answer: "Sí. Si tienes una web que no convierte, hacemos un análisis UX y de rendimiento para identificar los puntos de fuga. Muchas empresas de Sabadell nos contactan porque su web existe pero no genera resultados. El rediseño orientado a conversión puede transformar una web invisible en la principal fuente de leads de tu negocio en el Vallès."
  },
  {
    question: "¿Funciona el diseño web para empresas B2B del Vallès Occidental?",
    answer: "Sí, y más de lo que muchos piensan. Las empresas industriales y de servicios B2B de Sabadell y el Vallès Occidental que invierten en una web profesional consiguen más solicitudes de presupuesto, mejoran su imagen frente a clientes de fuera del Vallès y reducen el ciclo de venta porque la web ya hace parte del trabajo de presentación y credibilidad."
  }
];

let webCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('es');
  webCases = casesRes.data
    .map((i: any) => i.attributes ?? i)
    .filter((c: any) => {
      const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
      return cats.some((s: string) => s.includes('web') || s.includes('dise'));
    });
} catch {}

const steps = [
  { title: "Análisis y Estrategia Web en Sabadell", desc: "Estudiamos tu negocio y tu mercado local en el Vallès Occidental. Tanto si estás en el Eix Macià como en los polígons industrials de Can Roqueta, definimos una arquitectura web orientada a captar exactamente a tus clientes en Sabadell." },
  { title: "Diseño UX Personalizado", desc: "Creamos prototipos y diseños adaptados al perfil del cliente de Sabadell. La experiencia de usuario fluye tan naturalmente como un paseo por la Rambla: sin fricciones, clara y con objetivos definidos en cada pantalla." },
  { title: "Desarrollo y Maquetación", desc: "Construimos tu web con tecnología moderna, rápida y segura. Cada línea de código está pensada para que tu negocio destaque en Google tanto en Sabadell como en toda la comarca del Vallès Occidental y más allá." },
  { title: "Optimización SEO y Velocidad", desc: "Antes de lanzar, auditamos velocidad, SEO técnico y compatibilidad móvil. Tu web saldrá preparada para competir en Google desde el primer día, visible para los clientes que buscan tus servicios en Creu Alta, Can Feu o el centre de Sabadell." },
  { title: "Lanzamiento y Mejora Continua", desc: "El lanzamiento es el inicio, no el final. Analizamos el comportamiento de tus visitantes del Vallès y mejoramos continuamente tu web para maximizar las conversiones y el retorno de tu inversión mes a mes." }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Agencia de Diseño Web para Pymes",
  "provider": {
    "@type": "ProfessionalService",
    "@id": "https://novamarketing.es/#organization",
    "name": "Nova Marketing",
    "image": "https://novamarketing.es/agencia-marketing-pymes-nova-marketing-logo.png",
    "telephone": "+34644738270",
    "priceRange": "€€",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Carrer de Bilbao 1",
      "addressLocality": "Sabadell",
      "addressRegion": "Barcelona",
      "postalCode": "08202",
      "addressCountry": "ES"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "31"
    }
  },
  "areaServed": {
    "@type": "City",
    "name": "Sabadell",
    "sameAs": "https://www.wikidata.org/wiki/Q12258"
  },
  "description": "Expertos en diseño de páginas web y desarrollo orientado a conversión para pequeñas y medianas empresas en Sabadell. Creamos sitios web modernos, rápidos y optimizados para captar clientes en el Vallès Occidental.",
  "offers": {
    "@type": "Offer",
    "priceRange": "€€"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Servicios de Diseño y Desarrollo Web",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Diseño Web Corporativo" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Desarrollo de Tiendas Online (E-commerce)" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Optimización de Velocidad y WPO" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Mantenimiento Web y Seguridad" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Rediseño y UX (Experiencia de Usuario)" } }
    ]
  }
};
---

<BaseLayout
  title="Agencia de Diseño Web en Sabadell | Nova Marketing"
  description="Diseñamos páginas web que convierten para empresas de Sabadell. Webs rápidas, optimizadas y orientadas a captar clientes en el Vallès Occidental. Solicita presupuesto."
  locale="es"
  alternates={alternates}
  schemas={[serviceSchema, faqSchema]}
>

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[88vh] flex items-center justify-center pt-24 pb-16 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
    <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
    <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>
    <div class="max-w-7xl mx-auto reveal relative z-10">
      <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-6 shadow-sm">
        <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
        Especialistas en Diseño Web en Sabadell
      </span>
      <h1 class="text-4xl sm:text-6xl md:text-7xl lg:text-[5.5rem] uppercase font-black tracking-tighter leading-[0.82] mb-8 text-zinc-900 flex flex-col items-center text-center">
        <span>Agencia de</span>
        <span>Diseño Web en</span>
        <span class="text-mktg-gradient px-4 overflow-visible inline-block">Sabadell</span>
      </h1>
      <p class="text-base sm:text-lg text-zinc-500 font-light leading-relaxed max-w-2xl mx-auto mb-12">
        Diseñamos páginas web que convierten visitas en clientes para empresas de Sabadell. Desde el Eix Macià hasta los polígons industrials de Can Roqueta, creamos webs modernas, rápidas y orientadas a resultados reales en el Vallès Occidental.
      </p>
      <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
        <button class="contact-modal-trigger btn-mktg-v5 shadow-[0_20px_40px_-10px_rgba(0,0,0,0.15)] hover:shadow-[0_25px_50px_-12px_rgba(0,0,0,0.25)] hover:-translate-y-1 transition-all duration-300 !py-5 !px-12 !text-[12px] !tracking-wider font-black w-full sm:w-auto">
          SOLICITAR PRESUPUESTO GRATIS
        </button>
      </div>
    </div>
  </section>

  <!-- ═══ LOGOS CLIENTES ═══ -->
  <section class="py-12 border-b border-black/5 bg-zinc-50/40 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="text-[9px] sm:text-[10px] uppercase font-black tracking-widest text-zinc-400 text-center mb-8">Pymes que ya estrenan web con Nova</p>
      <div class="overflow-hidden w-full relative [mask-image:linear-gradient(to_right,transparent,white_10%,white_90%,transparent)]">
        <div id="logos-marquee-web-sab" class="flex items-center gap-16 w-max animate-scroll-logo-web"></div>
      </div>
    </div>
  </section>
  <style>
    @keyframes scrollMarqueeLogoWeb { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
    .animate-scroll-logo-web { animation: scrollMarqueeLogoWeb 60s linear infinite; }
  </style>
  <script is:inline>
    (function() {
      var logos = [
        { src: "/clients/bermaq-cliente-novamarketing.webp", alt: "Bermaq" },
        { src: "/clients/cb-lhospitalet-cliente-novamarketing.webp", alt: "CB l'Hospitalet" },
        { src: "/clients/medhs-cliente-novamarketing.webp", alt: "MedHS" },
        { src: "/clients/palacio-del-bebe-cliente-novamarketing.webp", alt: "Palacio del bebé" },
        { src: "/clients/tagtio-cliente-novamarketing.webp", alt: "Tagtio" },
        { src: "/clients/tejados-tapar-cliente-novamarketing.webp", alt: "Tejados Tapar" },
        { src: "/clients/fastpoint-cliente-novamarketing.webp", alt: "FastPoint" },
        { src: "/clients/mundeta-cliente-novamarketing.webp", alt: "Mundeta" },
        { src: "/clients/tattoox-cliente-novamarketing.webp", alt: "TattooX" },
        { src: "/clients/voltura-projects-cliente-novamarketing.webp", alt: "Voltura Projects" }
      ];
      var shuffled = logos.sort(function() { return Math.random() - 0.5; });
      var full = shuffled.concat(shuffled, shuffled, shuffled);
      var c = document.getElementById('logos-marquee-web-sab');
      if (c) c.innerHTML = full.map(function(l) { return '<img src="' + l.src + '" alt="' + l.alt + '" class="h-[50px] w-auto object-contain filter grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-300 pointer-events-none" style="mix-blend-mode:multiply" />'; }).join('');
    })();
  </script>

  <!-- ═══ EXPERTOS EN DISEÑO WEB EN SABADELL ═══ -->
  <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808005_1px,transparent_1px),linear-gradient(to_bottom,#80808005_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_50%,#000_80%,transparent_100%)]"></div>
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 sm:mb-24 reveal">
        <h2 class="text-3xl sm:text-5xl lg:text-7xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.82]">
          Expertos en Diseño Web<br class="hidden sm:inline" /> en Sabadell
        </h2>
        <p class="text-zinc-500 font-light text-base sm:text-lg leading-relaxed max-w-2xl mx-auto">
          No hacemos webs genéricas. Diseñamos sitios web orientados al mercado del Vallès Occidental, pensados para el tipo de cliente que busca tu negocio en Sabadell y su entorno.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 items-stretch">
        {[
          { title: "Webs que Venden", desc: "Creamos sitios web orientados a captar clientes en Sabadell, optimizados para convertir visitantes en leads reales. Cada elemento del diseño tiene un propósito comercial." },
          { title: "Diseño UX Sabadell", desc: "Experiencias digitales pensadas para el perfil del cliente del Vallès, desde el comercio del centre de Sabadell hasta la empresa industrial del polígon de Can Feu." },
          { title: "Rendimiento y Velocidad", desc: "Webs rápidas y optimizadas para Google. En el mercado competitivo de Sabadell y el Vallès Occidental, una web lenta pierde clientes antes de que te conozcan." },
          { title: "SEO desde el Primer Día", desc: "Estructuras web preparadas para posicionar en Google desde el primer clic, captando clientes que buscan tus servicios en Sabadell, Creu Alta, Can Feu y toda la comarca." }
        ].map((s, i) => (
          <div class="group flex flex-col justify-between p-8 sm:p-10 h-full bg-white rounded-3xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden reveal flex-1">
            <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
            <div class="absolute -bottom-6 -right-4 text-9xl font-black text-black/2 group-hover:text-accent/[0.04] transition-all duration-500 select-none">0{i + 1}</div>
            <div class="relative z-10 flex flex-col h-full justify-between">
              <div>
                <div class="p-3 bg-zinc-50 border border-black/5 w-fit rounded-xl mb-6 group-hover:bg-accent/5 transition-colors">
                  <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                </div>
                <h3 class="text-xl sm:text-2xl uppercase mb-3 tracking-tighter group-hover:text-accent font-black text-zinc-900 border-b border-zinc-100 pb-2 w-fit">{s.title}</h3>
                <p class="text-xs sm:text-sm text-zinc-500 leading-relaxed font-light">{s.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ TIMELINE / PROCESO ═══ -->
  <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16 sm:mb-24 reveal">
        <h2 class="text-2xl sm:text-5xl lg:text-7xl font-black tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.85]">
          Cómo diseñamos tu web en Sabadell
        </h2>
        <div class="text-zinc-500 w-[75%] mx-auto font-light text-sm sm:text-base leading-relaxed">
          <p>Un proceso claro y transparente con un <strong>Account Manager dedicado</strong> que trabaja mano a mano con tu equipo. Cada fase está pensada para que tu negocio en Sabadell tenga una web que genere resultados reales desde el primer día.</p>
        </div>
      </div>
      <div id="timeline-container" class="relative timeline-container">
        <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
        <div class="progress-bar hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100" style="height: 0%;"></div>
        <div class="space-y-16 md:space-y-24 flex flex-col items-center">
          {steps.map((step, index) => (
            <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal" style={`transition-delay: ${index * 100}ms`}>
              <div class="hidden md:block md:flex-1 text-right md:order-1">
                {index % 2 === 0 && (
                  <div class="md:pr-12">
                    <h3 class="text-xl sm:text-2xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{step.title}</h3>
                    <p class="text-sm text-zinc-500 font-light max-w-md ml-auto">{step.desc}</p>
                  </div>
                )}
              </div>
              <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all duration-300">0{index + 1}</div>
              <div class="flex-1 text-left md:order-3">
                <div class="md:pl-12">
                  <h3 class:list={["text-xl sm:text-2xl font-black uppercase tracking-tighter mb-2 text-zinc-900", index % 2 === 0 ? "md:hidden" : ""]}>{step.title}</h3>
                  <p class:list={["text-sm text-zinc-500 font-light max-w-md mr-auto", index % 2 === 0 ? "md:hidden" : ""]}>{step.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
  <style>
    .timeline-container .reveal { opacity: 0; transform: translateY(20px); transition: all 0.6s cubic-bezier(0.165, 0.84, 0.44, 1); }
    .timeline-container .reveal.active { opacity: 1; transform: translateY(0); }
  </style>
  <script is:inline>
    function initTimeline() {
      var timeline = document.getElementById('timeline-container');
      var progressBar = timeline && timeline.querySelector('.progress-bar');
      function updateProgress() {
        if (!timeline || !progressBar) return;
        var rect = timeline.getBoundingClientRect();
        var winHeight = window.innerHeight;
        var topPassed = (winHeight / 2) - rect.top;
        var percentage = Math.max(0, Math.min(100, (topPassed / rect.height) * 100));
        progressBar.style.height = percentage + '%';
        timeline.querySelectorAll('.node-circle').forEach(function(node) {
          if (node.getBoundingClientRect().top < winHeight / 2) { node.classList.add('!border-accent', '!bg-accent', '!text-white'); }
          else { node.classList.remove('!border-accent', '!bg-accent', '!text-white'); }
        });
      }
      window.addEventListener('scroll', updateProgress);
      document.addEventListener('astro:page-load', updateProgress);
      updateProgress();
    }
    document.addEventListener('DOMContentLoaded', initTimeline);
    document.addEventListener('astro:page-load', initTimeline);
  </script>

  <!-- ═══ CONSULTOR DISEÑO WEB ═══ -->
  <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
    <div class="max-w-6xl mx-auto reveal">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
        <div class="md:col-span-5 relative group flex justify-center">
          <div class="absolute inset-0 bg-accent/20 rounded-full blur-3xl opacity-30 group-hover:scale-105 transition-transform duration-500"></div>
          <div class="relative w-full max-w-sm">
            <div class="absolute -top-6 -left-6 w-24 h-24 bg-[radial-gradient(#000000_15%,transparent_15%)] bg-[length:12px_12px] opacity-20"></div>
            <div class="overflow-hidden rounded-[2rem] shadow-[0_30px_60px_-15px_rgba(0,0,0,0.1)] border-4 border-white">
              <img src="/img/consultor-de-seo-en-sabadell.webp" alt="Consultor de Diseño Web en Sabadell" class="w-full h-auto object-cover">
            </div>
            <div class="absolute -bottom-4 -right-4 backdrop-blur-md bg-black/90 text-white px-6 py-4 rounded-xl shadow-xl flex items-center gap-3 border border-white/10">
              <div class="w-2 h-2 bg-accent rounded-full animate-pulse"></div>
              <div class="text-[10px] sm:text-xs font-black uppercase tracking-widest">Diseño Web Sabadell</div>
            </div>
          </div>
        </div>
        <div class="md:col-span-7 text-left">
          <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.4em] text-accent mb-4 block">Diseño y Desarrollo Web</span>
          <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.85]">
            Consultor de Diseño Web en Sabadell
          </h2>
