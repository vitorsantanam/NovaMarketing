---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildAlternates } from '../lib/i18n';
import { strapiClient } from '../lib/strapi';
import LogoMarquee from '../components/sections/LogoMarquee.astro';
import FaqHome from '../components/sections/FaqHome.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-seo-para-pymes', '/agencia-seo-per-pimes', SITE_URL);

const faqItems = [
    {
        question: "¿Cómo puedo hacer que mi pequeña empresa aparezca la primera en Google cuando alguien busca mi servicio?",
        answer: "Para que tu pyme escale puestos, trabajamos el posicionamiento analizando qué busca exactamente tu cliente. Identificamos la KW con mayor intención de compra para tu sector y optimizamos tu web para que Google la considere la mejor respuesta. El objetivo es que tu pequeña empresa deje de ser invisible y empiece a captar tráfico de calidad que realmente quiera contratarte."
    },
    {
        question: "Mi negocio es local, ¿cómo me ayuda el SEO local a atraer clientes de mi ciudad o barrio?",
        answer: "Aquí es donde entra en juego el SEO Local. Optimizamos tu Google Business Profile (antiguo Google My Business) para que, cuando alguien cercano busque lo que ofreces, tu pequeña y mediana empresa aparezca en el mapa con fotos, horario y reseñas. Es la forma más rápida y efectiva de que una pyme atraiga clientes que están físicamente cerca de su local u oficina."
    },
    {
        question: "¿Cuánto tiempo tardará mi pyme en ver resultados reales con el posicionamiento?",
        answer: "El posicionamiento es una estrategia a medio y largo plazo, pero muy rentable para las pequeñas empresas porque no pagas por cada clic. Normalmente, una pyme empieza a notar una mejora en su visibilidad y volumen de contactos a partir de los 3 o 6 meses. Es una inversión que construye un activo propio para tu pequeña y mediana empresa que perdura en el tiempo."
    },
    {
        question: "¿Es necesario tener una ficha de Google Business Profile bien gestionada?",
        answer: "Es fundamental para cualquier pequeña y mediana empresa. Una ficha descuidada o con mala información espanta a los clientes. Nosotros nos encargamos de que el perfil de tu pyme esté impecable, actualizado y optimizado para que los clientes confíen en ti antes incluso de entrar en tu web, destacando tus mejores reseñas y servicios locales."
    },
    {
        question: "¿Mi pequeña empresa puede competir con grandes marcas en Google?",
        answer: "¡Claro que sí! La ventaja de ser una pyme es que puedes ser mucho más específico y ágil. Mientras las grandes empresas van a por todo el mercado, nosotros enfocamos a tu pequeña empresa hacia nichos y zonas geográficas concretas donde la competencia es menor. Con una buena estrategia de KW locales, tu pyme puede ganar la partida a marcas mucho más grandes en su propia zona."
    }
];

const seoServiceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Posicionamiento SEO",
  "name": "Servicio de SEO Integral para Pymes en Cataluña",
  "description": "Estrategias avanzadas de SEO para pymes. Especialistas en auditoría técnica, SEO local y posicionamiento nacional con cobertura en las principales ciudades de Cataluña.",
  "provider": {
    "@type": "ProfessionalService",
    "name": "Nova Marketing",
    "url": "https://novamarketing.es",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Carrer de Bilbao 1",
      "addressLocality": "Sabadell",
      "addressRegion": "Barcelona",
      "postalCode": "08202",
      "addressCountry": "ES"
    }
  },
  "areaServed": [
    {"@type": "Country", "name": "Spain"},
    {"@type": "State", "name": "Cataluña"},
    {"@type": "City", "name": "Barcelona"},
    {"@type": "City", "name": "L'Hospitalet de Llobregat"},
    {"@type": "City", "name": "Terrassa"},
    {"@type": "City", "name": "Sabadell"},
    {"@type": "City", "name": "Badalona"},
    {"@type": "City", "name": "Sant Cugat del Vallès"},
    {"@type": "City", "name": "Lleida"},
    {"@type": "City", "name": "Tarragona"},
    {"@type": "City", "name": "Mataró"},
    {"@type": "City", "name": "Reus"},
    {"@type": "City", "name": "Girona"},
    {"@type": "City", "name": "Cornellà de Llobregat"},
    {"@type": "City", "name": "Sant Boi de Llobregat"},
    {"@type": "City", "name": "Cerdanyola del Vallès"},
    {"@type": "City", "name": "El Prat de Llobregat"},
    {"@type": "City", "name": "Castelldefels"},
    {"@type": "City", "name": "Rubí"},
    {"@type": "City", "name": "Manresa"},
    {"@type": "City", "name": "Vilanova i la Geltrú"},
    {"@type": "City", "name": "Granollers"},
    {"@type": "City", "name": "Viladecans"},
    {"@type": "City", "name": "Santa Coloma de Gramenet"},
    {"@type": "City", "name": "Vic"},
    {"@type": "City", "name": "Figueres"},
    {"@type": "City", "name": "Mollet del Vallès"},
    {"@type": "City", "name": "Gavà"},
    {"@type": "City", "name": "Sant Adrià de Besòs"},
    {"@type": "City", "name": "Esplugues de Llobregat"},
    {"@type": "City", "name": "Olot"},
    {"@type": "City", "name": "Vilafranca del Penedès"}
  ],
  "audience": {
    "@type": "Audience",
    "audienceType": "Pymes, autónomos y negocios locales en Cataluña"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Servicios SEO Especializados",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Auditoría SEO Técnica y Semántica"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "SEO Local para negocios en Barcelona y Vallès"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Estrategia de Contenidos y Linkbuilding"
        }
      }
    ]
  },
  "serviceOutput": "Mejora en el ranking de Google, aumento de tráfico cualificado y reportes de rendimiento mensuales.",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://novamarketing.es/agencia-seo-para-pymes/"
  }
};

// Casos de éxito SEO
let seoCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('es');
  seoCases = casesRes.data
    .map((i: any) => i.attributes ?? i)
    .filter((c: any) => {
      const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
      return cats.some((s: string) => s.includes('seo'));
    });
} catch {}

const steps = [
  { title: "Auditoría SEO Inicial", desc: "Analizamos tu pyme y su presencia digital con una auditoría completa para detectar errores técnicos y margen de mejora." },
  { title: "Keyword Research", desc: "Buscamos las palabras clave que te traen clientes y conversiones, no solo visitas. Estrategia enfocada a intención de compra." },
  { title: "SEO On-Page", desc: "Optimizamos el contenido de tu web, meta-etiquetas, velocidad de carga y trabajamos el enlazado interno para facilitar el rastreo." },
  { title: "Linkbuilding de Calidad", desc: "Conseguimos que otras webs de referencia nos enlacen para conseguir mayor autoridad a los ojos de Google y subir posiciones." },
  { title: "SEO Local", desc: "Posicionamos tu negocio en tu ciudad y Google Maps para captar clientes locales de forma inmediata." }
];

const benefits = [
  { title: "Tráfico orgánico constante sin pagar por cada clic", desc: "A diferencia de Google Ads, el SEO genera visitas recurrentes y estables que no dependen de tu presupuesto diario de inversión." },
  { title: "Mejora de la autoridad de marca y confianza", desc: "Aparecer en los primeros puestos de Google de forma orgánica transmite seriedad, liderazgo y genera una gran confianza en el usuario." },
  { title: "Resultados medibles con informes mensuales", desc: "Transparencia absoluta. Analizamos el tráfico, las conversiones y las posiciones de tus palabras clave para que entiendas el ROI." }
];
---

<BaseLayout
  title="Posicionamiento SEO para PYMES | Nova Marketing"
  description="Multiplicamos el tráfico y las ventas de tu pyme con posicionamiento SEO en Google. Auditoría inicial gratis, SEO local y Estrategia ROI."
  locale="es"
  alternates={alternates}
  schemas={[seoServiceSchema]}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="min-h-[88vh] flex items-center justify-center pt-24 pb-16 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-7xl mx-auto reveal relative z-10">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-6 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Especialistas en Posicionamiento
            </span>

            <h1 class="text-4xl sm:text-6xl md:text-7xl lg:text-[5.5rem] uppercase font-black tracking-tighter leading-[0.82] mb-8 text-zinc-900 flex flex-col items-center text-center">
                <span>Agencia de</span>
                <span>Posicionamiento SEO</span>
                <span class="text-mktg-gradient px-4 overflow-visible inline-block">para pymes</span>
            </h1>

            <p class="text-base sm:text-lg text-zinc-500 font-light leading-relaxed max-w-2xl mx-auto mb-12">
                Multiplicamos el tráfico y las ventas de tu pyme con estrategias de posicionamiento orgánico en Google que generan rentabilidad a largo plazo.
            </p>

            <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
                <button class="contact-modal-trigger btn-mktg-v5 shadow-[0_20px_40px_-10px_rgba(0,0,0,0.15)] hover:shadow-[0_25px_50px_-12px_rgba(0,0,0,0.25)] hover:-translate-y-1 transition-all duration-300 !py-5 !px-12 !text-[12px] !tracking-wider font-black w-full sm:w-auto">
                    SOLICITAR AUDITORÍA GRATIS
                </button>
            </div>
        </div>
    </section>

    <!-- ═══ LOGOS CLIENTES (SOCIAL PROOF) ══════════════════════════════════ -->
    <LogoMarquee />

    <!-- ═══ SECCIÓN 1: AUDITORÍA Y ESTRATEGIA ═══════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6 relative overflow-hidden">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808005_1px,transparent_1px),linear-gradient(to_bottom,#80808005_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_50%,#000_80%,transparent_100%)]"></div>

        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <h2 class="text-3xl sm:text-5xl lg:text-7xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.82]">
                    Auditoría y Estrategia <br class="hidden sm:inline" /> SEO para tu Pyme
                </h2>
                <p class="text-zinc-500 font-light text-base sm:text-lg leading-relaxed max-w-2xl mx-auto">
                    No empezamos a ciegas ni usamos plantillas genéricas. Analizamos tu web de arriba a abajo para diseñar una estrategia orientada 100% a conversiones.
                </p>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 items-stretch">
                {[
                    { title: "Auditoría Técnica", desc: "Corregimos errores de indexación, velocidad y adaptabilidad móvil para que Google te valore más." },
                    { title: "Estudio de Keywords", desc: "Analizamos qué busca tu cliente potencial para posicionar términos con intención de compra real." },
                    { title: "SEO On-Page", desc: "Optimizamos títulos, etiquetas y enlazado interno para decirle a Google exactamente qué vendes." },
                    { title: "Plan de Enlaces", desc: "Construimos autoridad con enlaces de calidad que disparan la relevancia de tu dominio." }
                ].map((s, i) => (
                    <div class="group flex flex-col justify-between p-8 sm:p-10 h-full bg-white rounded-3xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden reveal flex-1">
                        <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
                        <div class="absolute -bottom-6 -right-4 text-9xl font-black text-black/2 group-hover:text-accent/[0.04] transition-all duration-500 select-none">
                            0{i + 1}
                        </div>
                        <div class="relative z-10 flex flex-col h-full justify-between">
                            <div>
                                <div class="p-3 bg-zinc-50 border border-black/5 w-fit rounded-xl mb-6 group-hover:bg-accent/5 transition-colors">
                                    <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                                </div>
                                <h3 class="text-xl sm:text-2xl uppercase mb-3 tracking-tighter group-hover:text-accent font-black text-zinc-900 border-b border-zinc-100 pb-2 w-fit">{s.title}</h3>
                                <p class="text-xs sm:text-sm text-zinc-500 leading-relaxed font-light">{s.desc}</p>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ═══ SECCIÓN 2: TIMELINE (COMO GOOGLE ADS) ═══════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <h2 class="text-2xl sm:text-5xl lg:text-7xl font-black tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.85]">
                    Cómo trabajamos el SEO de tu Empresa
                </h2>
                <div class="text-zinc-500 w-[75%] mx-auto font-light text-sm sm:text-base leading-relaxed space-y-4">
                    <p>
                        Olvídate del SEO en piloto automático. Contarás con un <strong>Account Manager dedicado</strong> que trabajará de la mano con tu equipo para resolver dudas, supervisar avances y mantenerte informado con métricas de negocio.
                    </p>
                </div>
            </div>

            <div id="timeline-container" class="relative timeline-container">
                <!-- Vertical Background Line -->
                <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
                <!-- Vertical Progressing Line -->
                <div class="progress-bar hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100" style="height: 0%;"></div>
                
                <div class="space-y-16 md:space-y-24 flex flex-col items-center">
                    {steps.map((step, index) => (
                        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal" style={`transition-delay: ${index * 100}ms`}>
                            
                            <!-- Borde Lateral Izquierdo (Desktop Solo Alternancia) -->
                            <div class="hidden md:block md:flex-1 text-right md:order-1">
                                {index % 2 === 0 && (
                                    <div class="md:pr-12">
                                        <h3 class="text-xl sm:text-2xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{step.title}</h3>
                                        <p class="text-sm text-zinc-500 font-light max-w-md ml-auto">{step.desc}</p>
                                    </div>
                                )}
                            </div>
                            
                            <!-- Nodo Central -->
                            <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all duration-300">
                                0{index + 1}
                            </div>

                            <!-- Lado Derecho (Móvil todo / Desktop Impares) -->
                            <div class="flex-1 text-left md:order-3">
                                <div class="md:pl-12">
                                    <h3 class:list={["text-xl sm:text-2xl font-black uppercase tracking-tighter mb-2 text-zinc-900", index % 2 === 0 ? "md:hidden" : ""]}>{step.title}</h3>
                                    <p class:list={["text-sm text-zinc-500 font-light max-w-md mr-auto", index % 2 === 0 ? "md:hidden" : ""]}>{step.desc}</p>
                                </div>
                            </div>

                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <style>
        .timeline-container .reveal {
            opacity: 0;
            transform: translateY(20px);
            transition: all 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
        }
        .timeline-container .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }
    </style>

    <script is:inline>
        function initTimeline() {
            const timeline = document.getElementById('timeline-container');
            const progressBar = timeline?.querySelector('.progress-bar');
            
            function updateProgress() {
                if (!timeline || !progressBar) return;
                const rect = timeline.getBoundingClientRect();
                const winHeight = window.innerHeight;
                const topPassed = (winHeight / 2) - rect.top;
                let percentage = (topPassed / rect.height) * 100;
                percentage = Math.max(0, Math.min(100, percentage));
                progressBar.style.height = `${percentage}%`;

                const nodes = timeline.querySelectorAll('.node-circle');
                nodes.forEach((node) => {
                    const nodeTop = node.getBoundingClientRect().top;
                    if (nodeTop < winHeight / 2) {
                        node.classList.add('!border-accent', '!bg-accent', '!text-white');
                    } else {
                        node.classList.remove('!border-accent', '!bg-accent', '!text-white');
                    }
                });
            }

            window.addEventListener('scroll', updateProgress);
            document.addEventListener('astro:page-load', updateProgress);
            updateProgress();
        }
        document.addEventListener('DOMContentLoaded', initTimeline);
        document.addEventListener('astro:page-load', initTimeline);
    </script>

    <!-- ═══ CASOS DE ÉXITO SEO ════════════════════════════════════════════ -->
    {seoCases.length > 0 && (
    <section class="py-20 sm:py-32 bg-zinc-50 border-t border-black/5 px-4 sm:px-6">
        <div class="max-w-7xl mx-auto">
            <div class="mb-16 reveal">
                <span class="text-[10px] font-black uppercase tracking-[0.3em] text-accent mb-4 block">Resultados probados</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl uppercase tracking-tighter font-extrabold text-zinc-900 leading-[0.9]">
                    Casos de éxito de posicionamiento<br class="hidden md:inline" /> SEO en pymes
                </h2>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                {seoCases.map((cs: any, i: number) => {
                  const catName = (cs.categories || []).map((c: any) => c.name || c.attributes?.name).filter(Boolean).join(' | ');
                  const caseUrl = cs.isPublic && cs.slug ? `/casos-exito/${cs.slug}/` : null;
                  return (
                    <div class="bg-white p-8 border border-black/5 flex flex-col justify-between group hover:shadow-xl hover:-translate-y-1 transition-all duration-300 rounded-2xl reveal" style={`transition-delay: ${i * 80}ms`}>
                      <div>
                        {catName && <span class="text-[10px] font-black uppercase tracking-widest text-accent mb-4 block">{catName}</span>}
                        <h3 class="text-base font-black uppercase tracking-tight text-zinc-900 mb-3 group-hover:text-accent transition-colors leading-tight">{cs.title}</h3>
                        <p class="text-xs text-zinc-500 font-light leading-relaxed">{cs.description}</p>
                      </div>
                      {caseUrl && (
                        <a href={caseUrl} class="mt-6 text-[9px] font-black tracking-[0.25em] text-accent flex items-center gap-1.5 hover:gap-3 transition-all uppercase">
                          VER MÁS <span class="text-sm">→</span>
                        </a>
                      )}
                    </div>
                  );
                })}
            </div>
        </div>
    </section>
    )}

    <!-- ═══ FAQ ════════════════════════════════════════════════════════════ -->
    <FaqHome
        items={faqItems}
        title="Preguntas sobre posicionamiento SEO <br /> que nos hacen otras pymes"
    />

</BaseLayout>
