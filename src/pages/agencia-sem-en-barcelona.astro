---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildAlternates } from '../lib/i18n';
import { strapiClient } from '../lib/strapi';
import LogoMarquee from '../components/sections/LogoMarquee.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-sem-en-barcelona', '/ca/agencia-sem-a-barcelona', SITE_URL);

let pageCases: any[] = [];
try {
  const res = await strapiClient.getCaseStudies('es');
  pageCases = res.data.map((i: any) => i.attributes ?? i).filter((c: any) => {
    const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
    return cats.some((s: string) => s.includes('google-ads') || s.includes('ads'));
  });
} catch {}

const steps = [
  {
    title: "Análisis del mercado de Barcelona",
    desc: "Estudiamos la competencia local en Google Ads dentro de Barcelona, desde los negocios del Eixample y el Poblenou hasta las startups del 22@ y los comercios de Gràcia, para encontrar los huecos de oportunidad con menor CPC."
  },
  {
    title: "Configuración de campañas locales",
    desc: "Creamos estructuras de campaña segmentadas por barrio y distrito: Sarrià-Sant Gervasi, Poble Nou, El Born, Sant Martí, Les Corts. Cada grupo de anuncios apunta al cliente correcto en el área correcta de Barcelona."
  },
  {
    title: "Redacción de anuncios para el cliente barcelonés",
    desc: "Escribimos anuncios que conectan con el comprador de Barcelona. Mensajes directos y adaptados al perfil de cada barrio, que generan clics de calidad y no tráfico irrelevante."
  },
  {
    title: "Optimización continua y reporting",
    desc: "Cada semana analizamos las métricas reales: leads generados, coste por conversión, búsquedas que activan tus anuncios en Barcelona. Ajustamos sin parar para mejorar el ROI en el mercado más competitivo de Cataluña."
  }
];

const faqItems = [
  {
    question: "¿Cuánto cuesta gestionar Google Ads para mi negocio en Barcelona?",
    answer: "El coste de gestión en Nova varía según el volumen de inversión publicitaria. Trabajamos con pymes de Barcelona desde presupuestos de 500€/mes de inversión en Google. Barcelona es un mercado muy competitivo, por lo que la optimización experta es fundamental para rentabilizar cada euro."
  },
  {
    question: "¿Google Ads funciona para tiendas del Eixample o el Passeig de Gràcia?",
    answer: "Absolutamente. Los comercios del Eixample, el Passeig de Gràcia o el barrio de Gràcia tienen acceso a millones de búsquedas locales con Google Ads. Segmentamos para que tus anuncios se muestren únicamente a personas que buscan cerca de tu establecimiento en Barcelona."
  },
  {
    question: "¿Puede mi startup del 22@ de Barcelona usar Google Ads para crecer?",
    answer: "Sí. El ecosistema tecnológico del 22@ genera una demanda B2B muy específica. Google Ads permite impactar a decision makers en el momento exacto, ya sea en el Poblenou o desde cualquier punto de Barcelona. Diseñamos campañas orientadas a la generación de leads cualificados para startups y empresas tech."
  },
  {
    question: "¿Cuánto tiempo tarda en funcionar Google Ads para mi empresa de Barcelona?",
    answer: "A diferencia del SEO, Google Ads ofrece visibilidad casi inmediata. Tu empresa de Barcelona puede aparecer en los primeros resultados en cuestión de horas tras activar la campaña. En el primer mes ya tienes datos reales para optimizar y mejorar el ROI en el mercado barcelonés."
  },
  {
    question: "¿Mis anuncios pueden aparecer en Google Maps para atraer clientes a mi local de Barcelona?",
    answer: "Sí. Configuramos campañas locales con extensiones de ubicación para que tu negocio aparezca en Google Maps cuando alguien busca tu servicio cerca de la Rambla, el Eixample, el Born o cualquier barrio de Barcelona. Ideal para restaurantes, clínicas, talleres y servicios de proximidad."
  },
  {
    question: "¿Qué presupuesto mínimo necesito para Google Ads en Barcelona?",
    answer: "En Barcelona, al ser un mercado muy competitivo, los primeros resultados sólidos suelen verse con inversiones desde 500-800€/mes en publicidad bien gestionada. Recomendamos empezar con un presupuesto testado, medir el CPC real del sector y escalar cuando el ROI esté validado."
  },
  {
    question: "¿Cómo se mide el éxito de las campañas de Google Ads en Barcelona?",
    answer: "Medimos el éxito en métricas de negocio reales: leads generados, llamadas recibidas, formularios completados y ventas directas. No en clics o impresiones. Recibirás informes claros y transparentes del rendimiento de cada euro invertido en publicidad en Barcelona."
  },
  {
    question: "¿Se pueden segmentar los anuncios solo para barrios concretos de Barcelona?",
    answer: "Sí. Google Ads permite una segmentación geográfica muy precisa. Podemos mostrar tus anuncios únicamente en zonas específicas de Barcelona: Eixample, Gràcia, Sarrià, Poble Sec, Poblenou, Sant Martí o el 22@. Así optimizamos cada euro hacia las áreas más rentables para tu negocio."
  },
  {
    question: "¿Qué diferencia a Nova Marketing de otras agencias de Google Ads en Barcelona?",
    answer: "En Nova conocemos el mercado barcelonés en profundidad. No somos una agencia genérica: entendemos la diversidad de sectores de Barcelona, desde el retail de lujo del Passeig de Gràcia hasta las empresas industriales de la Zona Franca. Cada campaña se diseña específicamente para el perfil de tu negocio, no se aplican plantillas genéricas."
  },
  {
    question: "¿Puedo empezar con Google Ads aunque no haya tenido campañas antes en Barcelona?",
    answer: "Por supuesto. Para empresas de Barcelona sin historial previo en Google Ads hacemos una configuración inicial desde cero: investigación de palabras clave del mercado barcelonés, estructura de campañas, redacción de anuncios y configuración de conversiones. En semanas tienes datos reales para tomar decisiones."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Agencia de Google Ads para Pymes",
  "provider": {
    "@type": "ProfessionalService",
    "@id": "https://novamarketing.es/#organization"
  },
  "areaServed": {
    "@type": "City",
    "name": "Barcelona",
    "sameAs": "https://www.wikidata.org/wiki/Q1492"
  },
  "description": "Expertos en gestión de campañas de Google Ads y SEM para pequeñas y medianas empresas en Barcelona. Maximizamos tu visibilidad y ventas con estrategias a medida para el mercado barcelonés.",
  "offers": { "@type": "Offer", "priceRange": "€€" },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "38"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Servicios de Publicidad en Google",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Auditoría de cuenta de Google Ads" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Configuración inicial de campañas SEM" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Optimización continua y gestión de pujas" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Gestión de Google Merchant Center y Shopping" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Campañas de Remarketing y Display" }}
    ]
  }
};
---

<BaseLayout
  title="Agencia Google Ads en Barcelona | Nova Marketing"
  description="Gestión de campañas de Google Ads para empresas de Barcelona. Rentabiliza tu inversión publicitaria en el mercado más competitivo de Cataluña. Auditoría gratuita."
  locale="es"
  alternates={alternates}
  schemas={[serviceSchema, faqSchema]}
>

  <!-- ═══ 1. HERO ═══ -->
  <section class="pt-24 sm:pt-40 pb-20 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
    <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
    <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>
    <div class="max-w-5xl mx-auto reveal relative z-10">
      <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-8 shadow-sm">
        <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
        Publicidad Online Rentable
      </span>
      <h1 class="text-4xl sm:text-6xl md:text-7xl lg:text-8xl uppercase font-black tracking-tighter leading-[0.80] mb-6 text-zinc-900 flex flex-col items-center text-center">
        <span>Agencia de</span>
        <span>Google Ads</span>
        <span class="bg-gradient-to-r from-accent via-accent/90 to-purple-600 bg-clip-text text-transparent px-4 overflow-visible inline-block">en Barcelona</span>
      </h1>
      <p class="text-base sm:text-lg text-zinc-500 font-light leading-relaxed max-w-2xl mx-auto mb-12">Maximizamos tus ventas con campañas de pago por clic hipersegmentadas en Barcelona. Desde los comercios del Eixample y el Born hasta las startups del 22@ y las empresas de la Zona Franca, cada clic cuenta.</p>
      <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
        <button class="contact-modal-trigger btn-mktg-v5 shadow-[0_20px_40px_-10px_rgba(0,0,0,0.15)] hover:shadow-[0_25px_50px_-12px_rgba(0,0,0,0.25)] hover:-translate-y-1 transition-all duration-300 !py-5 !px-12 !text-[12px] !tracking-wider font-black w-full sm:w-auto">
          MULTIPLICAR MI FACTURACIÓN
        </button>
      </div>
    </div>
  </section>

  <!-- ═══ 2. LOGO MARQUEE ═══ -->
  <LogoMarquee />

  <!-- ═══ 3. DOMINIO TOTAL + 4 CARDS ═══ -->
  <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808005_1px,transparent_1px),linear-gradient(to_bottom,#80808005_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_50%,#000_80%,transparent_100%)]"></div>
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 sm:mb-24 reveal">
        <h2 class="text-3xl sm:text-5xl lg:text-7xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.82]">
          Dominio Total de <br class="hidden sm:inline" /> Google Ads en Barcelona
        </h2>
        <p class="text-zinc-500 font-light text-base sm:text-lg leading-relaxed max-w-2xl mx-auto">No experimentamos con el presupuesto de empresas de Barcelona. Diseñamos campañas quirúrgicas para el mercado barcelonés que impactan exactamente en el cliente ideal cuando está listo para comprar.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 items-stretch">
        {[
          { title: "Auditoría de Cuenta", desc: "Analizamos tu historial en Google Ads detectando fugas de presupuesto habituales en el mercado de Barcelona. Especial atención a sectores como el retail del Eixample, la hostelería del Born y la tecnología del 22@." },
          { title: "Keyword Research SEM", desc: "Seleccionamos búsquedas con alta intención de compra en Barcelona: desde servicios locales en Gràcia hasta empresas B2B del Poblenou y el 22@. Cero clics de curiosos." },
          { title: "Anuncios de Impacto", desc: "Redactamos textos que conectan con el cliente barcelonés. Mensajes que resuenan tanto para el comprador del Eixample como para el directivo de startup del 22@ o el empresario de la Zona Franca." },
          { title: "Optimización de Puja", desc: "Ajustamos las pujas para que tu empresa de Barcelona pague el mínimo por cada cliente captado en el mercado más competitivo de Cataluña, priorizando los momentos de mayor intención comercial." }
        ].map((s, i) => (
          <div class="group flex flex-col justify-between p-8 sm:p-10 h-full bg-white rounded-3xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden reveal flex-1">
            <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
            <div class="absolute -bottom-6 -right-4 text-9xl font-black text-black/2 group-hover:text-accent/[0.04] transition-all duration-500 select-none">0{i + 1}</div>
            <div class="relative z-10 flex flex-col h-full justify-between">
              <div>
                <div class="p-3 bg-zinc-50 border border-black/5 w-fit rounded-xl mb-6 group-hover:bg-accent/5 transition-colors">
                  <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                </div>
                <h3 class="text-xl sm:text-2xl uppercase mb-3 tracking-tighter group-hover:text-accent font-black text-zinc-900 border-b border-zinc-100 pb-2 w-fit">{s.title}</h3>
                <p class="text-xs sm:text-sm text-zinc-500 leading-relaxed font-light">{s.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ 4. TIMELINE ═══ -->
  <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16 sm:mb-24 reveal">
        <h2 class="text-2xl sm:text-5xl lg:text-7xl font-black tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.85]">
          Cómo trabajamos el SEM en Barcelona
        </h2>
        <div class="text-zinc-500 w-[75%] mx-auto font-light text-sm sm:text-base leading-relaxed">
          <p>Olvídate del SEM en piloto automático. Contarás con un <strong>Account Manager dedicado</strong> que conoce el mercado de Barcelona y trabajará de la mano con tu equipo para supervisar avances y mantenerte informado con métricas reales.</p>
        </div>
      </div>
      <div id="timeline-container" class="relative timeline-container">
        <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
        <div class="progress-bar hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100" style="height: 0%;"></div>
        <div class="space-y-16 md:space-y-24 flex flex-col items-center">
          {steps.map((step, index) => (
            <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal" style={`transition-delay: ${index * 100}ms`}>
              <div class="hidden md:block md:flex-1 text-right md:order-1">
                {index % 2 === 0 && (
                  <div class="md:pr-12">
                    <h3 class="text-xl sm:text-2xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{step.title}</h3>
                    <p class="text-sm text-zinc-500 font-light max-w-md ml-auto">{step.desc}</p>
                  </div>
                )}
              </div>
              <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all duration-300">0{index + 1}</div>
              <div class="flex-1 text-left md:order-3">
                <div class="md:pl-12">
                  <h3 class:list={["text-xl sm:text-2xl font-black uppercase tracking-tighter mb-2 text-zinc-900", index % 2 === 0 ? "md:hidden" : ""]}>{step.title}</h3>
                  <p class:list={["text-sm text-zinc-500 font-light max-w-md mr-auto", index % 2 === 0 ? "md:hidden" : ""]}>{step.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
  <style>
    .timeline-container .reveal { opacity: 0; transform: translateY(20px); transition: all 0.6s cubic-bezier(0.165, 0.84, 0.44, 1); }
    .timeline-container .reveal.active { opacity: 1; transform: translateY(0); }
  </style>
  <script is:inline>
    function initTimeline() {
      const timeline = document.getElementById('timeline-container');
      const progressBar = timeline?.querySelector('.progress-bar');
      function updateProgress() {
        if (!timeline || !progressBar) return;
        const rect = timeline.getBoundingClientRect();
        const winHeight = window.innerHeight;
        const topPassed = (winHeight / 2) - rect.top;
        let percentage = (topPassed / rect.height) * 100;
        percentage = Math.max(0, Math.min(100, percentage));
        progressBar.style.height = `${percentage}%`;
        const nodes = timeline.querySelectorAll('.node-circle');
        nodes.forEach((node) => {
          const nodeTop = node.getBoundingClientRect().top;
          if (nodeTop < winHeight / 2) { node.classList.add('!border-accent', '!bg-accent', '!text-white'); }
          else { node.classList.remove('!border-accent', '!bg-accent', '!text-white'); }
        });
      }
      window.addEventListener('scroll', updateProgress);
      document.addEventListener('astro:page-load', updateProgress);
      updateProgress();
    }
    document.addEventListener('DOMContentLoaded', initTimeline);
    document.addEventListener('astro:page-load', initTimeline);
  </script>

  <!-- ═══ 5. CONSULTOR ═══ -->
  <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
    <div class="max-w-6xl mx-auto reveal">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
        <div class="md:col-span-5 relative group flex justify-center">
          <div class="absolute inset-0 bg-accent/20 rounded-full blur-3xl opacity-30 group-hover:scale-105 transition-transform duration-500"></div>
          <div class="relative w-full max-w-sm">
            <div class="absolute -top-6 -left-6 w-24 h-24 bg-[radial-gradient(#000000_15%,transparent_15%)] bg-[length:12px_12px] opacity-20"></div>
            <div class="overflow-hidden rounded-[2rem] shadow-[0_30px_60px_-15px_rgba(0,0,0,0.1)] border-4 border-white">
              <img src="/img/consultor-de-google-ads-en-barcelona.webp" alt="Consultor de Google Ads en Barcelona" class="w-full h-auto object-cover">
            </div>
            <div class="absolute -bottom-4 -right-4 backdrop-blur-md bg-black/90 text-white px-6 py-4 rounded-xl shadow-xl flex items-center gap-3 border border-white/10">
              <div class="w-2 h-2 bg-accent rounded-full animate-pulse"></div>
              <div class="text-[10px] sm:text-xs font-black uppercase tracking-widest">Estrategia SEM</div>
            </div>
          </div>
        </div>
        <div class="md:col-span-7 text-left">
          <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.4em] text-accent mb-4 block">Rentabilidad PPC</span>
          <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.85]">
            Consultor de Google Ads en Barcelona
          </h2>
          <p class="text-zinc-500 font-light text-base sm:text-lg leading-relaxed mb-8">Como consultor experto en Google Ads en Barcelona, configuro y optimizo campañas para que ningún euro de presupuesto se pierda en clics irrelevantes. Conozco el mercado local barcelonés —desde el Eixample y el Born hasta el 22@ y la Zona Franca— y diseño estrategias orientadas a atraer compradores de alta intención en la ciudad.</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="p-6 bg-zinc-50 border border-black/5 rounded-xl hover:bg-zinc-100 transition-colors">
              <div class="text-sm font-black uppercase tracking-wider text-black mb-2">Auditoría</div>
              <p class="text-xs text-zinc-400 font-light">Control de presupuesto de clics.</p>
            </div>
            <div class="p-6 bg-zinc-50 border border-black/5 rounded-xl hover:bg-zinc-100 transition-colors">
              <div class="text-sm font-black uppercase tracking-wider text-black mb-2">ROI Directo</div>
              <p class="text-xs text-zinc-400 font-light">Enfoque a beneficio local.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ 6. RENTABILIDAD + STATS + TESTIMONIALS ═══ -->
  <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16 sm:mb-24 reveal">
        <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
          Rentabilidad de campañas de Google Ads en Barcelona
        </h2>
        <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
          No medimos el éxito en clics. Medimos el coste por adquisición y el margen de beneficio generado. Obtendrás un panel de métricas transparentes alineadas con las ventas reales de tu negocio en Barcelona.
        </p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16 reveal text-center">
        <div class="p-8 bg-white rounded-2xl border border-black/5 shadow-sm hover:shadow-xl hover:-translate-y-1 hover:border-accent/10 transition-all duration-300"><div class="text-4xl sm:text-5xl font-black text-accent mb-2 tracking-tighter">+40%</div><div class="text-xs text-zinc-400 font-black tracking-widest uppercase">Media de Conversión</div></div>
        <div class="p-8 bg-white rounded-2xl border border-black/5 shadow-sm hover:shadow-xl hover:-translate-y-1 hover:border-accent/10 transition-all duration-300"><div class="text-4xl sm:text-5xl font-black text-accent mb-2 tracking-tighter">-35%</div><div class="text-xs text-zinc-400 font-black tracking-widest uppercase">Reducción Coste / Clic</div></div>
        <div class="p-8 bg-white rounded-2xl border border-black/5 shadow-sm hover:shadow-xl hover:-translate-y-1 hover:border-accent/10 transition-all duration-300"><div class="text-4xl sm:text-5xl font-black text-accent mb-2 tracking-tighter">x4.5</div><div class="text-xs text-zinc-400 font-black tracking-widest uppercase">Retorno Inversión (ROI)</div></div>
        <div class="p-8 bg-white rounded-2xl border border-black/5 shadow-sm hover:shadow-xl hover:-translate-y-1 hover:border-accent/10 transition-all duration-300"><div class="text-4xl sm:text-5xl font-black text-accent mb-2 tracking-tighter">x3</div><div class="text-xs text-zinc-400 font-black tracking-widest uppercase">Leads Cualificados/Mes</div></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 reveal">
        <div class="bg-zinc-950 text-white p-10 rounded-2xl border border-zinc-800 flex flex-col justify-between group hover:shadow-2xl hover:border-zinc-700 transition-all">
          <div>
            <div class="flex items-center gap-1 mb-6 text-accent">★★★★★</div>
