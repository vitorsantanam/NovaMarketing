---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildAlternates } from '../lib/i18n';
import { strapiClient } from '../lib/strapi';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-diseno-web-barcelona/', '/ca/agencia-disseny-web-barcelona/', SITE_URL);

const faqItems = [
  {
    question: "¿Por qué necesita mi empresa de Barcelona una web profesional?",
    answer: "Barcelona es uno de los mercados digitales más competitivos de España. En barrios como el Eixample, Gràcia o el 22@ del Poblenou, miles de empresas compiten por la atención del mismo cliente online. Sin una web profesional, rápida y orientada a convertir, tu negocio queda invisible frente a competidores que sí tienen una presencia digital sólida en la ciudad."
  },
  {
    question: "¿Cuánto cuesta diseñar una web para una empresa de Barcelona?",
    answer: "El coste varía según el proyecto: una web corporativa para una pyme barcelonesa parte desde 1.500€, mientras que un e-commerce completo puede llegar a 10.000€ o más dependiendo de la complejidad. Trabajamos con empresas de todos los barrios y sectores de Barcelona, desde autónomos del Born hasta empresas tecnológicas del 22@, adaptando cada propuesta al presupuesto y objetivos reales."
  },
  {
    question: "¿Qué hace diferente a una web que convierte en el mercado de Barcelona?",
    answer: "En Barcelona, el consumidor digital es exigente y multidispositivo. Una web que convierte carga en menos de 2 segundos en móvil, transmite credibilidad desde el primer scroll, tiene llamadas a la acción claras y está optimizada para Google. No basta con el diseño: la experiencia de usuario y la orientación a conversión son lo que separa una web rentable de una decorativa."
  },
  {
    question: "¿Cuánto tiempo tarda diseñar mi web en Barcelona?",
    answer: "Un proyecto web estándar en Barcelona dura entre 3 y 6 semanas. Para proyectos más complejos, como tiendas online para empresas del Eixample o webs corporativas para startups del Poblenou, el plazo puede extenderse a 8-12 semanas. Siempre con un Account Manager dedicado que te mantiene informado de cada avance sin sorpresas."
  },
  {
    question: "¿Diseñáis webs para startups y empresas tecnológicas del 22@ de Barcelona?",
    answer: "Sí. El districte 22@ del Poblenou es uno de los hubs tecnológicos más importantes de Europa. Diseñamos webs para startups, scaleups y empresas tecnológicas del 22@ que necesitan una presencia digital a la altura de su ambición: webs modernas, ultrarrápidas, con diseño premium y orientadas a captar talento, inversores y clientes B2B."
  },
  {
    question: "¿Incluís optimización SEO en el diseño web para Barcelona?",
    answer: "Sí. Todas nuestras webs para empresas de Barcelona incluyen las bases técnicas del SEO desde el diseño: estructura semántica, velocidad Core Web Vitals, datos estructurados Schema y contenidos orientados a las búsquedas de tus clientes en Barcelona y sus barrios. Posicionarte en Google desde el primer día es parte de nuestra metodología."
  },
  {
    question: "¿Diseñáis tiendas online para comercios y marcas de Barcelona?",
    answer: "Sí. Diseñamos e-commerce para marcas y comercios de Barcelona, tanto de barrios tradicionales como el Born, Gràcia o Sarrià-Sant Gervasi, como para marcas online que operan desde la ciudad. Integramos las mejores pasarelas de pago, gestión de catálogo y experiencias de compra optimizadas para el consumidor barcelonés."
  },
  {
    question: "¿Cómo os diferenciáis de otras agencias de diseño web en Barcelona?",
    answer: "En un mercado tan saturado como Barcelona, la diferencia está en los resultados. No vendemos webs bonitas, construimos activos digitales que generan negocio. Nuestro enfoque combina diseño orientado a conversión, bases SEO sólidas y seguimiento post-lanzamiento con métricas reales. Y lo hacemos con conocimiento del mercado local de cada barrio de Barcelona."
  },
  {
    question: "¿Podéis rediseñar la web de mi empresa en Barcelona para que convierta más?",
    answer: "Sí. Si tu web existe pero no convierte, realizamos un análisis UX y de rendimiento para identificar los puntos de fuga. Muchas empresas de Barcelona con webs antiguas o mal diseñadas pierden clientes a diario. Un rediseño orientado a conversión puede transformar radicalmente tus resultados digitales, tanto en el Eixample como en Les Corts o Sant Martí."
  },
  {
    question: "¿Trabajáis con empresas de hostelería, restauración y turismo en Barcelona?",
    answer: "Sí. Barcelona es una de las ciudades con más volumen turístico de Europa, y el sector hostelero y de restauración tiene una oportunidad enorme en el canal digital. Diseñamos webs para hoteles boutique del Gothic, restaurantes del Born, bares de Gràcia y empresas turísticas del Passeig de Gràcia que quieren captar reservas directas y reducir su dependencia de las plataformas intermediarias."
  }
];

let webCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('es');
  webCases = casesRes.data
    .map((i: any) => i.attributes ?? i)
    .filter((c: any) => {
      const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
      return cats.some((s: string) => s.includes('web') || s.includes('dise'));
    });
} catch {}

const steps = [
  { title: "Análisis y Estrategia Web en Barcelona", desc: "Estudiamos tu negocio, tu sector y tu competencia en Barcelona. Ya sea que estés en el Eixample, en el Born o en el 22@ del Poblenou, definimos una arquitectura web orientada a captar exactamente a tus clientes en la ciudad." },
  { title: "Diseño UX para el Usuario Barcelonés", desc: "Creamos diseños tan cuidados como el modernismo de la Diagonal: sin excesos, funcionales y orientados al usuario. El cliente barcelonés juzga en segundos —diseñamos para que la primera impresión sea la que convierte." },
  { title: "Desarrollo y Maquetación", desc: "Construimos tu web con tecnología de última generación, tan robusta y escalable como la arquitectura del 22@. Velocidad, seguridad y código limpio para que tu web compita en el exigente mercado digital de Barcelona." },
  { title: "Optimización SEO y Core Web Vitals", desc: "Antes de lanzar, auditamos velocidad, Core Web Vitals y SEO técnico. Tu web saldrá lista para posicionar en Google y captar clientes que buscan tus servicios desde Sarrià hasta Poblenou, desde Gràcia hasta Les Corts." },
  { title: "Lanzamiento y Mejora Continua", desc: "Tras el lanzamiento analizamos datos, comportamiento de usuarios y conversiones. Barcelona es un mercado que no se estanca: tu web tampoco. Mejoramos continuamente para maximizar el retorno mes a mes." }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Agencia de Diseño Web para Pymes",
  "provider": {
    "@type": "ProfessionalService",
    "@id": "https://novamarketing.es/#organization",
    "name": "Nova Marketing",
    "image": "https://novamarketing.es/agencia-marketing-pymes-nova-marketing-logo.png",
    "telephone": "+34644738270",
    "priceRange": "€€",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Calle General Mendoza 10",
      "addressLocality": "Barcelona",
      "addressRegion": "Barcelona",
      "postalCode": "08035",
      "addressCountry": "ES"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "47"
    }
  },
  "areaServed": {
    "@type": "City",
    "name": "Barcelona",
    "sameAs": "https://www.wikidata.org/wiki/Q1492"
  },
  "description": "Expertos en diseño de páginas web y desarrollo orientado a conversión para pequeñas y medianas empresas en Barcelona. Webs modernas, rápidas y optimizadas para el competitivo mercado digital de la ciudad.",
  "offers": {
    "@type": "Offer",
    "priceRange": "€€"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Servicios de Diseño y Desarrollo Web",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Diseño Web Corporativo" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Desarrollo de Tiendas Online (E-commerce)" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Optimización de Velocidad y WPO" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Mantenimiento Web y Seguridad" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Rediseño y UX (Experiencia de Usuario)" } }
    ]
  }
};
---

<BaseLayout
  title="Agencia de Diseño Web en Barcelona | Nova Marketing"
  description="Diseñamos páginas web que convierten para empresas de Barcelona. Webs rápidas, optimizadas y orientadas a resultados en el competitivo mercado digital barcelonés. Solicita presupuesto."
  locale="es"
  alternates={alternates}
  schemas={[serviceSchema, faqSchema]}
>

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[88vh] flex items-center justify-center pt-24 pb-16 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
    <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
    <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>
    <div class="max-w-7xl mx-auto reveal relative z-10">
      <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-6 shadow-sm">
        <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
        Especialistas en Diseño Web en Barcelona
      </span>
      <h1 class="text-4xl sm:text-6xl md:text-7xl lg:text-[5.5rem] uppercase font-black tracking-tighter leading-[0.82] mb-8 text-zinc-900 flex flex-col items-center text-center">
        <span>Agencia de</span>
        <span>Diseño Web en</span>
        <span class="text-mktg-gradient px-4 overflow-visible inline-block">Barcelona</span>
      </h1>
      <p class="text-base sm:text-lg text-zinc-500 font-light leading-relaxed max-w-2xl mx-auto mb-12">
        Diseñamos páginas web que convierten para empresas de Barcelona. Desde las startups del 22@ hasta los comercios del Eixample y los restaurantes del Born, creamos webs modernas, rápidas y orientadas a resultados en uno de los mercados digitales más competitivos de España.
      </p>
      <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
        <button class="contact-modal-trigger btn-mktg-v5 shadow-[0_20px_40px_-10px_rgba(0,0,0,0.15)] hover:shadow-[0_25px_50px_-12px_rgba(0,0,0,0.25)] hover:-translate-y-1 transition-all duration-300 !py-5 !px-12 !text-[12px] !tracking-wider font-black w-full sm:w-auto">
          SOLICITAR PRESUPUESTO GRATIS
        </button>
      </div>
    </div>
  </section>

  <!-- ═══ LOGOS CLIENTES ═══ -->
  <section class="py-12 border-b border-black/5 bg-zinc-50/40 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="text-[9px] sm:text-[10px] uppercase font-black tracking-widest text-zinc-400 text-center mb-8">Pymes que ya estrenan web con Nova</p>
      <div class="overflow-hidden w-full relative [mask-image:linear-gradient(to_right,transparent,white_10%,white_90%,transparent)]">
        <div id="logos-marquee-web-bcn" class="flex items-center gap-16 w-max animate-scroll-logo-web-bcn"></div>
      </div>
    </div>
  </section>
  <style>
    @keyframes scrollMarqueeLogoWebBCN { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
    .animate-scroll-logo-web-bcn { animation: scrollMarqueeLogoWebBCN 60s linear infinite; }
  </style>
  <script is:inline>
    (function() {
      var logos = [
        { src: "/clients/bermaq-cliente-novamarketing.webp", alt: "Bermaq" },
        { src: "/clients/cb-lhospitalet-cliente-novamarketing.webp", alt: "CB l'Hospitalet" },
        { src: "/clients/medhs-cliente-novamarketing.webp", alt: "MedHS" },
        { src: "/clients/palacio-del-bebe-cliente-novamarketing.webp", alt: "Palacio del bebé" },
        { src: "/clients/tagtio-cliente-novamarketing.webp", alt: "Tagtio" },
        { src: "/clients/tejados-tapar-cliente-novamarketing.webp", alt: "Tejados Tapar" },
        { src: "/clients/fastpoint-cliente-novamarketing.webp", alt: "FastPoint" },
        { src: "/clients/mundeta-cliente-novamarketing.webp", alt: "Mundeta" },
        { src: "/clients/tattoox-cliente-novamarketing.webp", alt: "TattooX" },
        { src: "/clients/voltura-projects-cliente-novamarketing.webp", alt: "Voltura Projects" }
      ];
      var shuffled = logos.sort(function() { return Math.random() - 0.5; });
      var full = shuffled.concat(shuffled, shuffled, shuffled);
      var c = document.getElementById('logos-marquee-web-bcn');
      if (c) c.innerHTML = full.map(function(l) { return '<img src="' + l.src + '" alt="' + l.alt + '" class="h-[50px] w-auto object-contain filter grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-300 pointer-events-none" style="mix-blend-mode:multiply" />'; }).join('');
    })();
  </script>

  <!-- ═══ EXPERTOS EN DISEÑO WEB EN BARCELONA ═══ -->
  <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808005_1px,transparent_1px),linear-gradient(to_bottom,#80808005_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_50%,#000_80%,transparent_100%)]"></div>
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 sm:mb-24 reveal">
        <h2 class="text-3xl sm:text-5xl lg:text-7xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.82]">
          Expertos en Diseño Web<br class="hidden sm:inline" /> en Barcelona
        </h2>
        <p class="text-zinc-500 font-light text-base sm:text-lg leading-relaxed max-w-2xl mx-auto">
          Barcelona no perdona las webs mediocres. Diseñamos sitios web orientados al mercado más competitivo de Cataluña: pensados para el usuario exigente, optimizados para Google y construidos para convertir.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 items-stretch">
        {[
          { title: "Diseño que Convierte en BCN", desc: "En el mercado digital de Barcelona, la competencia es máxima. Creamos webs orientadas a resultados que captan al cliente barcelonés desde el primer scroll y no lo sueltan hasta el contacto." },
          { title: "UX para el Usuario Barcelonés", desc: "El usuario de Barcelona es exigente, multidispositivo y compare. Diseñamos experiencias digitales tan cuidadas como el modernismo del Passeig de Gràcia: funcionales, bellas y orientadas a convertir." },
          { title: "Rendimiento y Core Web Vitals", desc: "Webs con puntuaciones perfectas en Core Web Vitals y velocidad de carga premium. En Barcelona, donde cada segundo cuenta, una web rápida es una ventaja competitiva real en los resultados de Google." },
          { title: "SEO Local por Barrios de BCN", desc: "Construimos estructura SEO desde el diseño para que aparezcas en Google cuando tus clientes buscan tus servicios en Gràcia, el Born, el Poblenou, el Eixample o cualquier barrio de Barcelona." }
        ].map((s, i) => (
          <div class="group flex flex-col justify-between p-8 sm:p-10 h-full bg-white rounded-3xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden reveal flex-1">
            <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
            <div class="absolute -bottom-6 -right-4 text-9xl font-black text-black/2 group-hover:text-accent/[0.04] transition-all duration-500 select-none">0{i + 1}</div>
            <div class="relative z-10 flex flex-col h-full justify-between">
              <div>
                <div class="p-3 bg-zinc-50 border border-black/5 w-fit rounded-xl mb-6 group-hover:bg-accent/5 transition-colors">
                  <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                </div>
                <h3 class="text-xl sm:text-2xl uppercase mb-3 tracking-tighter group-hover:text-accent font-black text-zinc-900 border-b border-zinc-100 pb-2 w-fit">{s.title}</h3>
                <p class="text-xs sm:text-sm text-zinc-500 leading-relaxed font-light">{s.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ TIMELINE / PROCESO ═══ -->
  <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16 sm:mb-24 reveal">
        <h2 class="text-2xl sm:text-5xl lg:text-7xl font-black tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.85]">
          Cómo diseñamos tu web en Barcelona
        </h2>
        <div class="text-zinc-500 w-[75%] mx-auto font-light text-sm sm:text-base leading-relaxed">
          <p>Un proceso claro y sin sorpresas, con un <strong>Account Manager dedicado</strong> que trabaja contigo en cada fase. En el mercado más competitivo de Cataluña, cada decisión de diseño está respaldada por datos y estrategia.</p>
        </div>
      </div>
      <div id="timeline-container" class="relative timeline-container">
        <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
        <div class="progress-bar hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100" style="height: 0%;"></div>
        <div class="space-y-16 md:space-y-24 flex flex-col items-center">
          {steps.map((step, index) => (
            <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal" style={`transition-delay: ${index * 100}ms`}>
              <div class="hidden md:block md:flex-1 text-right md:order-1">
                {index % 2 === 0 && (
                  <div class="md:pr-12">
                    <h3 class="text-xl sm:text-2xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{step.title}</h3>
                    <p class="text-sm text-zinc-500 font-light max-w-md ml-auto">{step.desc}</p>
                  </div>
                )}
              </div>
              <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all duration-300">0{index + 1}</div>
              <div class="flex-1 text-left md:order-3">
                <div class="md:pl-12">
                  <h3 class:list={["text-xl sm:text-2xl font-black uppercase tracking-tighter mb-2 text-zinc-900", index % 2 === 0 ? "md:hidden" : ""]}>{step.title}</h3>
                  <p class:list={["text-sm text-zinc-500 font-light max-w-md mr-auto", index % 2 === 0 ? "md:hidden" : ""]}>{step.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
  <style>
    .timeline-container .reveal { opacity: 0; transform: translateY(20px); transition: all 0.6s cubic-bezier(0.165, 0.84, 0.44, 1); }
    .timeline-container .reveal.active { opacity: 1; transform: translateY(0); }
  </style>
  <script is:inline>
    function initTimeline() {
      var timeline = document.getElementById('timeline-container');
      var progressBar = timeline && timeline.querySelector('.progress-bar');
      function updateProgress() {
        if (!timeline || !progressBar) return;
        var rect = timeline.getBoundingClientRect();
        var winHeight = window.innerHeight;
        var topPassed = (winHeight / 2) - rect.top;
        var percentage = Math.max(0, Math.min(100, (topPassed / rect.height) * 100));
        progressBar.style.height = percentage + '%';
        timeline.querySelectorAll('.node-circle').forEach(function(node) {
          if (node.getBoundingClientRect().top < winHeight / 2) { node.classList.add('!border-accent', '!bg-accent', '!text-white'); }
          else { node.classList.remove('!border-accent', '!bg-accent', '!text-white'); }
        });
      }
      window.addEventListener('scroll', updateProgress);
      document.addEventListener('astro:page-load', updateProgress);
      updateProgress();
    }
    document.addEventListener('DOMContentLoaded', initTimeline);
    document.addEventListener('astro:page-load', initTimeline);
  </script>

  <!-- ═══ CONSULTOR DISEÑO WEB ═══ -->
  <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
    <div class="max-w-6xl mx-auto reveal">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
        <div class="md:col-span-5 relative group flex justify-center">
          <div class="absolute inset-0 bg-accent/20 rounded-full blur-3xl opacity-30 group-hover:scale-105 transition-transform duration-500"></div>
          <div class="relative w-full max-w-sm">
            <div class="absolute -top-6 -left-6 w-24 h-24 bg-[radial-gradient(#000000_15%,transparent_15%)] bg-[length:12px_12px] opacity-20"></div>
            <div class="overflow-hidden rounded-[2rem] shadow-[0_30px_60px_-15px_rgba(0,0,0,0.1)] border-4 border-white">
              <img src="/img/consultor-de-seo-en-barcelona.webp" alt="Consultor de Diseño Web en Barcelona" class="w-full h-auto object-cover">
            </div>
            <div class="absolute -bottom-4 -right-4 backdrop-blur-md bg-black/90 text-white px-6 py-4 rounded-xl shadow-xl flex items-center gap-3 border border-white/10">
              <div class="w-2 h-2 bg-accent rounded-full animate-pulse"></div>
              <div class="text-[10px] sm:text-xs font-black uppercase tracking-widest">Diseño Web Barcelona</div>
            </div>
          </div>
        </div>
        <div class="md:col-span-7 text-left">
          <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.4em] text-accent mb-4 block">Diseño y Desarrollo Web</span>
          <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.85]">
            Consultor de Diseño Web en Barcelona
          </h2>
