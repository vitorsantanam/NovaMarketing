---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildAlternates } from '../lib/i18n';
import { strapiClient } from '../lib/strapi';
import LogoMarquee from '../components/sections/LogoMarquee.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-seo-en-barcelona', '/ca/agencia-seo-a-barcelona', SITE_URL);

const faqItems = [
  {
    question: "¿Cómo puede el SEO ayudar a mi negocio a destacar en un mercado tan competitivo como Barcelona?",
    answer: "Barcelona tiene miles de empresas compitiendo por los mismos clientes. La clave está en la hiperlocalización: posicionarse por barrios concretos como el Eixample, Gràcia o Sarrià en lugar de intentar competir con toda la ciudad a la vez. Identificamos las búsquedas con mayor intención de compra en tu zona y tu sector para que tu negocio aparezca primero cuando más importa."
  },
  {
    question: "¿Qué diferencia al SEO en Barcelona del SEO en otras ciudades?",
    answer: "La competencia es mucho más alta y los volúmenes de búsqueda son mayores. Esto significa que una buena posición en Google en Barcelona puede generar un flujo muy importante de clientes. Pero también requiere una estrategia más robusta: más contenido de calidad, más autoridad de dominio y una arquitectura web más cuidada."
  },
  {
    question: "¿El SEO local funciona para negocios en el Eixample o en el 22@?",
    answer: "Absolutamente. El Eixample es el distrito comercial más denso de Barcelona, y el 22@ concentra empresas tecnológicas y creativas. En ambos casos, el SEO local por barrio es muy efectivo porque los usuarios buscan proveedores cercanos. Optimizamos tu presencia en Google Maps y en las búsquedas orgánicas por zona."
  },
  {
    question: "¿Cuánto tiempo tarda el SEO en posicionar en Barcelona?",
    answer: "Por la alta competencia, el horizonte habitual en Barcelona es de 4-8 meses para ver mejoras significativas en sectores competidos. En nichos más específicos puede ser más rápido. Lo importante es que el SEO construye un activo duradero: a diferencia de Google Ads, las posiciones ganadas no desaparecen cuando paras la inversión."
  },
  {
    question: "¿Trabajáis el SEO para ecommerce y tiendas físicas de Barcelona?",
    answer: "Sí, para ambos modelos. Para tiendas físicas trabajamos el SEO local por barrio y la optimización del Google Business Profile. Para ecommerce, desarrollamos estrategias de posicionamiento de categorías y fichas de producto que generan tráfico orgánico cualificado y reducen la dependencia de la publicidad de pago."
  }
];

let seoCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('es');
  seoCases = casesRes.data
    .map((i: any) => i.attributes ?? i)
    .filter((c: any) => {
      const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
      return cats.some((s: string) => s.includes('seo') || s.includes('consultor'));
    });
} catch {}

const steps = [
  { title: "Auditoría SEO en Barcelona", desc: "Analizamos tu web en profundidad y evaluamos la competencia en tu sector dentro de Barcelona. Identificamos los errores técnicos y las oportunidades de posicionamiento por barrio y por keyword." },
  { title: "Keyword Research por Barrios", desc: "Barcelona se posiciona barrio a barrio. Identificamos las búsquedas con mayor intención de compra en tu zona — Eixample, Gràcia, Poblenou, Sarrià — para atraer el tráfico más cualificado." },
  { title: "SEO On-Page y Contenidos", desc: "Creamos y optimizamos contenidos que posicionan tu negocio en Barcelona. Desde landing pages de barrio hasta artículos de blog que construyen autoridad temática en tu sector." },
  { title: "Linkbuilding en Medios Barcelona", desc: "Conseguimos menciones y enlaces en medios digitales barceloneses, directorios locales y webs de referencia que trasladan autoridad a tu dominio y mejoran tu ranking." },
  { title: "SEO Local y Google Maps", desc: "Posicionamos tu ficha de Google Business Profile para que aparezcas en el pack local cuando alguien busca tu servicio en tu barrio de Barcelona. Más reseñas, más visibilidad, más clientes." }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Agencia de Posicionamiento SEO para Pymes",
  "provider": {
    "@type": "ProfessionalService",
    "@id": "https://novamarketing.es/#organization",
    "name": "Nova Marketing",
    "image": "https://novamarketing.es/agencia-marketing-pymes-nova-marketing-logo.png",
    "telephone": "+34644738270",
    "priceRange": "€€",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Carrer de Bilbao 1",
      "addressLocality": "Sabadell",
      "addressRegion": "Barcelona",
      "postalCode": "08202",
      "addressCountry": "ES"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "35"
    }
  },
  "areaServed": {
    "@type": "City",
    "name": "Barcelona",
    "sameAs": "https://www.wikidata.org/wiki/Q1492"
  },
  "description": "Expertos en posicionamiento SEO y SEO local para pequeñas y medianas empresas en Barcelona. Maximizamos tu visibilidad orgánica en Google por barrios: Eixample, 22@, Gràcia, Born, Poblenou y Sarrià.",
  "offers": { "@type": "Offer", "priceRange": "€€" },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Servicios de Posicionamiento SEO",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Auditoría SEO técnica" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Keyword Research local por barrios" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "SEO On-Page y contenidos" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Linkbuilding y autoridad de dominio" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "SEO Local y Google Business Profile" }}
    ]
  }
};
---

<BaseLayout
  title="Agencia SEO en Barcelona | Nova Marketing"
  description="Barcelona es el mercado más competitivo de Cataluña. Posicionamos tu empresa en Google por barrios: Eixample, 22@, Gràcia o Sarrià. Auditoría SEO gratis."
  locale="es"
  alternates={alternates}
  schemas={[serviceSchema, faqSchema]}
>

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[88vh] flex items-center justify-center pt-24 pb-16 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
    <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
    <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>
    <div class="max-w-7xl mx-auto reveal relative z-10">
      <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-6 shadow-sm">
        <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
        Especialistas en Posicionamiento SEO en Barcelona
      </span>
      <h1 class="text-4xl sm:text-6xl md:text-7xl lg:text-[5.5rem] uppercase font-black tracking-tighter leading-[0.82] mb-8 text-zinc-900 flex flex-col items-center text-center">
        <span>Agencia de</span>
        <span>Posicionamiento SEO</span>
        <span class="text-mktg-gradient px-4 overflow-visible inline-block">en Barcelona</span>
      </h1>
      <p class="text-base sm:text-lg text-zinc-500 font-light leading-relaxed max-w-2xl mx-auto mb-12">
        Posicionamos tu empresa en Google en el mercado más competitivo de Cataluña. Desde el Eixample y el 22@ hasta Gràcia, Born o Sarrià, dominamos las búsquedas locales por barrio que generan clientes reales.
      </p>
      <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
        <button class="contact-modal-trigger btn-mktg-v5 shadow-[0_20px_40px_-10px_rgba(0,0,0,0.15)] hover:shadow-[0_25px_50px_-12px_rgba(0,0,0,0.25)] hover:-translate-y-1 transition-all duration-300 !py-5 !px-12 !text-[12px] !tracking-wider font-black w-full sm:w-auto">
          SOLICITAR AUDITORÍA GRATIS
        </button>
      </div>
    </div>
  </section>

  <!-- ═══ LOGOS CLIENTES ═══ -->
  <LogoMarquee />

  <!-- ═══ AUDITORÍA Y ESTRATEGIA ═══ -->
  <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808005_1px,transparent_1px),linear-gradient(to_bottom,#80808005_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_50%,#000_80%,transparent_100%)]"></div>
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 sm:mb-24 reveal">
        <h2 class="text-3xl sm:text-5xl lg:text-7xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.82]">
          Auditoría y Estrategia <br class="hidden sm:inline" /> SEO en Barcelona
        </h2>
        <p class="text-zinc-500 font-light text-base sm:text-lg leading-relaxed max-w-2xl mx-auto">
          En Barcelona, improvisar en SEO es tirar el presupuesto. Analizamos tu competencia por barrio y sector para encontrar los huecos de oportunidad que otros no ven y posicionarte donde tus clientes te buscan.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 items-stretch">
        {[
          { title: "Auditoría Técnica", desc: "Detectamos los errores que frenan tu visibilidad en Barcelona: velocidad, indexación, Core Web Vitals y arquitectura de URLs para el mercado barcelonés." },
          { title: "Keywords por Barrio", desc: "Analizamos las búsquedas de cada zona de Barcelona para posicionar tu negocio donde está tu cliente ideal: Eixample, 22@, Gràcia, Poblenou o Sarrià." },
          { title: "SEO On-Page", desc: "Optimizamos contenidos y estructura para que Google entienda que eres la mejor opción en tu barrio y sector dentro de Barcelona." },
          { title: "Linkbuilding Barcelonés", desc: "Construimos autoridad con enlaces de medios digitales barceloneses, directorios locales y webs de referencia que potencian tu posición en Google." }
        ].map((s, i) => (
          <div class="group flex flex-col justify-between p-8 sm:p-10 h-full bg-white rounded-3xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden reveal flex-1">
            <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
            <div class="absolute -bottom-6 -right-4 text-9xl font-black text-black/2 group-hover:text-accent/[0.04] transition-all duration-500 select-none">0{i + 1}</div>
            <div class="relative z-10 flex flex-col h-full justify-between">
              <div>
                <div class="p-3 bg-zinc-50 border border-black/5 w-fit rounded-xl mb-6 group-hover:bg-accent/5 transition-colors">
                  <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                </div>
                <h3 class="text-xl sm:text-2xl uppercase mb-3 tracking-tighter group-hover:text-accent font-black text-zinc-900 border-b border-zinc-100 pb-2 w-fit">{s.title}</h3>
                <p class="text-xs sm:text-sm text-zinc-500 leading-relaxed font-light">{s.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ TIMELINE ═══ -->
  <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16 sm:mb-24 reveal">
        <h2 class="text-2xl sm:text-5xl lg:text-7xl font-black tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.85]">
          Cómo trabajamos el SEO en Barcelona
        </h2>
        <div class="text-zinc-500 w-[75%] mx-auto font-light text-sm sm:text-base leading-relaxed">
          <p>En el mercado más exigente de Cataluña no hay margen para el error. Contarás con un <strong>Account Manager dedicado</strong> que conoce Barcelona barrio a barrio y trabaja con métricas de negocio reales, no con vanity metrics.</p>
        </div>
      </div>
      <div id="timeline-container" class="relative timeline-container">
        <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
        <div class="progress-bar hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100" style="height: 0%;"></div>
        <div class="space-y-16 md:space-y-24 flex flex-col items-center">
          {steps.map((step, index) => (
            <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal" style={`transition-delay: ${index * 100}ms`}>
              <div class="hidden md:block md:flex-1 text-right md:order-1">
                {index % 2 === 0 && (
                  <div class="md:pr-12">
                    <h3 class="text-xl sm:text-2xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{step.title}</h3>
                    <p class="text-sm text-zinc-500 font-light max-w-md ml-auto">{step.desc}</p>
                  </div>
                )}
              </div>
              <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all duration-300">0{index + 1}</div>
              <div class="flex-1 text-left md:order-3">
                <div class="md:pl-12">
                  <h3 class:list={["text-xl sm:text-2xl font-black uppercase tracking-tighter mb-2 text-zinc-900", index % 2 === 0 ? "md:hidden" : ""]}>{step.title}</h3>
                  <p class:list={["text-sm text-zinc-500 font-light max-w-md mr-auto", index % 2 === 0 ? "md:hidden" : ""]}>{step.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
  <style>
    .timeline-container .reveal { opacity: 0; transform: translateY(20px); transition: all 0.6s cubic-bezier(0.165, 0.84, 0.44, 1); }
    .timeline-container .reveal.active { opacity: 1; transform: translateY(0); }
  </style>
  <script is:inline>
    function initTimeline() {
      const timeline = document.getElementById('timeline-container');
      const progressBar = timeline?.querySelector('.progress-bar');
      function updateProgress() {
        if (!timeline || !progressBar) return;
        const rect = timeline.getBoundingClientRect();
        const winHeight = window.innerHeight;
        const topPassed = (winHeight / 2) - rect.top;
        let percentage = (topPassed / rect.height) * 100;
        percentage = Math.max(0, Math.min(100, percentage));
        progressBar.style.height = `${percentage}%`;
        const nodes = timeline.querySelectorAll('.node-circle');
        nodes.forEach((node) => {
          const nodeTop = node.getBoundingClientRect().top;
          if (nodeTop < winHeight / 2) { node.classList.add('!border-accent', '!bg-accent', '!text-white'); }
          else { node.classList.remove('!border-accent', '!bg-accent', '!text-white'); }
        });
      }
      window.addEventListener('scroll', updateProgress);
      document.addEventListener('astro:page-load', updateProgress);
      updateProgress();
    }
    document.addEventListener('DOMContentLoaded', initTimeline);
    document.addEventListener('astro:page-load', initTimeline);
  </script>

  <!-- ═══ CONSULTOR SEO ═══ -->
  <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
    <div class="max-w-6xl mx-auto reveal">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
        <div class="md:col-span-5 relative group flex justify-center">
          <div class="absolute inset-0 bg-accent/20 rounded-full blur-3xl opacity-30 group-hover:scale-105 transition-transform duration-500"></div>
          <div class="relative w-full max-w-sm">
            <div class="absolute -top-6 -left-6 w-24 h-24 bg-[radial-gradient(#000000_15%,transparent_15%)] bg-[length:12px_12px] opacity-20"></div>
            <div class="overflow-hidden rounded-[2rem] shadow-[0_30px_60px_-15px_rgba(0,0,0,0.1)] border-4 border-white">
              <img src="/img/consultor-seo-en-barcelona.webp" alt="Consultor SEO en Barcelona" class="w-full h-auto object-cover">
            </div>
            <div class="absolute -bottom-4 -right-4 backdrop-blur-md bg-black/90 text-white px-6 py-4 rounded-xl shadow-xl flex items-center gap-3 border border-white/10">
              <div class="w-2 h-2 bg-accent rounded-full animate-pulse"></div>
              <div class="text-[10px] sm:text-xs font-black uppercase tracking-widest">Estrategia SEO</div>
            </div>
          </div>
        </div>
        <div class="md:col-span-7 text-left">
          <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.4em] text-accent mb-4 block">Posicionamiento Orgánico</span>
          <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.85]">
            Consultor de posicionamiento SEO en Barcelona
          </h2>
          <p class="text-zinc-500 font-light text-base sm:text-lg leading-relaxed mb-8">Como consultor experto en SEO en Barcelona, diseño estrategias hipersegmentadas por barrio para que tu empresa aparezca cuando tus clientes te buscan en Google. Conozco la realidad del mercado barcelonés —desde el Eixample comercial y el 22@ tecnológico hasta el Born, Poblenou y Sarrià— y construyo visibilidad orgánica duradera donde está tu cliente ideal.</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="p-6 bg-zinc-50 border border-black/5 rounded-xl hover:bg-zinc-100 transition-colors">
              <div class="text-sm font-black uppercase tracking-wider text-black mb-2">SEO por Barrios</div>
              <p class="text-xs text-zinc-400 font-light">Posicionamiento hiperlocalizado en Barcelona.</p>
            </div>
            <div class="p-6 bg-zinc-50 border border-black/5 rounded-xl hover:bg-zinc-100 transition-colors">
              <div class="text-sm font-black uppercase tracking-wider text-black mb-2">Alta Competencia</div>
              <p class="text-xs text-zinc-400 font-light">Estrategias para destacar en el mercado más exigente.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ RENTABILIDAD + STATS + TESTIMONIOS ═══ -->
  <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16 sm:mb-24 reveal">
        <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
          Rentabilidad de trabajar el SEO en Barcelona
        </h2>
        <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
          Barcelona es el mercado con mayor potencial de tráfico orgánico de Cataluña. Las empresas que invierten en SEO en Barcelona generan un flujo continuo de clientes cualificados sin depender exclusivamente de la publicidad de pago.
        </p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16 reveal text-center">
        <div class="p-8 bg-white rounded-2xl border border-black/5 shadow-sm hover:shadow-xl hover:-translate-y-1 hover:border-accent/10 transition-all duration-300"><div class="text-4xl sm:text-5xl font-black text-accent mb-2 tracking-tighter">+80%</div><div class="text-xs text-zinc-400 font-black tracking-widest uppercase">Tráfico Orgánico</div></div>
        <div class="p-8 bg-white rounded-2xl border border-black/5 shadow-sm hover:shadow-xl hover:-translate-y-1 hover:border-accent/10 transition-all duration-300"><div class="text-4xl sm:text-5xl font-black text-accent mb-2 tracking-tighter">-45%</div><div class="text-xs text-zinc-400 font-black tracking-widest uppercase">Coste por Lead</div></div>
        <div class="p-8 bg-white rounded-2xl border border-black/5 shadow-sm hover:shadow-xl hover:-translate-y-1 hover:border-accent/10 transition-all duration-300"><div class="text-4xl sm:text-5xl font-black text-accent mb-2 tracking-tighter">x4</div><div class="text-xs text-zinc-400 font-black tracking-widest uppercase">ROI a 12 Meses</div></div>
        <div class="p-8 bg-white rounded-2xl border border-black/5 shadow-sm hover:shadow-xl hover:-translate-y-1 hover:border-accent/10 transition-all duration-300"><div class="text-4xl sm:text-5xl font-black text-accent mb-2 tracking-tighter">+70%</div><div class="text-xs text-zinc-400 font-black tracking-widest uppercase">Posiciones Top 3</div></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 reveal">
        <div class="bg-zinc-950 text-white p-10 rounded-2xl border border-zinc-800 flex flex-col justify-between group hover:shadow-2xl hover:border-zinc-700 transition-all">
          <div>
            <div class="flex items-center gap-1 mb-6 text-accent">★★★★★</div>
            <p class="font-light text-lg leading-relaxed mb-8">"Competir en el Eixample era imposible sin SEO. Nova nos posicionó en el top 3 de nuestras palabras clave en 6 meses. Ahora el 60% de nuestros clientes nos encuentran en Google de forma orgánica."</p>
          </div>
          <div>
            <div class="font-black">E-commerce de moda, Eixample de Barcelona</div>
            <div class="text-[10px] text-zinc-500 uppercase tracking-widest mt-1">Sector: E-commerce</div>
          </div>
        </div>
        <div class="bg-white p-10 rounded-2xl border border-zinc-100 shadow-sm hover:shadow-xl hover:border-accent/10 hover:-translate-y-1 transition-all flex flex-col justify-between">
          <div>
            <div class="flex items-center gap-1 mb-6 text-accent">★★★★★</div>
            <p class="font-light text-zinc-600 text-lg leading-relaxed mb-8">"Nuestra startup del 22@ necesitaba visibilidad orgánica sin quemar presupuesto en Ads. Nova construyó una estrategia SEO B2B que nos genera leads cualificados cada semana desde Google."</p>
          </div>
          <div>
            <div class="font-black text-zinc-900">Startup SaaS, Distrito 22@ Barcelona</div>
            <div class="text-[10px] text-zinc-400 uppercase tracking-widest mt-1">Sector: Tecnología B2B</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CASOS DE ÉXITO SEO ═══ -->
  {seoCases.length > 0 && (
  <section class="py-20 sm:py-32 bg-zinc-50 border-t border-black/5 px-4 sm:px-6 overflow-hidden">
