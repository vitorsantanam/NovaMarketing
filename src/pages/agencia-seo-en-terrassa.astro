---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildAlternates } from '../lib/i18n';
import { strapiClient } from '../lib/strapi';
import LogoMarquee from '../components/sections/LogoMarquee.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-seo-en-terrassa', '/ca/agencia-seo-a-terrassa', SITE_URL);

const faqItems = [
  {
    question: "¿Cómo puede el SEO ayudar a mi empresa en Terrassa a conseguir más clientes?",
    answer: "Terrassa tiene un tejido empresarial muy activo, con un sector industrial fuerte y una creciente actividad de servicios. El SEO local en Terrassa te permite aparecer cuando alguien en la ciudad o en el eje Terrassa-Sabadell busca lo que tú ofreces. Es la forma más rentable de captar clientes que ya tienen intención de comprar."
  },
  {
    question: "¿El SEO funciona para empresas industriales del polígon de Terrassa?",
    answer: "Sí. Las empresas del polígon industrial de Terrassa —ya sean fabricantes, distribuidores o servicios técnicos— tienen clientes que buscan proveedores en Google. El SEO B2B para industria en Terrassa posiciona tu empresa para búsquedas profesionales que generan presupuestos y contratos reales, no solo visitas."
  },
  {
    question: "¿Cuánto tiempo tarda el SEO en posicionar en Terrassa?",
    answer: "En Terrassa, con un nivel de competencia moderado en la mayoría de sectores, los primeros resultados suelen verse en 3-5 meses. Sectores como clínicas, inmobiliarias o servicios jurídicos pueden requerir algo más de tiempo. Lo importante es que el SEO genera un crecimiento sostenido y acumulativo."
  },
  {
    question: "¿Trabajáis el SEO local para negocios de Ca n'Anglada y Vallparadís?",
    answer: "Sí. Para negocios en barrios como Ca n'Anglada, Vallparadís o el centre de Terrassa, optimizamos la presencia en Google Maps y creamos contenidos que apuntan a búsquedas locales específicas. El objetivo es que cuando alguien en tu barrio o en Terrassa busque tu servicio, tu negocio sea el primero en aparecer."
  },
  {
    question: "¿El SEO puede ayudar a negocios cercanos a la Universitat Politècnica de Terrassa?",
    answer: "Sin duda. El entorno universitario genera una gran demanda de servicios: alimentación, hostelería, copisterías, tecnología, formación complementaria. Las empresas bien posicionadas en Google captan ese tráfico de forma continua. Diseñamos estrategias que conectan tu negocio con el público universitario y profesional de Terrassa."
  }
];

let seoCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('es');
  seoCases = casesRes.data
    .map((i: any) => i.attributes ?? i)
    .filter((c: any) => {
      const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
      return cats.some((s: string) => s.includes('seo') || s.includes('consultor'));
    });
} catch {}

const steps = [
  { title: "Auditoría SEO en Terrassa", desc: "Analizamos tu presencia digital en Terrassa y detectamos los errores técnicos que frenan tu visibilidad. Estudiamos a tu competencia local y trazamos el camino para superarla en Google." },
  { title: "Keyword Research Local", desc: "Identificamos las búsquedas que realizan los usuarios de Terrassa, Ca n'Anglada, Vallparadís y el eje Terrassa-Sabadell para atraer tráfico con alta intención de compra a tu negocio." },
  { title: "SEO On-Page para tu Sector", desc: "Adaptamos los contenidos y la estructura de tu web para posicionarte en Terrassa. Tanto si eres un negocio de servicios como una empresa industrial, optimizamos para tu cliente real." },
  { title: "Linkbuilding en el Vallès", desc: "Construimos la autoridad de tu dominio con enlaces de calidad desde medios locales del Vallès Occidental, directorios empresariales de Terrassa y webs de referencia de tu sector." },
  { title: "SEO Local y Google Maps", desc: "Posicionamos tu Google Business Profile en Terrassa para que aparezcas en las búsquedas locales con mapa. Esencial para negocios de proximidad, hostelería, clínicas y servicios al cliente." }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Agencia de Posicionamiento SEO para Pymes",
  "provider": {
    "@type": "ProfessionalService",
    "@id": "https://novamarketing.es/#organization",
    "name": "Nova Marketing",
    "image": "https://novamarketing.es/agencia-marketing-pymes-nova-marketing-logo.png",
    "telephone": "+34644738270",
    "priceRange": "€€",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Carrer de Bilbao 1",
      "addressLocality": "Sabadell",
      "addressRegion": "Barcelona",
      "postalCode": "08202",
      "addressCountry": "ES"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "18"
    }
  },
  "areaServed": {
    "@type": "City",
    "name": "Terrassa",
    "sameAs": "https://www.wikidata.org/wiki/Q12285"
  },
  "description": "Expertos en posicionamiento SEO y SEO local para pequeñas y medianas empresas en Terrassa. Estrategias de posicionamiento orgánico para el mercado industrial y de servicios del Vallès Occidental.",
  "offers": { "@type": "Offer", "priceRange": "€€" },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Servicios de Posicionamiento SEO",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Auditoría SEO técnica" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Keyword Research local" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "SEO On-Page y contenidos" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Linkbuilding y autoridad de dominio" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "SEO Local y Google Business Profile" }}
    ]
  }
};
---

<BaseLayout
  title="Agencia SEO en Terrassa | Nova Marketing"
  description="Posicionamos tu empresa en Google para dominar las búsquedas en Terrassa. Desde Ca n'Anglada hasta el polígon industrial. Auditoría SEO gratis."
  locale="es"
  alternates={alternates}
  schemas={[serviceSchema, faqSchema]}
>

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[88vh] flex items-center justify-center pt-24 pb-16 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
    <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
    <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>
    <div class="max-w-7xl mx-auto reveal relative z-10">
      <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-6 shadow-sm">
        <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
        Especialistas en Posicionamiento SEO en Terrassa
      </span>
      <h1 class="text-4xl sm:text-6xl md:text-7xl lg:text-[5.5rem] uppercase font-black tracking-tighter leading-[0.82] mb-8 text-zinc-900 flex flex-col items-center text-center">
        <span>Agencia de</span>
        <span>Posicionamiento SEO</span>
        <span class="text-mktg-gradient px-4 overflow-visible inline-block">en Terrassa</span>
      </h1>
      <p class="text-base sm:text-lg text-zinc-500 font-light leading-relaxed max-w-2xl mx-auto mb-12">
        Posicionamos tu empresa en Google para dominar las búsquedas en Terrassa y el eje Terrassa-Sabadell. Desde el Eix del Parc y la Rambla d'Ègara hasta los polígons industrials de Les Arenes y Ca n'Anglada.
      </p>
      <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
        <button class="contact-modal-trigger btn-mktg-v5 shadow-[0_20px_40px_-10px_rgba(0,0,0,0.15)] hover:shadow-[0_25px_50px_-12px_rgba(0,0,0,0.25)] hover:-translate-y-1 transition-all duration-300 !py-5 !px-12 !text-[12px] !tracking-wider font-black w-full sm:w-auto">
          SOLICITAR AUDITORÍA GRATIS
        </button>
      </div>
    </div>
  </section>

  <!-- ═══ LOGOS CLIENTES ═══ -->
  <LogoMarquee />

  <!-- ═══ AUDITORÍA Y ESTRATEGIA ═══ -->
  <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808005_1px,transparent_1px),linear-gradient(to_bottom,#80808005_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_50%,#000_80%,transparent_100%)]"></div>
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 sm:mb-24 reveal">
        <h2 class="text-3xl sm:text-5xl lg:text-7xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.82]">
          Auditoría y Estrategia <br class="hidden sm:inline" /> SEO en Terrassa
        </h2>
        <p class="text-zinc-500 font-light text-base sm:text-lg leading-relaxed max-w-2xl mx-auto">
          Terrassa concentra un tejido empresarial industrial y de servicios muy potente. Diseñamos estrategias SEO para captar tanto el cliente de proximidad del Eix del Parc como el cliente industrial de los polígons del Vallès.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 items-stretch">
        {[
          { title: "Auditoría Técnica Local", desc: "Detectamos los errores que frenan tu visibilidad en Terrassa: velocidad, indexación y estructura de URLs para que Google priorice tu negocio en las búsquedas locales." },
          { title: "Keywords del Vallès", desc: "Analizamos las búsquedas de los usuarios de Terrassa, Ca n'Anglada, Vallparadís y el eje Terrassa-Sabadell para posicionar términos con alta intención de compra." },
          { title: "SEO On-Page", desc: "Optimizamos contenidos para posicionarte en Terrassa. Desde servicios de proximidad del Eix del Parc hasta empresas industriales de Les Arenes, optimizamos para tu cliente real." },
          { title: "Plan de Enlaces", desc: "Construimos autoridad con enlaces de medios del Vallès Occidental, directorios empresariales de Terrassa y webs de referencia industrial que posicionan tu dominio." }
        ].map((s, i) => (
          <div class="group flex flex-col justify-between p-8 sm:p-10 h-full bg-white rounded-3xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden reveal flex-1">
            <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
            <div class="absolute -bottom-6 -right-4 text-9xl font-black text-black/2 group-hover:text-accent/[0.04] transition-all duration-500 select-none">0{i + 1}</div>
            <div class="relative z-10 flex flex-col h-full justify-between">
              <div>
                <div class="p-3 bg-zinc-50 border border-black/5 w-fit rounded-xl mb-6 group-hover:bg-accent/5 transition-colors">
                  <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                </div>
                <h3 class="text-xl sm:text-2xl uppercase mb-3 tracking-tighter group-hover:text-accent font-black text-zinc-900 border-b border-zinc-100 pb-2 w-fit">{s.title}</h3>
                <p class="text-xs sm:text-sm text-zinc-500 leading-relaxed font-light">{s.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ TIMELINE ═══ -->
  <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16 sm:mb-24 reveal">
        <h2 class="text-2xl sm:text-5xl lg:text-7xl font-black tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.85]">
          Cómo trabajamos el SEO en Terrassa
        </h2>
        <div class="text-zinc-500 w-[75%] mx-auto font-light text-sm sm:text-base leading-relaxed">
          <p>Olvídate del SEO en piloto automático. Contarás con un <strong>Account Manager dedicado</strong> que conoce el tejido empresarial de Terrassa y trabaja de la mano con tu equipo con métricas de negocio reales, no con posiciones vacías.</p>
        </div>
      </div>
      <div id="timeline-container" class="relative timeline-container">
        <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
        <div class="progress-bar hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100" style="height: 0%;"></div>
        <div class="space-y-16 md:space-y-24 flex flex-col items-center">
          {steps.map((step, index) => (
            <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal" style={`transition-delay: ${index * 100}ms`}>
              <div class="hidden md:block md:flex-1 text-right md:order-1">
                {index % 2 === 0 && (
                  <div class="md:pr-12">
                    <h3 class="text-xl sm:text-2xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{step.title}</h3>
                    <p class="text-sm text-zinc-500 font-light max-w-md ml-auto">{step.desc}</p>
                  </div>
                )}
              </div>
              <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all duration-300">0{index + 1}</div>
              <div class="flex-1 text-left md:order-3">
                <div class="md:pl-12">
                  <h3 class:list={["text-xl sm:text-2xl font-black uppercase tracking-tighter mb-2 text-zinc-900", index % 2 === 0 ? "md:hidden" : ""]}>{step.title}</h3>
                  <p class:list={["text-sm text-zinc-500 font-light max-w-md mr-auto", index % 2 === 0 ? "md:hidden" : ""]}>{step.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
  <style>
    .timeline-container .reveal { opacity: 0; transform: translateY(20px); transition: all 0.6s cubic-bezier(0.165, 0.84, 0.44, 1); }
    .timeline-container .reveal.active { opacity: 1; transform: translateY(0); }
  </style>
  <script is:inline>
    function initTimeline() {
      const timeline = document.getElementById('timeline-container');
      const progressBar = timeline?.querySelector('.progress-bar');
      function updateProgress() {
        if (!timeline || !progressBar) return;
        const rect = timeline.getBoundingClientRect();
        const winHeight = window.innerHeight;
        const topPassed = (winHeight / 2) - rect.top;
        let percentage = (topPassed / rect.height) * 100;
        percentage = Math.max(0, Math.min(100, percentage));
        progressBar.style.height = `${percentage}%`;
        const nodes = timeline.querySelectorAll('.node-circle');
        nodes.forEach((node) => {
          const nodeTop = node.getBoundingClientRect().top;
          if (nodeTop < winHeight / 2) { node.classList.add('!border-accent', '!bg-accent', '!text-white'); }
          else { node.classList.remove('!border-accent', '!bg-accent', '!text-white'); }
        });
      }
      window.addEventListener('scroll', updateProgress);
      document.addEventListener('astro:page-load', updateProgress);
      updateProgress();
    }
    document.addEventListener('DOMContentLoaded', initTimeline);
    document.addEventListener('astro:page-load', initTimeline);
  </script>

  <!-- ═══ CONSULTOR SEO ═══ -->
  <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
    <div class="max-w-6xl mx-auto reveal">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
        <div class="md:col-span-5 relative group flex justify-center">
          <div class="absolute inset-0 bg-accent/20 rounded-full blur-3xl opacity-30 group-hover:scale-105 transition-transform duration-500"></div>
          <div class="relative w-full max-w-sm">
            <div class="absolute -top-6 -left-6 w-24 h-24 bg-[radial-gradient(#000000_15%,transparent_15%)] bg-[length:12px_12px] opacity-20"></div>
            <div class="overflow-hidden rounded-[2rem] shadow-[0_30px_60px_-15px_rgba(0,0,0,0.1)] border-4 border-white">
              <img src="/img/consultor-seo-en-terrassa.webp" alt="Consultor SEO en Terrassa" class="w-full h-auto object-cover">
            </div>
            <div class="absolute -bottom-4 -right-4 backdrop-blur-md bg-black/90 text-white px-6 py-4 rounded-xl shadow-xl flex items-center gap-3 border border-white/10">
              <div class="w-2 h-2 bg-accent rounded-full animate-pulse"></div>
              <div class="text-[10px] sm:text-xs font-black uppercase tracking-widest">Estrategia SEO</div>
            </div>
          </div>
        </div>
        <div class="md:col-span-7 text-left">
          <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.4em] text-accent mb-4 block">Posicionamiento Orgánico</span>
          <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.85]">
            Consultor de posicionamiento SEO en Terrassa
          </h2>
          <p class="text-zinc-500 font-light text-base sm:text-lg leading-relaxed mb-8">Como consultor experto en SEO en Terrassa, diseño estrategias de posicionamiento orgánico adaptadas al tejido empresarial local. Conozco el mercado de Terrassa —desde el Eix del Parc y la Rambla d'Ègara hasta los polígons industrials de Les Arenes y Ca n'Anglada— y construyo visibilidad en Google orientada a generar presupuestos y ventas reales.</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="p-6 bg-zinc-50 border border-black/5 rounded-xl hover:bg-zinc-100 transition-colors">
              <div class="text-sm font-black uppercase tracking-wider text-black mb-2">SEO Industrial</div>
              <p class="text-xs text-zinc-400 font-light">B2B y servicios técnicos del Vallès.</p>
            </div>
            <div class="p-6 bg-zinc-50 border border-black/5 rounded-xl hover:bg-zinc-100 transition-colors">
              <div class="text-sm font-black uppercase tracking-wider text-black mb-2">SEO Local</div>
              <p class="text-xs text-zinc-400 font-light">Pack Google Maps y búsquedas de proximidad.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ RENTABILIDAD + STATS + TESTIMONIOS ═══ -->
  <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16 sm:mb-24 reveal">
        <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
          Rentabilidad de trabajar el SEO en Terrassa
        </h2>
        <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
          Terrassa ofrece una oportunidad SEO real: competencia menor que Barcelona, tejido empresarial activo y clientes que buscan proveedores en Google. Las empresas que invierten en posicionamiento orgánico generan leads sostenidos sin depender de publicidad de pago.
        </p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16 reveal text-center">
        <div class="p-8 bg-white rounded-2xl border border-black/5 shadow-sm hover:shadow-xl hover:-translate-y-1 hover:border-accent/10 transition-all duration-300"><div class="text-4xl sm:text-5xl font-black text-accent mb-2 tracking-tighter">+60%</div><div class="text-xs text-zinc-400 font-black tracking-widest uppercase">Tráfico Orgánico</div></div>
        <div class="p-8 bg-white rounded-2xl border border-black/5 shadow-sm hover:shadow-xl hover:-translate-y-1 hover:border-accent/10 transition-all duration-300"><div class="text-4xl sm:text-5xl font-black text-accent mb-2 tracking-tighter">-35%</div><div class="text-xs text-zinc-400 font-black tracking-widest uppercase">Coste por Lead</div></div>
        <div class="p-8 bg-white rounded-2xl border border-black/5 shadow-sm hover:shadow-xl hover:-translate-y-1 hover:border-accent/10 transition-all duration-300"><div class="text-4xl sm:text-5xl font-black text-accent mb-2 tracking-tighter">x3.2</div><div class="text-xs text-zinc-400 font-black tracking-widest uppercase">ROI a 12 Meses</div></div>
        <div class="p-8 bg-white rounded-2xl border border-black/5 shadow-sm hover:shadow-xl hover:-translate-y-1 hover:border-accent/10 transition-all duration-300"><div class="text-4xl sm:text-5xl font-black text-accent mb-2 tracking-tighter">+50%</div><div class="text-xs text-zinc-400 font-black tracking-widest uppercase">Posiciones Top 3</div></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 reveal">
        <div class="bg-zinc-950 text-white p-10 rounded-2xl border border-zinc-800 flex flex-col justify-between group hover:shadow-2xl hover:border-zinc-700 transition-all">
          <div>
            <div class="flex items-center gap-1 mb-6 text-accent">★★★★★</div>
            <p class="font-light text-lg leading-relaxed mb-8">"Teníamos web pero no recibíamos solicitudes desde Google. Nova nos posicionó para búsquedas industriales en Terrassa y en 6 meses empezamos a recibir presupuestos de clientes que nos encontraron solos."</p>
          </div>
          <div>
            <div class="font-black">Empresa industrial, Polígon Les Arenes de Terrassa</div>
            <div class="text-[10px] text-zinc-500 uppercase tracking-widest mt-1">Sector: Industria</div>
          </div>
        </div>
        <div class="bg-white p-10 rounded-2xl border border-zinc-100 shadow-sm hover:shadow-xl hover:border-accent/10 hover:-translate-y-1 transition-all flex flex-col justify-between">
          <div>
            <div class="flex items-center gap-1 mb-6 text-accent">★★★★★</div>
            <p class="font-light text-zinc-600 text-lg leading-relaxed mb-8">"Con el SEO local de Nova aparecemos en el pack de Google Maps en Terrassa. Nuestra tienda del Eix del Parc recibe llamadas directas cada día de clientes que nos buscan en Google."</p>
          </div>
          <div>
            <div class="font-black text-zinc-900">Comercio, Eix del Parc de Terrassa</div>
            <div class="text-[10px] text-zinc-400 uppercase tracking-widest mt-1">Sector: Retail local</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CASOS DE ÉXITO SEO ═══ -->
  {seoCases.length > 0 && (
