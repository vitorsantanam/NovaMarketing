---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/blog/PageHeader.astro';
import SuccessCard from '../../components/blog/SuccessCard.astro';
import CategoryTabs from '../../components/blog/CategoryTabs.astro';
import { strapiClient } from '../../lib/strapi';
import { buildAlternates } from '../../lib/i18n';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/casos-exito', '/ca/casos-exit', SITE_URL);

// Fetch data
let cases = [];
let categoriesWithCases = [];

try {
  const casesRes = await strapiClient.getCaseStudies('es');
  // Solo mostramos los públicos
  cases = casesRes.data
    .map(i => i.attributes ?? i)
    .filter(c => c.isPublic);
  
  const categoriesRes = await strapiClient.getCaseStudyCategories('es');
  const allCategories = categoriesRes.data.map(i => i.attributes ?? i);
  categoriesWithCases = allCategories.filter(cat => !!cat.slug);
} catch (e) {
  console.error("DEBUG: Casos index error:", e);
}
---

<BaseLayout
  title="Casos de éxito | Nova Marketing"
  description="Resultados reales logrados para pequeñas y medianas empresas. Mira cómo hemos ayudado a crecer a nuestros clientes."
  locale="es"
  alternates={alternates}
>
  <PageHeader
    badge="RESULTADOS"
    title="Casos de <span class='text-mktg-gradient'>Éxito</span>"
  />

  <section class="pt-8 pb-16 px-6 sm:px-12 bg-white">
    <div class="max-w-7xl mx-auto">
      
      <CategoryTabs
        categories={categoriesWithCases}
        locale="es"
      />

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 lg:gap-6">
        {cases.map(cs => (
          <div data-item data-cats={((cs.categories as any) ?? []).map((c: any) => c?.attributes?.slug || c?.slug).filter(Boolean).join(' ')}>
            <SuccessCard caseStudy={cs} locale="es" />
          </div>
        ))}
      </div>

      {cases.length === 0 && (
        <div class="text-center py-40 border-2 border-dashed border-zinc-100 rounded-3xl">
          <p class="text-zinc-400 font-light">Todavía no hay casos de éxito en esta sección.</p>
        </div>
      )}
    </div>
  </section>

</BaseLayout>
