---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildAlternates } from '../lib/i18n';
import { strapiClient } from '../lib/strapi';
import LogoMarquee from '../components/sections/LogoMarquee.astro';
import FaqHome from '../components/sections/FaqHome.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/consultoria-marketing-para-pymes', '/consultoria-marketing-per-pimes', SITE_URL);

let pageCases: any[] = [];
try {
  const res = await strapiClient.getCaseStudies('es');
  pageCases = res.data.map((i: any) => i.attributes ?? i).filter((c: any) => {
    const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
    return cats.some((s: string) => s.includes('seo') || s.includes('marketing'));
  });
} catch {}

const faqItems = [
    {
        question: "¿Qué diferencia hay entre contratar a un consultor y simplemente hacer anuncios para mi pyme?",
        answer: "Un consultor es como el arquitecto de tu estrategia. Mientras que un servicio de anuncios se centra en la ejecución, la consultoría para pequeñas empresas analiza el \"porqué\" de las cosas. En Nova te ayudamos a entender dónde está fallando tu proceso de ventas, qué canales son los más rentables para tu pequeña y mediana empresa y cómo optimizar cada euro invertido antes de lanzarte a gastar."
    },
    {
        question: "¿Vais a decirme qué hacer o también lo vais a implementar en mi pequeña empresa?",
        answer: "Esa es la ventaja de trabajar con nosotros. Como consultores para pymes, no solo te entregamos un documento con consejos; te acompañamos en el proceso. Podemos encargarnos de la ejecución técnica o guiar a tu equipo interno para que los cambios se apliquen correctamente en tu pequeña empresa, asegurándonos de que la estrategia no se quede olvidada en un cajón."
    },
    {
        question: "¿Vale la pena invertir en consultoría si mi pequeña y mediana empresa tiene un presupuesto ajustado?",
        answer: "Precisamente por eso es más necesaria. Una pyme no puede permitirse desperdiciar dinero en acciones que no funcionan. La consultoría ayuda a las pequeñas empresas a detectar fugas de presupuesto y a centrar los esfuerzos en lo que realmente trae clientes, logrando que tu inversión sea mucho más inteligente y rentable desde el primer momento."
    },
    {
        question: "¿Cómo se adaptan las sesiones de consultoría al ritmo de trabajo de una pyme?",
        answer: "Sabemos que el día a día de una pequeña y mediana empresa es intenso. Por eso, nuestras sesiones son directas, prácticas y sin rellenos. Nos adaptamos a tu agenda y utilizamos canales ágiles como WhatsApp o videollamadas rápidas para resolver dudas, de modo que la consultoría impulse a tu pequeña empresa en lugar de quitarte tiempo de gestión."
    },
    {
        question: "¿Obtendré una estrategia personalizada para mi pyme o usáis una plantilla estándar?",
        answer: "Cada pequeña empresa es un mundo, y lo que le funciona a una ferretería no le sirve a un centro de estética. En Nova realizamos un diagnóstico profundo de tu pyme, de tu competencia y de tu Keyword ideal para diseñar un plan de acción único. No creemos en soluciones \"café para todos\" para las pequeñas y medianas empresas."
    },
    {
        question: "¿La consultoría es solo para pymes que tienen problemas o también para las que quieren crecer?",
        answer: "La mayoría de las pequeñas empresas que acuden a nosotros ya funcionan bien, pero han tocado un techo de cristal. La consultoría ayuda a estas pymes a profesionalizar sus procesos, usar tecnología avanzada e IA y encontrar nuevas oportunidades de mercado para escalar de forma ordenada y segura."
    }
];

const consultingServiceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Consultoría de Marketing Digital",
  "name": "Consultoría Estratégica de Marketing para Pymes en Cataluña",
  "description": "Servicio de consultoría liderado por Sergio García. Ayudamos a pymes a trazar planes de marketing, análisis de competencia y estrategias de crecimiento en toda Cataluña.",
  "provider": {
    "@type": "ProfessionalService",
    "name": "Nova Marketing",
    "url": "https://novamarketing.es",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Carrer de Bilbao 1",
      "addressLocality": "Sabadell",
      "addressRegion": "Barcelona",
      "postalCode": "08202",
      "addressCountry": "ES"
    }
  },
  "areaServed": [
    {"@type": "Country", "name": "Spain"},
    {"@type": "State", "name": "Cataluña"},
    {"@type": "City", "name": "Barcelona"},
    {"@type": "City", "name": "L'Hospitalet de Llobregat"},
    {"@type": "City", "name": "Terrassa"},
    {"@type": "City", "name": "Sabadell"},
    {"@type": "City", "name": "Badalona"},
    {"@type": "City", "name": "Sant Cugat del Vallès"},
    {"@type": "City", "name": "Lleida"},
    {"@type": "City", "name": "Tarragona"},
    {"@type": "City", "name": "Mataró"},
    {"@type": "City", "name": "Reus"},
    {"@type": "City", "name": "Girona"},
    {"@type": "City", "name": "Cornellà de Llobregat"},
    {"@type": "City", "name": "Sant Boi de Llobregat"},
    {"@type": "City", "name": "Cerdanyola del Vallès"},
    {"@type": "City", "name": "El Prat de Llobregat"},
    {"@type": "City", "name": "Castelldefels"},
    {"@type": "City", "name": "Rubí"},
    {"@type": "City", "name": "Manresa"},
    {"@type": "City", "name": "Vilanova i la Geltrú"},
    {"@type": "City", "name": "Granollers"},
    {"@type": "City", "name": "Viladecans"},
    {"@type": "City", "name": "Santa Coloma de Gramenet"},
    {"@type": "City", "name": "Vic"},
    {"@type": "City", "name": "Figueres"},
    {"@type": "City", "name": "Mollet del Vallès"},
    {"@type": "City", "name": "Gavà"},
    {"@type": "City", "name": "Sant Adrià de Besòs"},
    {"@type": "City", "name": "Esplugues de Llobregat"},
    {"@type": "City", "name": "Olot"},
    {"@type": "City", "name": "Vilafranca del Penedès"}
  ],
  "audience": {
    "@type": "Audience",
    "audienceType": "Gerentes, directivos de pymes y emprendedores"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Servicios de Consultoría",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Auditoría de Marketing 360º"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Definición de Estrategia Digital"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Análisis de Competencia y Mercado"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Mentoring para Departamentos de Marketing"
        }
      }
    ]
  },
  "serviceOutput": "Plan estratégico de marketing, hoja de ruta de acciones (Roadmap) y optimización de presupuestos publicitarios.",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://novamarketing.es/consultoria-marketing-para-pymes/"
  }
};

const steps = [
  { title: "Fase 1: Diagnóstico Completo", desc: "Analizamos tu punto de partida, tu competencia local y tu madurez digital para saber exactamente dónde atacar primero." },
  { title: "Fase 2: Estrategia de Ejecución", desc: "Diseñamos un plan de marketing paso a paso con embudos de venta específicos para captar clientes cualificados continuamente." },
  { title: "Fase 3: Medición y ROI", desc: "Revisamos KPIs periódicamente. No nos basamos en likes, nos basamos en ventas, llamadas y rentabilidad de tu inversión." }
];

const benefits = [
  { title: "Presupuesto Optimizado", desc: "Elimina el gasto en publicidad que no funciona. Enfocamos cada euro donde realmente hay intención de compra." },
  { title: "Plan 100% Personalizado", desc: "Definimos objetivos reales y creamos una hoja de ruta clara para que dejes de improvisar en tu negocio." },
  { title: "Embudos de Venta (Funnels)", desc: "Automatizamos la captación de prospectos para que tu equipo comercial reciba solicitudes de presupuesto en piloto automático." }
];
---

<BaseLayout
  title="Consultoría de Marketing para PYMES | Nova Marketing"
  description="Aportamos una visión estratégica externa sin los costes fijos de un departamento interno con consultorías de marketing orientadas a ventas."
  locale="es"
  alternates={alternates}
  schemas={[consultingServiceSchema]}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="min-h-[88vh] flex items-center justify-center pt-24 pb-16 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-7xl mx-auto reveal relative z-10">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-6 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Especialistas en Estrategia
            </span>

            <h1 class="text-4xl sm:text-6xl md:text-7xl lg:text-[5.5rem] uppercase font-black tracking-tighter leading-[0.82] mb-8 text-zinc-900 flex flex-col items-center text-center">
                <span>Consultor de</span>
                <span>Marketing digital</span>
                <span class="text-mktg-gradient px-4 overflow-visible inline-block">para Pymes</span>
            </h1>

            <p class="text-base sm:text-lg text-zinc-500 font-light leading-relaxed max-w-2xl mx-auto mb-12">
                Aportamos una visión estratégica externa sin los costes fijos de un departamento interno para escalar las ventas de tu pyme con seguridad.
            </p>

            <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
                <button class="contact-modal-trigger btn-mktg-v5 shadow-[0_20px_40px_-10px_rgba(0,0,0,0.15)] hover:shadow-[0_25px_50px_-12px_rgba(0,0,0,0.25)] hover:-translate-y-1 transition-all duration-300 !py-5 !px-12 !text-[12px] !tracking-wider font-black w-full sm:w-auto">
                    RESERVAR CONSULTORÍA
                </button>
            </div>
        </div>
    </section>

    <!-- ═══ LOGOS CLIENTES (SOCIAL PROOF) ══════════════════════════════════ -->
    <LogoMarquee />

    <!-- ═══ SECCIÓN 1: AUDITORÍA Y ESTRATEGIA ═══════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6 relative overflow-hidden">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808005_1px,transparent_1px),linear-gradient(to_bottom,#80808005_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_50%,#000_80%,transparent_100%)]"></div>

        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <h2 class="text-3xl sm:text-5xl lg:text-7xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.82]">
                    Diagnóstico y Estrategia <br class="hidden sm:inline" /> de Marketing para tu Pyme
                </h2>
                <p class="text-zinc-500 font-light text-base sm:text-lg leading-relaxed max-w-2xl mx-auto">
                    No empezamos a ciegas ni usamos plantillas genéricas. Analizamos tu modelo de negocio de arriba a abajo para diseñar una metodología orientada 100% a rentabilidades reales.
                </p>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 items-stretch">
                {[
                    { title: "Análisis de Fugas", desc: "Detectamos dónde se está perdiendo dinero en tu proceso de ventas para tapar grietas antes de escalar." },
                    { title: "Estudio de Mercado", desc: "Analizamos qué busca tu cliente potencial y dónde se encuentra para atacarlo con la oferta ganadora." },
                    { title: "Estrategia Omnicanal", desc: "Definimos los canales más rentables para tu pyme: SEO, SEM, Social Ads o Email Marketing." },
                    { title: "Plan de Roadmap", desc: "Trazamos una hoja de ruta con hitos claros para que sepas qué esperar en cada etapa del crecimiento." }
                ].map((s, i) => (
                    <div class="group flex flex-col justify-between p-8 sm:p-10 h-full bg-white rounded-3xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden reveal flex-1">
                        <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
                        <div class="absolute -bottom-6 -right-4 text-9xl font-black text-black/2 group-hover:text-accent/[0.04] transition-all duration-500 select-none">
                            0{i + 1}
                        </div>
                        <div class="relative z-10 flex flex-col h-full justify-between">
                            <div>
                                <div class="p-3 bg-zinc-50 border border-black/5 w-fit rounded-xl mb-6 group-hover:bg-accent/5 transition-colors">
                                    <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                                </div>
                                <h3 class="text-xl sm:text-2xl uppercase mb-3 tracking-tighter group-hover:text-accent font-black text-zinc-900 border-b border-zinc-100 pb-2 w-fit">{s.title}</h3>
                                <p class="text-xs sm:text-sm text-zinc-500 leading-relaxed font-light">{s.desc}</p>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ═══ SECCIÓN 2: TIMELINE (COMO GOOGLE ADS) ═══════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <h2 class="text-2xl sm:text-5xl lg:text-7xl font-black tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.85]">
                    Cómo trabajamos la Consultoría Estratégica de tu Empresa
                </h2>
                <div class="text-zinc-500 w-[75%] mx-auto font-light text-sm sm:text-base leading-relaxed space-y-4">
                    <p>
                        Olvídate de la Consultoría Estratégica en piloto automático. Contarás con un <strong>Account Manager dedicado</strong> que trabajará de la mano con tu equipo para resolver dudas, supervisar avances y mantenerte informado con métricas de negocio.
                    </p>
                </div>
            </div>

            <div id="timeline-container" class="relative timeline-container">
                <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
                <div class="progress-bar hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100" style="height: 0%;"></div>
                
                <div class="space-y-16 flex flex-col items-center">
                    {steps.map((step, index) => (
                        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal" style={`transition-delay: ${index * 100}ms`}>
                            <div class:list={[
                                "flex-1 w-full",
                                index % 2 === 0 ? "md:order-1 md:text-right" : "md:order-3 md:text-left"
                            ]}>
                                <div class="p-8 sm:p-10 bg-zinc-50 border border-black/5 rounded-3xl hover:border-accent/10 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group">
                                     <h3 class="text-xl sm:text-2xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{index + 1}. {step.title}</h3>
                                     <div class:list={["h-0.5 bg-accent w-full mb-4 opacity-80", index % 2 === 0 ? "md:ml-auto" : ""]}></div>
                                     <p class:list={["text-sm text-zinc-500 font-light max-w-md", index % 2 === 0 ? "md:ml-auto" : ""]}>{step.desc}</p>
                                     <div class="absolute -bottom-6 -right-5 text-8xl font-black text-black/[0.02] select-none z-0 group-hover:scale-105 transition-transform duration-500">0{index+1}</div>
                                </div>
                            </div>
                            <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all duration-300">
                                0{index + 1}
                            </div>
                            <div class:list={[
                                "hidden md:block md:flex-1",
                                index % 2 === 0 ? "md:order-3" : "md:order-1"
                            ]}></div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ CONTACTO FORM ════════════════════════════════════════════════ -->
    <section id="contacto" class="py-20 sm:py-40 px-4 sm:px-6 relative bg-accent">
        <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-12 sm:gap-20 items-center">
            <div class="reveal text-white">
                <span class="text-[10px] font-black uppercase tracking-[0.5em] mb-6 block opacity-70">CRECIMIENTO INMEDIATO</span>
                <h2 class="text-4xl sm:text-5xl lg:text-5xl font-black uppercase tracking-tighter leading-[0.85] mb-8">
                   Contactar con Expertos en Estrategia para Pymes
                </h2>
                <p class="font-light max-w-sm text-base">
                    Solicita tu auditoría de marketing gratis. Revisaremos tu modelo actual y trazaremos un plan para optimizar tu crecimiento.
                </p>
            </div>

            <div class="reveal">
                <div class="bg-white p-8 shadow-[0_40px_100px_rgba(0,0,0,0.1)] rounded-sm">
                    <form class="space-y-6" id="contact-form">
                        <div class="grid grid-cols-1 gap-4 text-[10px] font-black tracking-widest uppercase text-zinc-800">
                            <div class="flex flex-col gap-2">
                                <label class="opacity-40">NOMBRE</label>
                                <input type="text" name="name" aria-label="Nombre" required class="border-b border-zinc-200 py-2 focus:border-accent outline-none font-normal text-sm text-zinc-900">
                            </div>
                        </div>
                        <div class="grid grid-cols-1 gap-4 text-[10px] font-black tracking-widest uppercase text-zinc-800">
                            <div class="flex flex-col gap-2">
                                <label class="opacity-40">EMAIL PROFESIONAL</label>
                                <input type="email" name="email" aria-label="Correo electrónico" required class="border-b border-zinc-200 py-2 focus:border-accent outline-none font-normal text-sm text-zinc-900">
                            </div>
                        </div>
                        <div class="grid grid-cols-1 gap-4 text-[10px] font-black tracking-widest uppercase text-zinc-800">
                            <div class="flex flex-col gap-2">
                                <label class="opacity-40">MENSAJE</label>
                                <textarea name="msg" aria-label="Mensaje" rows="2" class="border-b border-zinc-200 py-2 focus:border-accent outline-none font-normal text-sm text-zinc-900 resize-none"></textarea>
                            </div>
                        </div>
                        <button type="submit" class="w-full btn-mktg-v5 !py-4 shadow-md uppercase">AUDITAR MI ESTRATEGIA</button>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ CASOS DE ÉXITO CONSULTORÍA ═══════════════════════════════════ -->
    {pageCases.length > 0 && (
    <section class="py-20 sm:py-32 bg-zinc-50 border-t border-black/5 px-4 sm:px-6">
        <div class="max-w-7xl mx-auto">
            <div class="mb-16 reveal">
                <span class="text-[10px] font-black uppercase tracking-[0.3em] text-accent mb-4 block">Resultados probados</span>
                <h2 class="text-3xl sm:text-5xl lg:text-6xl uppercase tracking-tighter font-extrabold text-zinc-900 leading-[0.9]">
                    Casos de éxito de consultoría<br class="hidden md:inline" /> de marketing para pymes
                </h2>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                {pageCases.map((cs: any, i: number) => {
                  const catName = (cs.categories || []).map((c: any) => c.name || c.attributes?.name).filter(Boolean).join(' | ');
                  const caseUrl = cs.isPublic && cs.slug ? `/casos-exito/${cs.slug}/` : null;
                  return (
                    <div class="bg-white p-8 border border-black/5 flex flex-col justify-between group hover:shadow-xl hover:-translate-y-1 transition-all duration-300 rounded-2xl reveal" style={`transition-delay: ${i * 80}ms`}>
                      <div>
                        {catName && <span class="text-[10px] font-black uppercase tracking-widest text-accent mb-4 block">{catName}</span>}
                        <h3 class="text-base font-black uppercase tracking-tight text-zinc-900 mb-3 group-hover:text-accent transition-colors leading-tight">{cs.title}</h3>
                        <p class="text-xs text-zinc-500 font-light leading-relaxed">{cs.description}</p>
                      </div>
                      {caseUrl && (
                        <a href={caseUrl} class="mt-6 text-[9px] font-black tracking-[0.25em] text-accent flex items-center gap-1.5 hover:gap-3 transition-all uppercase">
                          VER MÁS <span class="text-sm">→</span>
                        </a>
                      )}
                    </div>
                  );
                })}
            </div>
        </div>
    </section>
    )}

    <!-- ═══ FAQ ════════════════════════════════════════════════════════════ -->
    <FaqHome
        items={faqItems}
        title="Preguntas sobre consultoría <br /> que nos hacen otras pymes"
    />

</BaseLayout>

<script is:inline>
    function initTimeline() {
        const progressBar = document.querySelector('.timeline-container .progress-bar');
        const timeline = document.querySelector('.timeline-container');
        if (!progressBar || !timeline) return;

        function updateProgress() {
            const rect = timeline.getBoundingClientRect();
            const winHeight = window.innerHeight;
            const topPassed = (winHeight / 2) - rect.top;
            let percentage = (topPassed / rect.height) * 100;
            percentage = Math.max(0, Math.min(100, percentage));
            progressBar.style.height = `${percentage}%`;

            const nodes = timeline.querySelectorAll('.node-circle');
            nodes.forEach((node) => {
                const nodeTop = node.getBoundingClientRect().top;
                if (nodeTop < winHeight / 2) {
                    node.classList.add('!border-accent', '!bg-accent', '!text-white');
                } else {
                    node.classList.remove('!border-accent', '!bg-accent', '!text-white');
                }
            });
        }

        window.addEventListener('scroll', updateProgress);
        document.addEventListener('astro:page-load', updateProgress);
        updateProgress();
    }
    document.addEventListener('DOMContentLoaded', initTimeline);
    document.addEventListener('astro:page-load', initTimeline);
</script>
