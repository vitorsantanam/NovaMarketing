---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildAlternates } from '../lib/i18n';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-de-marketing-digital-en-terrassa', '/ca/agencia-de-marketing-digital-a-terrassa', SITE_URL);

const steps = [
  { title: "Diagnóstico Industrial", desc: "Auditamos tu presencia frente al ecosistema de pymes y naves de Terrassa y la comarca." },
  { title: "Plan de Digitalización", desc: "Trazamos la transición de tu negocio tradicional hacia flujos de captación digital rentables." },
  { title: "Optimización B2B/B2C", desc: "Focalizamos los esfuerzos en canales de alta conversión para rentabilizar tu inversión local." }
];

const benefits = [
  { title: "Tradición y Futuro", desc: "Ayudamos a pymes de Terrassa a adaptar su legado industrial a la era de la captación digital." },
  { title: "Dominio de Zona", desc: "Posicionamos tu empresa para ser el referente de servicios o suministros en el Vallès Occidental." },
  { title: "Trasparencia Total", desc: "Métricas exactas de los contactos generados (llamadas, formularios) directo a tu bandeja de entrada." }
];

---

<BaseLayout
  title="Marketing Digital en Terrassa | Nova Marketing"
  description="Impulso digital para pymes en Terrassa. Estrategias de SEO, Google Ads y Diseño Web enfocadas al patrimonio industrial del Vallès Occidental."
  locale="es"
  alternates={alternates}
>

    <!-- ═══ HERO / H1 ═══════════════════════════════════════════════════════ -->
    <section class="pt-24 sm:pt-40 pb-20 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
        <!-- Background Grid Mesh -->
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>

        <!-- Glow Orbs -->
        <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
        <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>

        <div class="max-w-5xl mx-auto reveal">
            <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-8 shadow-sm">
                <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
                Impulso Digital para Pymes
            </span>
            <h1 class="text-3xl sm:text-5xl md:text-7xl lg:text-8xl uppercase font-extrabold tracking-tighter leading-[0.88] mb-8 text-gradient flex flex-col items-center text-center">
                <span class="lg:whitespace-nowrap">Agencia de Marketing</span>
                <span class="lg:whitespace-nowrap">Digital en Terrassa</span>
            </h1>
            <p class="text-lg sm:text-xl text-zinc-500 font-light leading-relaxed w-[75%] mx-auto mb-10">
                Alineamos el legado industrial de Terrassa con estrategias de marketing digital de vanguardia para escalar pymes y autónomos.
            </p>
            <div class="flex justify-center mt-4">
                <a href="#contacto" class="contact-modal-trigger btn-mktg-v5 shadow-[0_10px_30px_rgba(0,0,0,0.1)] !py-4 sm:!py-5 !px-6 sm:!px-10 !text-[11px] !tracking-widest font-black">
                    SOLICITAR PLAN DE ACCIÓN
                </a>
            </div>
        </div>
    </section>

    <!-- ═══ LOGOS CLIENTES (SOCIAL PROOF) ══════════════════════════════════ -->
    <section class="py-12 border-b border-black/5 bg-zinc-50/40 relative overflow-hidden">
        <div class="max-w-7xl mx-auto px-4 sm:px-6">
            <p class="text-[9px] sm:text-[10px] uppercase font-black tracking-widest text-zinc-400 text-center mb-8">Pymes que ya crecen con Nova Marketing</p>
            
            <!-- Contenedor Maratón -->
            <div class="overflow-hidden w-full relative [mask-image:linear-gradient(to_right,transparent,white_10%,white_90%,transparent)]">
                <div id="logos-marquee" class="flex items-center gap-16 w-max animate-scroll-logo">
                    <!-- Cargado por Script: loop infinito aleatorio -->
                </div>
            </div>
        </div>
    </section>

    <style>
        @keyframes scrollMarqueeLogo {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }
        .animate-scroll-logo {
            animation: scrollMarqueeLogo 25s linear infinite;
        }
    </style>

    <script is:inline>
        function initLogoMarquee() {
            const logos = [
                { src: "/clients/Bermaq-cliente-novamarketing.webp", alt: "Bermaq" },
                { src: "/clients/CB-lHospitalet-cliente-novamarketing.webp", alt: "CB l'Hospitalet" },
                { src: "/clients/MedHScliente-novamarketing.webp", alt: "MedHS" },
                { src: "/clients/Palacio-del-bebecliente-novamarketing.webp", alt: "Palacio del bebé" },
                { src: "/clients/Tagtiocliente-novamarketing.webp", alt: "Tagtio" },
                { src: "/clients/Tejados-Tapar-cliente-novamarketing.webp", alt: "Tejados Tapar" },
                { src: "/clients/fastpoint-cliente-novamarketing.webp", alt: "FastPoint" },
                { src: "/clients/mundeta-cliente-novamarketing.webp", alt: "Mundeta" },
                { src: "/clients/tattoox-cliente-novamarketing.webp", alt: "TattooX" },
                { src: "/clients/voltura-projects-cliente-novamarketing.webp", alt: "Voltura Projects" }
            ];

            const shuffledLogos = logos.sort(() => Math.random() - 0.5);
            const fullList = [...shuffledLogos, ...shuffledLogos, ...shuffledLogos, ...shuffledLogos];
            const container = document.getElementById('logos-marquee');
            if (container) {
                container.innerHTML = fullList.map(item => 
                    `<img src="${item.src}" alt="${item.alt}" class="h-[50px] w-auto object-contain filter grayscale opacity-40 hover:grayscale-0 hover:opacity-100 transition-all duration-300 pointer-events-none" />`
                ).join('');
            }
        }
        document.addEventListener('DOMContentLoaded', initLogoMarquee);
        document.addEventListener('astro:page-load', initLogoMarquee);
    </script>

    <!-- ═══ SECCIÓN 1: SERVICIOS ═══════════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6">
        <div class="max-w-7xl mx-auto text-center reveal">
            <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-16 text-zinc-900 leading-[0.9]">
                Servicios de Marketing Online en Terrassa
            </h2>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-left">
                <!-- SEO -->
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
        <!-- Hover Gradient Overlay -->
        <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
                                        <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/agencia-seo-en-terrassa/" class="hover:text-accent transition-colors">Agencia de Posicionamiento SEO en Terrassa</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">
                        Consigue que tu empresa en Terrassa encabece las búsquedas de Google. Optimizamos tu ficha de Google Business Profile y estructura web para desbancar a la competencia en el núcleo urbano y zonas industriales.
                    </p>
                    <a href="#contacto" class="contact-modal-trigger text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÁS →</a>
                </div>

                <!-- Google Ads -->
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
        <!-- Hover Gradient Overlay -->
        <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
                                        <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/agencia-google-ads-terrassa/" class="hover:text-accent transition-colors">Agencia de Google Ads en Terrassa</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">
                        Anuncios hiperrentables para captar clientes en minutos. Diseñamos campañas de búsqueda segmentadas en Terrassa para autónomos y pymes que necesitan llamadas cualificadas de inmediato.
                    </p>
                    <a href="#contacto" class="contact-modal-trigger text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÁS →</a>
                </div>

                <!-- Diseño Web -->
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
        <!-- Hover Gradient Overlay -->
        <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
                                        <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/agencia-diseno-web-terrassa/" class="hover:text-accent transition-colors">Agencia de Diseño Web en Terrassa</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">
                        Diseñamos la oficina digital que tu marca merece en Terrassa. Páginas web ultra rápidas, optimizadas para móvil y programadas específicamente para convertir cada visita en un formulario de presupuesto.
                    </p>
                    <a href="#contacto" class="contact-modal-trigger text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÁS →</a>
                </div>

                <!-- Consultoría -->
                <div class="service-card p-8 bg-white rounded-2xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden flex flex-col justify-between">
        <!-- Hover Gradient Overlay -->
        <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
                                        <h3 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">
                        <a href="/consultoria-marketing-digital-terrassa/" class="hover:text-accent transition-colors">Consultoría de Marketing en Terrassa</a>
                    </h3>
                    <p class="text-sm text-zinc-500 font-light leading-relaxed mb-4">
                        ¿Inversiones en marketing sin resultados? Auditamos tu empresa y naves en Terrassa para optimizar el embudo de ventas, definir canales idóneos y potenciar tu plan de marketing sin fugas.
                    </p>
                    <a href="#contacto" class="contact-modal-trigger text-[11px] font-black tracking-widest text-accent hover:underline">SABER MÁS →</a>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ SECCIÓN 2: COMO TRABAJAMOS -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
                    Estrategias de Crecimiento para Pymes en Terrassa
                </h2>
                <p class="text-zinc-500 w-[75%] mx-auto font-light text-sm sm:text-base leading-relaxed">
                    Estructuramos tu expansión digital combinando herencia empresarial y flujos de atracción de clientes modernos.
                </p>
            </div>

            <div id="timeline-container" class="relative">
                <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
                <div id="progress-bar" class="hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100" style="height: 0%;"></div>
                
                <div class="space-y-16 md:space-y-24 flex flex-col items-center">
                    {steps.map((step, index) => (
                        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal">
                            <div class="hidden md:block md:flex-1 text-right md:order-1">
                                {index % 2 === 0 && (
                                    <div class="md:pr-12">
                                        <h4 class="text-xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{step.title}</h4>
                                        <p class="text-sm text-zinc-500 font-light max-w-md ml-auto">{step.desc}</p>
                                    </div>
                                )}
                            </div>
                            <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all">
                                0{index + 1}
                            </div>
                            <div class="flex-1 text-left md:order-3">
                                <div class="md:pl-12">
                                    <h4 class:list={["text-xl font-black uppercase tracking-tighter mb-2 text-zinc-900", index % 2 === 0 ? "md:hidden" : ""]}>{step.title}</h4>
                                    <p class:list={["text-sm text-zinc-500 font-light max-w-md mr-auto", index % 2 === 0 ? "md:hidden" : ""]}>{step.desc}</p>
                                </div>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ SECCIÓN 3: BENEFICIOS ══════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-zinc-50/50 px-4 sm:px-6 relative overflow-hidden border-t border-black/5">
        <!-- Deco meshes -->
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808005_1px,transparent_1px),linear-gradient(to_bottom,#80808005_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_50%,#000_80%,transparent_100%)]"></div>
        <div class="absolute -top-40 right-1/4 w-96 h-96 bg-accent/10 rounded-full blur-3xl opacity-20 animate-pulse"></div>
        <div class="absolute -bottom-40 left-1/4 w-96 h-96 bg-purple-500/10 rounded-full blur-3xl opacity-10"></div>
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-16 sm:mb-24 reveal">
                <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-4 text-zinc-900 leading-[0.9]">
                    Especialistas en Marketing Digital en Terrassa
                </h2>
                <p class="text-zinc-500 w-[75%] mx-auto font-light text-sm sm:text-base">Dominamos el tejido de proximidad para asegurar que tu PIME destaque.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                {benefits.map((benefit) => (
                    <div class="group p-8 border border-black/5 bg-white rounded-sm hover:border-black/20 hover:shadow-[0_20px_50px_rgba(0,0,0,0.03)] transition-all duration-500 reveal">
                        <div class="h-1 bg-black w-12 group-hover:w-full transition-all duration-500 mb-6"></div>
                        <h4 class="text-xl font-black uppercase tracking-tighter mb-4 text-zinc-900">{benefit.title}</h4>
                        <p class="text-sm text-zinc-500 font-light leading-relaxed">{benefit.desc}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ═══ SECCIÓN 4: CASOS ══════════════════════════════════════ -->
    <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
        <div class="max-w-7xl mx-auto">
            <div class="mb-16 sm:mb-24 reveal text-center md:text-left">
                <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.3em] text-accent mb-4 block">Resultados Locales</span>
                <h2 class="text-3xl sm:text-5xl lg:text-7xl uppercase tracking-tighter font-extrabold mb-2 text-zinc-900 leading-[0.9]">
                    Proyectos y Casos de Éxito en Terrassa
                </h2>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 reveal">
                <div class="bg-zinc-50 p-8 border border-black/5 flex flex-col justify-between h-full group hover:shadow-[0_20px_60px_rgba(0,0,0,0.05)] transition-all">
                    <div>
                        <span class="text-[10px] font-black uppercase tracking-widest text-accent mb-4 block">SEO Local</span>
                        <h4 class="text-xl font-black uppercase tracking-tighter mb-4 group-hover:text-accent transition-colors">Taller Reparación</h4>
                        <p class="text-xs text-zinc-500 font-light leading-relaxed mb-6">Posicionado al mapa de Google atrayendo clientes diarios del núcleo de Terrassa.</p>
                    </div>
                    <div class="text-2xl font-black tracking-tighter text-black mt-4">Top 3 Google</div>
                </div>

                <div class="bg-zinc-50 p-8 border border-black/5 flex flex-col justify-between h-full group hover:shadow-[0_20px_60px_rgba(0,0,0,0.05)] transition-all">
                    <div>
                        <span class="text-[10px] font-black uppercase tracking-widest text-accent mb-4 block">Google Ads</span>
                        <h4 class="text-xl font-black uppercase tracking-tighter mb-4 group-hover:text-accent transition-colors">Suministros Industriales</h4>
                        <p class="text-xs text-zinc-500 font-light leading-relaxed mb-6">Puesta a punto de campañas bajando el coste de adquisición un 35% mensual.</p>
                    </div>
                    <div class="text-2xl font-black tracking-tighter text-black mt-4">-35% CPA</div>
                </div>

                <div class="bg-zinc-50 p-8 border border-black/5 flex flex-col justify-between h-full group hover:shadow-[0_20px_60px_rgba(0,0,0,0.05)] transition-all">
                    <div>
                        <span class="text-[10px] font-black uppercase tracking-widest text-accent mb-4 block">Diseño Web</span>
                        <h4 class="text-xl font-black uppercase tracking-tighter mb-4 group-hover:text-accent transition-colors">Gabinete Jurídico</h4>
                        <p class="text-xs text-zinc-500 font-light leading-relaxed mb-6">Rediseño enfocado a presupuesto con subida del 50% en contactos de valor.</p>
                    </div>
                    <div class="text-2xl font-black tracking-tighter text-black mt-4">+50% Leads</div>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ CONTACTO ════════════════════════════════════════════ -->
    <section id="contacto" class="py-20 sm:py-40 px-4 sm:px-6 relative bg-accent">
        <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-12 sm:gap-20 items-center">
            <div class="reveal text-white">
                <span class="text-[10px] font-black uppercase tracking-[0.5em] mb-6 block opacity-70">CRECIMIENTO GARANTIZADO</span>
                <h2 class="text-5xl sm:text-7xl font-black uppercase tracking-tighter leading-[0.8] mb-8">
                   IMPULSA <br>TU NEGOCIO <br>EN TERRASSA
                </h2>
                <p class="font-light max-w-md text-base sm:text-xl">Consúltame y te daré una hoja de ruta tradicional o industrial para tu empresa en Terrassa.</p>
            </div>

            <div class="reveal">
                <div class="bg-white p-8 sm:p-16 shadow-[0_40px_100px_rgba(0,0,0,0.1)] rounded-sm">
                    <form class="space-y-8" id="contact-form">
                        <div class="grid sm:grid-cols-2 gap-6 text-[10px] font-black tracking-widest uppercase">
                            <div class="flex flex-col gap-3">
                                <label class="opacity-30">NOMBRE</label>
                                <input type="text" name="name" aria-label="Nombre" required class="border-b border-black/10 py-2 focus:border-accent outline-none">
                            </div>
                            <div class="flex flex-col gap-3">
                                <label class="opacity-30">TELÉFONO</label>
                                <input type="tel" name="phone" class="border-b border-black/10 py-2 focus:border-accent outline-none">
                            </div>
                        </div>
                        <div class="flex flex-col gap-3 text-[10px] font-black tracking-widest uppercase">
                            <label class="opacity-30">EMAIL PROFESIONAL</label>
                            <input type="email" name="email" aria-label="Correo electrónico" required class="border-b border-black/10 py-2 focus:border-accent outline-none">
                        </div>
                        <div class="flex flex-col gap-3 text-[10px] font-black tracking-widest uppercase">
                            <label class="opacity-30">CONSULTA</label>
                            <textarea name="msg" aria-label="Mensaje" rows="3" class="border-b border-black/10 py-2 focus:border-accent outline-none resize-none" placeholder="¿Cuál es tu objetivo comercial en Terrassa?"></textarea>
                        </div>
                        <button type="submit" class="w-full btn-mktg-v5 !py-6">DESPEGAR MI PROYECTO</button>
                    </form>
                </div>
            </div>
        </div>
    </section>

</BaseLayout>

<script>
    document.getElementById('contact-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const form = e.target;
        const btn = form.querySelector('button');
        if (btn) { btn.innerHTML = 'ENVIANDO...'; btn.disabled = true; }
        const data = Object.fromEntries(new FormData(form));
        try {
            const res = await fetch('https://cms.novamarketing.es/api/contact', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data),
            });
            if (res.ok) {
                window.location.href =  + redirect + ;
            } else { throw new Error(); }
        } catch {
            if (btn) { btn.innerHTML =  + error_msg + ; btn.disabled = false; btn.style.background = '#ef4444'; }
        }
    });
function initTimeline() {
        const progressBar = document.getElementById('progress-bar');
        const timeline = document.getElementById('timeline-container');
        if (!progressBar || !timeline) return;

        function updateProgress() {
            const rect = timeline.getBoundingClientRect();
            const winHeight = window.innerHeight;
            const topPassed = (winHeight / 2) - rect.top;
            let percentage = (topPassed / rect.height) * 100;
            percentage = Math.max(0, Math.min(100, percentage));
            progressBar.style.height = `${percentage}%`;

            const nodes = timeline.querySelectorAll('.node-circle');
            nodes.forEach((node) => {
                const nodeTop = node.getBoundingClientRect().top;
                if (nodeTop < winHeight / 2) {
                    node.classList.add('!border-accent', '!bg-accent', '!text-white');
                } else {
                    node.classList.remove('!border-accent', '!bg-accent', '!text-white');
                }
            });
        }

        window.addEventListener('scroll', updateProgress);
        document.addEventListener('astro:page-load', updateProgress);
        updateProgress();
    }
    document.addEventListener('DOMContentLoaded', initTimeline);
    document.addEventListener('astro:page-load', initTimeline);
</script>
