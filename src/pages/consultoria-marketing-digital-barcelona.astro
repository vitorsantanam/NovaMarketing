---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildAlternates } from '../lib/i18n';
import { strapiClient } from '../lib/strapi';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/consultoria-marketing-digital-barcelona/', '/ca/consultoria-marketing-digital-barcelona/', SITE_URL);

const faqItems = [
  { question: `¿Qué es una consultoría de marketing digital en Barcelona?`, answer: `Una consultoría de marketing digital en Barcelona analiza tu situación actual, identifica las oportunidades del mercado barcelonés y diseña una estrategia para aumentar tus ventas. Abarca desde SEO y Google Ads hasta branding, contenidos y analítica web adaptados a la competitiva realidad de Barcelona.` },
  { question: `¿Cuánto cuesta la consultoría de marketing en Barcelona?`, answer: `El coste varía según el alcance. Ofrecemos una auditoría inicial gratuita para empresas de Barcelona. Trabajamos con presupuestos adaptados tanto a pymes del Eixample o Poblenou como a startups del 22@ que necesitan escalar rápido.` },
  { question: `¿En cuánto tiempo se ven los resultados en Barcelona?`, answer: `En Barcelona la competencia es alta, así que los plazos son realistas: Google Ads da resultados inmediatos, SEO entre 4 y 8 meses, y estrategias de branding o contenidos entre 6 y 12 meses. Todo se mide y se justifica con datos.` },
  { question: `¿Os especializáis en pymes y startups del Eixample, Poblenou y 22@ de Barcelona?`, answer: `Sí. Conocemos la dinámica de los distintos barrios de Barcelona: el perfil del cliente del Eixample es diferente al del 22@ o al de Gràcia. Diseñamos estrategias adaptadas a cada zona y sector dentro de Barcelona.` },
  { question: `¿Puedo contratar solo la auditoría sin compromiso en Barcelona?`, answer: `Sí. La auditoría inicial gratuita no tiene ningún compromiso. Analizamos tu web, tu visibilidad en Google, tu competencia en Barcelona y tu estrategia actual. El informe es tuyo independientemente de si contratas nuestros servicios.` },
  { question: `¿La consultoría de marketing en Barcelona incluye estrategia SEO local?`, answer: `Sí. El SEO local en Barcelona es fundamental para captar clientes en barrios concretos. La consultoría puede incluir una estrategia SEO local orientada a tu zona —Eixample, Poblenou, Gràcia, Zona Alta— y a tu perfil de cliente en Barcelona.` },
  { question: `¿Tenéis oficina en Barcelona?`, answer: `Sí, operamos desde el Calle General Mendoza 10 en Barcelona. Podemos reunirnos en persona, hacemos seguimiento presencial y conocemos el mercado local de primera mano.` },
  { question: `¿Por qué elegir Nova Marketing frente a otras consultoras de marketing en Barcelona?`, answer: `En Barcelona hay muchas agencias y consultoras, pero pocas con un enfoque tan orientado a resultados y ROI para pymes. Partimos de datos reales, proponemos acciones concretas con KPIs definidos y medimos cada euro invertido. Sin promesas vacías ni contratos de largo plazo sin resultados.` }
];

let consulCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('es');
  consulCases = casesRes.data
    .map((i: any) => i.attributes ?? i)
    .filter((c: any) => {
      const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
      return cats.some((s: string) => s.includes('consul') || s.includes('marketing'));
    });
} catch {}

const faqSchema = {"@context":"https://schema.org","@type":"FAQPage","mainEntity":[
    {"@type":"Question","name":"¿Qué es una consultoría de marketing digital en Barcelona?","acceptedAnswer":{"@type":"Answer","text":"Una consultoría de marketing digital en Barcelona analiza tu situación actual, identifica las oportunidades del mercado barcelonés y diseña una estrategia para aumentar tus ventas. Abarca desde SEO y Google Ads hasta branding, contenidos y analítica web adaptados a la competitiva realidad de Barcelona."}},
    {"@type":"Question","name":"¿Cuánto cuesta la consultoría de marketing en Barcelona?","acceptedAnswer":{"@type":"Answer","text":"El coste varía según el alcance. Ofrecemos una auditoría inicial gratuita para empresas de Barcelona. Trabajamos con presupuestos adaptados tanto a pymes del Eixample o Poblenou como a startups del 22@ que necesitan escalar rápido."}},
    {"@type":"Question","name":"¿En cuánto tiempo se ven los resultados en Barcelona?","acceptedAnswer":{"@type":"Answer","text":"En Barcelona la competencia es alta, así que los plazos son realistas: Google Ads da resultados inmediatos, SEO entre 4 y 8 meses, y estrategias de branding o contenidos entre 6 y 12 meses. Todo se mide y se justifica con datos."}},
    {"@type":"Question","name":"¿Os especializáis en pymes y startups del Eixample, Poblenou y 22@ de Barcelona?","acceptedAnswer":{"@type":"Answer","text":"Sí. Conocemos la dinámica de los distintos barrios de Barcelona: el perfil del cliente del Eixample es diferente al del 22@ o al de Gràcia. Diseñamos estrategias adaptadas a cada zona y sector dentro de Barcelona."}},
    {"@type":"Question","name":"¿Puedo contratar solo la auditoría sin compromiso en Barcelona?","acceptedAnswer":{"@type":"Answer","text":"Sí. La auditoría inicial gratuita no tiene ningún compromiso. Analizamos tu web, tu visibilidad en Google, tu competencia en Barcelona y tu estrategia actual. El informe es tuyo independientemente de si contratas nuestros servicios."}},
    {"@type":"Question","name":"¿La consultoría de marketing en Barcelona incluye estrategia SEO local?","acceptedAnswer":{"@type":"Answer","text":"Sí. El SEO local en Barcelona es fundamental para captar clientes en barrios concretos. La consultoría puede incluir una estrategia SEO local orientada a tu zona —Eixample, Poblenou, Gràcia, Zona Alta— y a tu perfil de cliente en Barcelona."}},
    {"@type":"Question","name":"¿Tenéis oficina en Barcelona?","acceptedAnswer":{"@type":"Answer","text":"Sí, operamos desde el Calle General Mendoza 10 en Barcelona. Podemos reunirnos en persona, hacemos seguimiento presencial y conocemos el mercado local de primera mano."}},
    {"@type":"Question","name":"¿Por qué elegir Nova Marketing frente a otras consultoras de marketing en Barcelona?","acceptedAnswer":{"@type":"Answer","text":"En Barcelona hay muchas agencias y consultoras, pero pocas con un enfoque tan orientado a resultados y ROI para pymes. Partimos de datos reales, proponemos acciones concretas con KPIs definidos y medimos cada euro invertido. Sin promesas vacías ni contratos de largo plazo sin resultados."}}
  ]};

const serviceSchema = {"@context":"https://schema.org","@type":"Service","serviceType":"Consultor de Marketing Digital para Pymes","provider":{"@type":"ProfessionalService","@id":"https://novamarketing.es/#organization","name":"Nova Marketing","image":"https://novamarketing.es/agencia-marketing-pymes-nova-marketing-logo.png","telephone":"+34644738270","priceRange":"€€","address":{"@type":"PostalAddress","streetAddress":"Calle General Mendoza 10","addressLocality":"Barcelona","addressRegion":"Barcelona","postalCode":"08035","addressCountry":"ES"},"aggregateRating":{"@type":"AggregateRating","ratingValue":"4.9","reviewCount":"35"}},"areaServed":{"@type":"City","name":"Barcelona","sameAs":"https://www.wikidata.org/wiki/Q1492"},"description":"Consultoría de marketing digital a medida para pymes de Barcelona. Estrategias de crecimiento para empresas del Eixample, 22@, Poblenou, Gràcia y toda Barcelona.","offers":{"@type":"Offer","priceRange":"€€"},"hasOfferCatalog":{"@type":"OfferCatalog","name":"Servicios de Consultoría de Marketing Digital","itemListElement":[{"@type":"Offer","itemOffered":{"@type":"Service","name":"Auditoría 360 de Marketing Digital"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Plan Estratégico de Marketing"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Consultoría de Competencia Digital"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Asesoría en Transformación Digital"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Análisis de Datos y Dashboarding"}}]}};
---

<BaseLayout
  title="Consultor de Marketing Digital en Barcelona | Nova Marketing"
  description="Estrategias de marketing digital a medida para pymes de Barcelona. Auditoría gratis. Especialistas en el mercado barcelonés: Eixample, 22@, Gràcia, Poblenou y Zona Alta."
  locale="es"
  alternates={alternates}
  schemas={[serviceSchema, faqSchema]}
>

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[88vh] flex items-center justify-center pt-24 pb-16 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
    <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
    <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>
    <div class="max-w-7xl mx-auto reveal relative z-10">
      <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-6 shadow-sm">
        <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
        Especialistas en Estrategia Digital
      </span>
      <h1 class="text-3xl sm:text-5xl md:text-6xl lg:text-[4.2rem] xl:text-[4.8rem] uppercase font-black tracking-tighter leading-[0.95] sm:leading-[0.9] mb-8 text-zinc-900 w-full text-center max-w-[85rem] mx-auto opacity-0 translate-y-4 animate-[fade-in-up_0.8s_ease-out_forwards]">
        <span class="block lg:inline">Consultor de Marketing</span>
                <span class="block lg:inline">Digital en</span>
                <span class="text-mktg-gradient inline-block px-1">Barcelona</span>
      </h1>
      <p class="text-base sm:text-lg text-zinc-500 font-light leading-relaxed max-w-2xl mx-auto mb-12">
        Estrategias de marketing a medida para escalar las ventas de tu pyme en Barcelona. Impulsamos empresas del Eixample, Poblenou, Gràcia y el 22@ con visión estratégica real y sin humo.
      </p>
      <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
        <button class="contact-modal-trigger btn-mktg-v5 shadow-[0_20px_40px_-10px_rgba(0,0,0,0.15)] hover:shadow-[0_25px_50px_-12px_rgba(0,0,0,0.25)] hover:-translate-y-1 transition-all duration-300 !py-5 !px-12 !text-[12px] !tracking-wider font-black w-full sm:w-auto">
          SOLICITAR AUDITORÍA GRATIS
        </button>
      </div>
    </div>
  </section>
  <style>
    @keyframes fade-in-up {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>

  <!-- ═══ LOGOS CLIENTES ═══ -->
  <section class="py-12 border-b border-black/5 bg-zinc-50/40 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="text-[9px] sm:text-[10px] uppercase font-black tracking-widest text-zinc-400 text-center mb-8">PYMES QUE YA CRECEN CON SU CONSULTOR EN NOVA</p>
      <div class="overflow-hidden w-full relative [mask-image:linear-gradient(to_right,transparent,white_10%,white_90%,transparent)]">
        <div id="logos-consult-bcn" class="flex items-center gap-16 w-max animate-scrollConsultBCN"></div>
      </div>
    </div>
  </section>
  <style>
    @keyframes scrollConsultBCN {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .animate-scrollConsultBCN {
      animation: scrollConsultBCN 60s linear infinite;
    }
  </style>
  <script is:inline>
    (function() {
      var logos = [
        { src: "/clients/bermaq-cliente-novamarketing.webp", alt: "Bermaq" },
        { src: "/clients/cb-lhospitalet-cliente-novamarketing.webp", alt: "CB l'Hospitalet" },
        { src: "/clients/medhs-cliente-novamarketing.webp", alt: "MedHS" },
        { src: "/clients/palacio-del-bebe-cliente-novamarketing.webp", alt: "Palacio del bebé" },
        { src: "/clients/tagtio-cliente-novamarketing.webp", alt: "Tagtio" },
        { src: "/clients/tejados-tapar-cliente-novamarketing.webp", alt: "Tejados Tapar" },
        { src: "/clients/fastpoint-cliente-novamarketing.webp", alt: "FastPoint" },
        { src: "/clients/mundeta-cliente-novamarketing.webp", alt: "Mundeta" },
        { src: "/clients/tattoox-cliente-novamarketing.webp", alt: "TattooX" },
        { src: "/clients/voltura-projects-cliente-novamarketing.webp", alt: "Voltura Projects" }
      ];
      function initMarquee() {
        var shuffled = logos.sort(function() { return Math.random() - 0.5; });
        var full = shuffled.concat(shuffled);
        var el = document.getElementById('logos-consult-bcn');
        if (el) {
          el.innerHTML = full.map(function(l) {
            return '<img src="' + l.src + '" alt="' + l.alt + '" class="h-[50px] w-auto object-contain filter grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-300 pointer-events-none" style="mix-blend-mode:multiply" />';
          }).join('');
        }
      }
      document.addEventListener('DOMContentLoaded', initMarquee);
      document.addEventListener('astro:page-load', initMarquee);
      initMarquee();
    })();
  </script>

  <!-- ═══ CONSULTOR ═══ -->
  <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
    <div class="max-w-6xl mx-auto reveal">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
        <div class="md:col-span-5 relative group flex justify-center">
          <div class="absolute inset-0 bg-accent/20 rounded-full blur-3xl opacity-30 group-hover:scale-105 transition-transform duration-500"></div>
          <div class="relative w-full max-w-sm">
            <div class="absolute -top-6 -left-6 w-24 h-24 bg-[radial-gradient(#000000_15%,transparent_15%)] bg-[length:12px_12px] opacity-20"></div>
            <div class="overflow-hidden rounded-[2rem] shadow-[0_30px_60px_-15px_rgba(0,0,0,0.1)] border-4 border-white">
              <img src="/img/consultor_marketing.webp" alt="Sergio García será tu consultor de marketing en Barcelona" class="w-full h-auto object-cover">
            </div>
            <div class="absolute -bottom-4 -right-4 backdrop-blur-md bg-black/90 text-white px-6 py-4 rounded-xl shadow-xl flex items-center gap-3 border border-white/10">
              <div class="w-2 h-2 bg-accent rounded-full animate-pulse"></div>
              <div class="text-[10px] sm:text-xs font-black uppercase tracking-widest">Consultoría de Marketing</div>
            </div>
          </div>
        </div>
        <div class="md:col-span-7 text-left">
          <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.4em] text-accent mb-4 block">Consultoría de Marketing</span>
          <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.85]">
            Sergio García será tu consultor de marketing en Barcelona
          </h2>
          <p class="text-zinc-500 font-light text-base sm:text-lg leading-relaxed mb-8">Barcelona es el mercado más competitivo de Cataluña. El Eixample, el 22@, Poblenou y la Zona Alta concentran miles de pymes que compiten por los mismos clientes. Aquí no hay atajos: diseñamos estrategias de marketing basadas en datos reales del mercado barcelonés para que tu empresa destaque donde importa.</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="p-6 bg-zinc-50 border border-black/5 rounded-xl hover:bg-zinc-100 transition-colors">
              <div class="text-sm font-black uppercase tracking-wider text-black mb-2">Mercado Competitivo</div>
              <p class="text-xs text-zinc-400 font-light">Estrategia para destacar en Barcelona.</p>
            </div>
            <div class="p-6 bg-zinc-50 border border-black/5 rounded-xl hover:bg-zinc-100 transition-colors">
              <div class="text-sm font-black uppercase tracking-wider text-black mb-2">Datos y Resultados</div>
              <p class="text-xs text-zinc-400 font-light">ROI medido, no promesas vacías.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FEATURE CARDS ═══ -->
  <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808005_1px,transparent_1px),linear-gradient(to_bottom,#80808005_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_50%,#000_80%,transparent_100%)]"></div>
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 sm:mb-24 reveal">
        <h2 class="text-3xl sm:text-5xl lg:text-7xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.82]">
          Consultoría de Marketing integral para pymes de Barcelona
        </h2>
        <p class="text-zinc-500 font-light text-base sm:text-lg leading-relaxed max-w-2xl mx-auto">
          En el mercado de Barcelona no basta con estar presente. Diseñamos estrategias de marketing para que tu empresa del Eixample, Poblenou o el 22@ destaque frente a la competencia y convierta visibilidad en ventas.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 items-stretch">
          <div class="group flex flex-col justify-between p-8 sm:p-10 h-full bg-white rounded-3xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden reveal flex-1">
            <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
            <div class="absolute -bottom-6 -right-4 text-9xl font-black text-black/2 group-hover:text-accent/[0.04] transition-all duration-500 select-none">01</div>
            <div class="relative z-10 flex flex-col h-full justify-between">
              <div>
                <div class="p-3 bg-zinc-50 border border-black/5 w-fit rounded-xl mb-6 group-hover:bg-accent/5 transition-colors">
                  <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
                </div>
                <h3 class="text-xl sm:text-2xl uppercase mb-3 tracking-tighter group-hover:text-accent font-black text-zinc-900 border-b border-zinc-100 pb-2 w-fit">Auditoría Estratégica</h3>
                <p class="text-xs sm:text-sm text-zinc-500 leading-relaxed font-light">Analizamos tu presencia digital, tu posición frente a competidores en Barcelona y las oportunidades en los mercados del Eixample, Poblenou, 22@ y Zona Alta.</p>
              </div>
            </div>
          </div>
          <div class="group flex flex-col justify-between p-8 sm:p-10 h-full bg-white rounded-3xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden reveal flex-1">
            <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
            <div class="absolute -bottom-6 -right-4 text-9xl font-black text-black/2 group-hover:text-accent/[0.04] transition-all duration-500 select-none">02</div>
            <div class="relative z-10 flex flex-col h-full justify-between">
              <div>
                <div class="p-3 bg-zinc-50 border border-black/5 w-fit rounded-xl mb-6 group-hover:bg-accent/5 transition-colors">
                  <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <h3 class="text-xl sm:text-2xl uppercase mb-3 tracking-tighter group-hover:text-accent font-black text-zinc-900 border-b border-zinc-100 pb-2 w-fit">Plan de Negocio</h3>
                <p class="text-xs sm:text-sm text-zinc-500 leading-relaxed font-light">Identificamos las palancas más rentables para tu pyme barcelonesa: canales, mensajes diferenciadores y presupuesto optimizado para el exigente mercado de Barcelona.</p>
              </div>
            </div>
          </div>
          <div class="group flex flex-col justify-between p-8 sm:p-10 h-full bg-white rounded-3xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden reveal flex-1">
            <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
            <div class="absolute -bottom-6 -right-4 text-9xl font-black text-black/2 group-hover:text-accent/[0.04] transition-all duration-500 select-none">03</div>
            <div class="relative z-10 flex flex-col h-full justify-between">
              <div>
                <div class="p-3 bg-zinc-50 border border-black/5 w-fit rounded-xl mb-6 group-hover:bg-accent/5 transition-colors">
                  <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                </div>
                <h3 class="text-xl sm:text-2xl uppercase mb-3 tracking-tighter group-hover:text-accent font-black text-zinc-900 border-b border-zinc-100 pb-2 w-fit">Implementación</h3>
                <p class="text-xs sm:text-sm text-zinc-500 leading-relaxed font-light">Ejecutamos la estrategia junto a tu equipo para que tu empresa de Barcelona —sea del Eixample, Gràcia o el 22@— consiga clientes de forma recurrente y escalable.</p>
              </div>
            </div>
          </div>
          <div class="group flex flex-col justify-between p-8 sm:p-10 h-full bg-white rounded-3xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden reveal flex-1">
            <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
            <div class="absolute -bottom-6 -right-4 text-9xl font-black text-black/2 group-hover:text-accent/[0.04] transition-all duration-500 select-none">04</div>
            <div class="relative z-10 flex flex-col h-full justify-between">
              <div>
                <div class="p-3 bg-zinc-50 border border-black/5 w-fit rounded-xl mb-6 group-hover:bg-accent/5 transition-colors">
