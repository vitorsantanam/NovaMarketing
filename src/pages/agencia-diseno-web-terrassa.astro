---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildAlternates } from '../lib/i18n';
import { strapiClient } from '../lib/strapi';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-diseno-web-terrassa/', '/ca/agencia-disseny-web-terrassa/', SITE_URL);

const faqItems = [
  {
    question: "¿Por qué necesita mi empresa de Terrassa una web profesional?",
    answer: "Terrassa es la segunda ciudad más grande del Vallès Occidental y tiene un tejido industrial y comercial muy potente. Pero muchas empresas del polígon de Can Parellada, del Vapor Nord o del centre todavía no tienen una presencia digital a la altura de su negocio. Una web profesional te permite captar clientes que buscan tus servicios en Google, antes de que los encuentren en tu competencia."
  },
  {
    question: "¿Cuánto cuesta diseñar una web para una empresa de Terrassa?",
    answer: "Una web corporativa para una pyme de Terrassa parte desde 1.500€. Un e-commerce completo o una web con funcionalidades avanzadas puede oscilar entre 3.000€ y 8.000€. Trabajamos con empresas de todos los sectores de Terrassa: industriales del polígon de Can Parellada, comercios de la Rambla d'Ègara y del Mercat de la Independència, y despachos profesionales del centre. Adaptamos cada proyecto al presupuesto real."
  },
  {
    question: "¿Qué tipo de web necesita una empresa industrial de Terrassa?",
    answer: "Las empresas industriales y B2B de los polígons de Terrassa —Vapor Nord, Can Parellada, Nord— necesitan webs que transmitan credibilidad, expliquen claramente sus productos o servicios y generen solicitudes de presupuesto online. Una web bien diseñada para el sector industrial de Terrassa puede multiplicar el número de contactos de calidad que recibes desde Google."
  },
  {
    question: "¿Cuánto tiempo tarda diseñar una web para una pyme de Terrassa?",
    answer: "Un proyecto web estándar para una pyme de Terrassa dura entre 3 y 6 semanas. Proyectos más complejos, como tiendas online o webs con integración de ERP para empresas industriales del polígon de Can Parellada, pueden requerir 8-12 semanas. Siempre con seguimiento transparente y un Account Manager dedicado."
  },
  {
    question: "¿Incluís SEO en el diseño de la web para Terrassa?",
    answer: "Sí. Todas las webs que diseñamos para empresas de Terrassa incluyen las bases SEO desde el primer día: estructura semántica, velocidad, datos estructurados y contenidos orientados a las búsquedas de tus clientes en Terrassa y el Vallès Occidental. Esto te da una ventaja en Google desde el lanzamiento, tanto en el centro como en los polígons."
  },
  {
    question: "¿Diseñáis tiendas online para comercios del centre de Terrassa o la Rambla d'Ègara?",
    answer: "Sí. Diseñamos e-commerce para comercios de Terrassa, tanto del centre histórico y la Rambla d'Ègara como de la zona del Mercat de la Independència. Integramos pasarelas de pago, gestión de catálogo y experiencias de compra móvil optimizadas para que tu tienda online llegue a clientes de toda la comarca del Vallès Occidental."
  },
  {
    question: "¿Cómo os diferenciáis de otras agencias de diseño web en Terrassa?",
    answer: "Nos diferenciamos por el enfoque orientado a resultados y el conocimiento local. No solo entregamos una web bonita: diseñamos con el mercado de Terrassa en mente, conocemos el tejido industrial de los polígons, el perfil del consumidor del centre y el ritmo empresarial de la ciudad. Eso nos permite crear webs que realmente funcionan en el mercado local."
  },
  {
    question: "¿Podéis rediseñar la web actual de mi empresa de Terrassa?",
    answer: "Sí. Si tienes una web que no genera resultados, analizamos la experiencia de usuario y el rendimiento para identificar los cuellos de botella. Muchas empresas de Terrassa tienen webs anticuadas que ahuyentan a los clientes. Un rediseño enfocado en conversión puede transformar tu web en una fuente real de negocio, tanto para el sector industrial del Vapor Nord como para los servicios del centre."
  },
  {
    question: "¿Tienen webs especiales para el sector textil e industrial de Terrassa?",
    answer: "Sí. Terrassa tiene una rica tradición industrial, especialmente en el sector textil vinculado al Museu de la Ciència i de la Tècnica. Diseñamos webs para empresas del sector textil, de fabricación y servicios industriales que necesitan modernizar su imagen digital y captar clientes tanto en la comarca como a nivel nacional o internacional."
  },
  {
    question: "¿Funciona el diseño web para empresas de hostelería y restauración de Terrassa?",
    answer: "Sí. La zona del centre de Terrassa, Can Palet y el barrio de Sant Pere tienen una oferta gastronómica creciente. Diseñamos webs para restaurantes, bares y espacios de eventos de Terrassa que quieren captar reservas online directas, reducir su dependencia de plataformas como TripAdvisor o TheFork y mejorar su visibilidad en Google Maps."
  }
];

let webCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('es');
  webCases = casesRes.data
    .map((i: any) => i.attributes ?? i)
    .filter((c: any) => {
      const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
      return cats.some((s: string) => s.includes('web') || s.includes('dise'));
    });
} catch {}

const steps = [
  { title: "Análisis y Estrategia Web en Terrassa", desc: "Estudiamos tu negocio y el mercado local de Terrassa. Tanto si estás en el polígon de Can Parellada, en el centre histórico o en la zona del Vapor Nord, diseñamos una estrategia web orientada a captar los clientes que buscan tus servicios en la ciudad." },
  { title: "Diseño UX Orientado a Conversión", desc: "Creamos diseños con la solidez industrial que caracteriza a Terrassa: funcionales, sin adornos innecesarios y orientados a convertir. Cada pantalla tiene un objetivo claro, como la arquitectura modernista de la ciudad: elegante y eficiente a la vez." },
  { title: "Desarrollo y Maquetación", desc: "Construimos tu web con tecnología moderna y segura, a la altura de la tradición innovadora del sector textil e industrial de Terrassa. Velocidad, estabilidad y escalabilidad para que tu negocio crezca online sin límites." },
  { title: "Optimización SEO y Velocidad", desc: "Antes del lanzamiento, auditamos SEO técnico, velocidad de carga y adaptación móvil. Tu web estará preparada para aparecer en Google cuando alguien en Terrassa, el Mercat de la Independència, Can Palet o los polígons industrials busque lo que vendes." },
  { title: "Lanzamiento y Mejora Continua", desc: "El lanzamiento es el inicio de la relación. Monitorizamos el comportamiento de los usuarios de Terrassa y optimizamos continuamente para que tu web genere más negocio cada mes, sin parar." }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Agencia de Diseño Web para Pymes",
  "provider": {
    "@type": "ProfessionalService",
    "@id": "https://novamarketing.es/#organization",
    "name": "Nova Marketing",
    "image": "https://novamarketing.es/agencia-marketing-pymes-nova-marketing-logo.png",
    "telephone": "+34644738270",
    "priceRange": "€€",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Carrer de la Rutlla 25",
      "addressLocality": "Terrassa",
      "addressRegion": "Barcelona",
      "postalCode": "08221",
      "addressCountry": "ES"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "25"
    }
  },
  "areaServed": {
    "@type": "City",
    "name": "Terrassa",
    "sameAs": "https://www.wikidata.org/wiki/Q15270"
  },
  "description": "Expertos en diseño de páginas web y desarrollo orientado a conversión para pequeñas y medianas empresas en Terrassa. Webs modernas, rápidas y optimizadas para el tejido industrial y comercial de Terrassa.",
  "offers": {
    "@type": "Offer",
    "priceRange": "€€"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Servicios de Diseño y Desarrollo Web",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Diseño Web Corporativo" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Desarrollo de Tiendas Online (E-commerce)" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Optimización de Velocidad y WPO" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Mantenimiento Web y Seguridad" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Rediseño y UX (Experiencia de Usuario)" } }
    ]
  }
};
---

<BaseLayout
  title="Agencia de Diseño Web en Terrassa | Nova Marketing"
  description="Diseñamos páginas web que convierten para empresas de Terrassa. Webs rápidas, orientadas a resultados para el tejido industrial y comercial del Vallès. Solicita presupuesto."
  locale="es"
  alternates={alternates}
  schemas={[serviceSchema, faqSchema]}
>

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[88vh] flex items-center justify-center pt-24 pb-16 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
    <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
    <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>
    <div class="max-w-7xl mx-auto reveal relative z-10">
      <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-6 shadow-sm">
        <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
        Especialistas en Diseño Web en Terrassa
      </span>
      <h1 class="text-4xl sm:text-6xl md:text-7xl lg:text-[5.5rem] uppercase font-black tracking-tighter leading-[0.82] mb-8 text-zinc-900 flex flex-col items-center text-center">
        <span>Agencia de</span>
        <span>Diseño Web en</span>
        <span class="text-mktg-gradient px-4 overflow-visible inline-block">Terrassa</span>
      </h1>
      <p class="text-base sm:text-lg text-zinc-500 font-light leading-relaxed max-w-2xl mx-auto mb-12">
        Diseñamos páginas web que convierten para empresas de Terrassa. Desde las industrias del polígon de Can Parellada hasta los comercios de la Rambla d'Ègara, creamos webs modernas, rápidas y orientadas a captar clientes en el Vallès Occidental.
      </p>
      <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
        <button class="contact-modal-trigger btn-mktg-v5 shadow-[0_20px_40px_-10px_rgba(0,0,0,0.15)] hover:shadow-[0_25px_50px_-12px_rgba(0,0,0,0.25)] hover:-translate-y-1 transition-all duration-300 !py-5 !px-12 !text-[12px] !tracking-wider font-black w-full sm:w-auto">
          SOLICITAR PRESUPUESTO GRATIS
        </button>
      </div>
    </div>
  </section>

  <!-- ═══ LOGOS CLIENTES ═══ -->
  <section class="py-12 border-b border-black/5 bg-zinc-50/40 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <p class="text-[9px] sm:text-[10px] uppercase font-black tracking-widest text-zinc-400 text-center mb-8">Pymes que ya estrenan web con Nova</p>
      <div class="overflow-hidden w-full relative [mask-image:linear-gradient(to_right,transparent,white_10%,white_90%,transparent)]">
        <div id="logos-marquee-web-ter" class="flex items-center gap-16 w-max animate-scroll-logo-web-ter"></div>
      </div>
    </div>
  </section>
  <style>
    @keyframes scrollMarqueeLogoWebTER { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
    .animate-scroll-logo-web-ter { animation: scrollMarqueeLogoWebTER 60s linear infinite; }
  </style>
  <script is:inline>
    (function() {
      var logos = [
        { src: "/clients/bermaq-cliente-novamarketing.webp", alt: "Bermaq" },
        { src: "/clients/cb-lhospitalet-cliente-novamarketing.webp", alt: "CB l'Hospitalet" },
        { src: "/clients/medhs-cliente-novamarketing.webp", alt: "MedHS" },
        { src: "/clients/palacio-del-bebe-cliente-novamarketing.webp", alt: "Palacio del bebé" },
        { src: "/clients/tagtio-cliente-novamarketing.webp", alt: "Tagtio" },
        { src: "/clients/tejados-tapar-cliente-novamarketing.webp", alt: "Tejados Tapar" },
        { src: "/clients/fastpoint-cliente-novamarketing.webp", alt: "FastPoint" },
        { src: "/clients/mundeta-cliente-novamarketing.webp", alt: "Mundeta" },
        { src: "/clients/tattoox-cliente-novamarketing.webp", alt: "TattooX" },
        { src: "/clients/voltura-projects-cliente-novamarketing.webp", alt: "Voltura Projects" }
      ];
      var shuffled = logos.sort(function() { return Math.random() - 0.5; });
      var full = shuffled.concat(shuffled, shuffled, shuffled);
      var c = document.getElementById('logos-marquee-web-ter');
      if (c) c.innerHTML = full.map(function(l) { return '<img src="' + l.src + '" alt="' + l.alt + '" class="h-[50px] w-auto object-contain filter grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-300 pointer-events-none" style="mix-blend-mode:multiply" />'; }).join('');
    })();
  </script>

  <!-- ═══ EXPERTOS EN DISEÑO WEB EN TERRASSA ═══ -->
  <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808005_1px,transparent_1px),linear-gradient(to_bottom,#80808005_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_50%,#000_80%,transparent_100%)]"></div>
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 sm:mb-24 reveal">
        <h2 class="text-3xl sm:text-5xl lg:text-7xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.82]">
          Expertos en Diseño Web<br class="hidden sm:inline" /> en Terrassa
        </h2>
        <p class="text-zinc-500 font-light text-base sm:text-lg leading-relaxed max-w-2xl mx-auto">
          No hacemos webs de plantilla. Diseñamos sitios web pensados para el tejido industrial, comercial y de servicios de Terrassa, orientados a captar al cliente real que busca tu negocio en el Vallès.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 items-stretch">
        {[
          { title: "Webs para el Tejido Industrial de Terrassa", desc: "Las empresas de los polígons de Terrassa —Can Parellada, Vapor Nord, polígon Nord— necesitan webs que generen presupuestos y contactos B2B. Diseñamos con ese objetivo desde el primer día." },
          { title: "Comercios y Servicios del Centre", desc: "Los negocios de la Rambla d'Ègara, el Mercat de la Independència y el centre histórico de Terrassa merecen una web tan cuidada como el entorno modernista en que trabajan." },
          { title: "Rendimiento y Velocidad", desc: "Webs rápidas y optimizadas para el usuario móvil de Terrassa. Una web lenta pierde clientes antes de que lean el primer párrafo: nosotros no nos permitimos ese lujo." },
          { title: "SEO desde el Diseño", desc: "Construimos estructura SEO desde el código para que aparezcas en Google cuando alguien en Terrassa, Can Palet o la zona del Ègara busque tus servicios con intención real de contratar." }
        ].map((s, i) => (
          <div class="group flex flex-col justify-between p-8 sm:p-10 h-full bg-white rounded-3xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden reveal flex-1">
            <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
            <div class="absolute -bottom-6 -right-4 text-9xl font-black text-black/2 group-hover:text-accent/[0.04] transition-all duration-500 select-none">0{i + 1}</div>
            <div class="relative z-10 flex flex-col h-full justify-between">
              <div>
                <div class="p-3 bg-zinc-50 border border-black/5 w-fit rounded-xl mb-6 group-hover:bg-accent/5 transition-colors">
                  <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                </div>
                <h3 class="text-xl sm:text-2xl uppercase mb-3 tracking-tighter group-hover:text-accent font-black text-zinc-900 border-b border-zinc-100 pb-2 w-fit">{s.title}</h3>
                <p class="text-xs sm:text-sm text-zinc-500 leading-relaxed font-light">{s.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ TIMELINE / PROCESO ═══ -->
  <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16 sm:mb-24 reveal">
        <h2 class="text-2xl sm:text-5xl lg:text-7xl font-black tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.85]">
          Cómo diseñamos tu web en Terrassa
        </h2>
        <div class="text-zinc-500 w-[75%] mx-auto font-light text-sm sm:text-base leading-relaxed">
          <p>Cada proyecto web en Terrassa tiene un <strong>Account Manager dedicado</strong> que trabaja con tu equipo en cada fase. Un proceso transparente, con fechas claras y resultados medibles desde el primer día.</p>
        </div>
      </div>
      <div id="timeline-container" class="relative timeline-container">
        <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
        <div class="progress-bar hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100" style="height: 0%;"></div>
        <div class="space-y-16 md:space-y-24 flex flex-col items-center">
          {steps.map((step, index) => (
            <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal" style={`transition-delay: ${index * 100}ms`}>
              <div class="hidden md:block md:flex-1 text-right md:order-1">
                {index % 2 === 0 && (
                  <div class="md:pr-12">
                    <h3 class="text-xl sm:text-2xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{step.title}</h3>
                    <p class="text-sm text-zinc-500 font-light max-w-md ml-auto">{step.desc}</p>
                  </div>
                )}
              </div>
              <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all duration-300">0{index + 1}</div>
              <div class="flex-1 text-left md:order-3">
                <div class="md:pl-12">
                  <h3 class:list={["text-xl sm:text-2xl font-black uppercase tracking-tighter mb-2 text-zinc-900", index % 2 === 0 ? "md:hidden" : ""]}>{step.title}</h3>
                  <p class:list={["text-sm text-zinc-500 font-light max-w-md mr-auto", index % 2 === 0 ? "md:hidden" : ""]}>{step.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
  <style>
    .timeline-container .reveal { opacity: 0; transform: translateY(20px); transition: all 0.6s cubic-bezier(0.165, 0.84, 0.44, 1); }
    .timeline-container .reveal.active { opacity: 1; transform: translateY(0); }
  </style>
  <script is:inline>
    function initTimeline() {
      var timeline = document.getElementById('timeline-container');
      var progressBar = timeline && timeline.querySelector('.progress-bar');
      function updateProgress() {
        if (!timeline || !progressBar) return;
        var rect = timeline.getBoundingClientRect();
        var winHeight = window.innerHeight;
        var topPassed = (winHeight / 2) - rect.top;
        var percentage = Math.max(0, Math.min(100, (topPassed / rect.height) * 100));
        progressBar.style.height = percentage + '%';
        timeline.querySelectorAll('.node-circle').forEach(function(node) {
          if (node.getBoundingClientRect().top < winHeight / 2) { node.classList.add('!border-accent', '!bg-accent', '!text-white'); }
          else { node.classList.remove('!border-accent', '!bg-accent', '!text-white'); }
        });
      }
      window.addEventListener('scroll', updateProgress);
      document.addEventListener('astro:page-load', updateProgress);
      updateProgress();
    }
    document.addEventListener('DOMContentLoaded', initTimeline);
    document.addEventListener('astro:page-load', initTimeline);
  </script>

  <!-- ═══ CONSULTOR DISEÑO WEB ═══ -->
  <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
    <div class="max-w-6xl mx-auto reveal">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
        <div class="md:col-span-5 relative group flex justify-center">
          <div class="absolute inset-0 bg-accent/20 rounded-full blur-3xl opacity-30 group-hover:scale-105 transition-transform duration-500"></div>
          <div class="relative w-full max-w-sm">
            <div class="absolute -top-6 -left-6 w-24 h-24 bg-[radial-gradient(#000000_15%,transparent_15%)] bg-[length:12px_12px] opacity-20"></div>
            <div class="overflow-hidden rounded-[2rem] shadow-[0_30px_60px_-15px_rgba(0,0,0,0.1)] border-4 border-white">
              <img src="/img/consultor-de-seo-en-terrassa.webp" alt="Consultor de Diseño Web en Terrassa" class="w-full h-auto object-cover">
            </div>
            <div class="absolute -bottom-4 -right-4 backdrop-blur-md bg-black/90 text-white px-6 py-4 rounded-xl shadow-xl flex items-center gap-3 border border-white/10">
              <div class="w-2 h-2 bg-accent rounded-full animate-pulse"></div>
              <div class="text-[10px] sm:text-xs font-black uppercase tracking-widest">Diseño Web Terrassa</div>
            </div>
          </div>
        </div>
        <div class="md:col-span-7 text-left">
          <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.4em] text-accent mb-4 block">Diseño y Desarrollo Web</span>
          <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.85]">
            Consultor de Diseño Web en Terrassa
          </h2>
