          Casos de éxito de posicionamiento<br class="hidden md:inline" /> SEO en Sant Cugat
        </h2>
      </div>
      <div class="cases-carousel relative overflow-hidden">
        <div class="cases-track flex gap-6 transition-transform duration-500 ease-in-out">
          {seoCases.map((cs: any, i: number) => {
            const catName = (cs.categories || []).map((c: any) => c.name || c.attributes?.name).filter(Boolean).join(' | ');
            const caseUrl = cs.isPublic && cs.slug ? `/casos-exito/${cs.slug}/` : null;
            return (
              <div class="cases-slide flex-none w-full sm:w-[calc(50%-12px)] lg:w-[calc(25%-18px)] bg-white p-8 border border-black/5 flex flex-col justify-between group hover:shadow-xl hover:-translate-y-1 transition-all duration-300 rounded-2xl">
                <div>
                  {catName && <span class="text-[10px] font-black uppercase tracking-widest text-accent mb-4 block">{catName}</span>}
                  <h3 class="text-base font-black uppercase tracking-tight text-zinc-900 mb-3 group-hover:text-accent transition-colors leading-tight">{cs.title}</h3>
                  <p class="text-xs text-zinc-500 font-light leading-relaxed">{cs.description}</p>
                </div>
                {caseUrl && (
                  <a href={caseUrl} class="mt-6 text-[9px] font-black tracking-[0.25em] text-accent flex items-center gap-1.5 hover:gap-3 transition-all uppercase">
                    VER MÁS <span class="text-sm">→</span>
                  </a>
                )}
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </section>
  )}
  <script is:inline>
    function initCasesCarousel() {
      const track = document.querySelector('.cases-track');
      if (!track) return;
      const slides = track.querySelectorAll('.cases-slide');
      if (slides.length <= 4) return;
      let current = 0;
      const total = slides.length;
      function getVisible() {
        if (window.innerWidth >= 1024) return 4;
        if (window.innerWidth >= 640) return 2;
        return 1;
      }
      function next() {
        const visible = getVisible();
        const maxIndex = total - visible;
        current = current >= maxIndex ? 0 : current + 1;
        const slideWidth = slides[0].offsetWidth + 24;
        track.style.transform = `translateX(-${current * slideWidth}px)`;
      }
      const interval = setInterval(next, 5000);
      document.addEventListener('astro:before-preparation', () => clearInterval(interval));
    }
    document.addEventListener('DOMContentLoaded', initCasesCarousel);
    document.addEventListener('astro:page-load', initCasesCarousel);
  </script>

