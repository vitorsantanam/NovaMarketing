---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildAlternates } from '../lib/i18n';
import { strapiClient } from '../lib/strapi';
import LogoMarquee from '../components/sections/LogoMarquee.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es';
const alternates = buildAlternates('/agencia-seo-en-sant-cugat', '/ca/agencia-seo-a-sant-cugat', SITE_URL);

const faqItems = [
  {
    question: "¿Por qué el SEO en Sant Cugat del Vallès es tan competitivo?",
    answer: "Sant Cugat tiene una economía muy activa con empresas de servicios, tecnología y sector inmobiliario de alto valor. La proximidad a Barcelona y el elevado poder adquisitivo de sus residentes atrae a muchos negocios que compiten por los mismos clientes. Sin una estrategia SEO sólida, tu empresa queda invisible frente a competidores más visibles en Google."
  },
  {
    question: "¿Cómo trabajáis el SEO local para negocios en Can Magí y Mira-sol?",
    answer: "Trabajamos por zonas y barrios dentro de Sant Cugat. Para negocios en Can Magí, Mira-sol o Valldoreix, creamos contenidos y optimizamos fichas locales que apuntan específicamente a esas áreas. El objetivo es que cuando alguien en esa zona busque un servicio como el tuyo, tu negocio aparezca primero."
  },
  {
    question: "¿Cuánto tiempo tarda el SEO en dar resultados en Sant Cugat?",
    answer: "En un mercado tan activo como Sant Cugat, los primeros movimientos en posiciones suelen verse en 3-4 meses. Para sectores muy competitivos como inmobiliario, clínicas o servicios profesionales, el horizonte se sitúa más cerca de 6 meses. La clave es que los resultados se acumulan y son sostenibles en el tiempo."
  },
  {
    question: "¿El SEO es útil para empresas de la zona empresarial de Sant Cugat?",
    answer: "Sin duda. La zona empresarial de Sant Cugat alberga decenas de empresas que buscan clientes y partners en Google. El SEO B2B en Sant Cugat te permite aparecer ante potenciales clientes cuando buscan tus servicios, generando leads de calidad sin depender exclusivamente de la publicidad de pago."
  },
  {
    question: "¿Trabajáis el SEO para clínicas, despachos y servicios profesionales en Sant Cugat?",
    answer: "Sí, son algunos de nuestros clientes más habituales. En Sant Cugat hay una gran demanda de servicios de salud, asesoría fiscal, abogados y coaches. Diseñamos estrategias SEO específicas para cada sector profesional, cumpliendo con las directrices YMYL de Google y posicionando tu despacho o clínica por delante de la competencia."
  }
];

let seoCases: any[] = [];
try {
  const casesRes = await strapiClient.getCaseStudies('es');
  seoCases = casesRes.data
    .map((i: any) => i.attributes ?? i)
    .filter((c: any) => {
      const cats = (c.categories || []).map((cat: any) => (cat.slug || cat.attributes?.slug || '').toLowerCase());
      return cats.some((s: string) => s.includes('seo') || s.includes('consultor'));
    });
} catch {}

const steps = [
  { title: "Auditoría SEO en Sant Cugat", desc: "Analizamos tu presencia digital en el competitivo mercado de Sant Cugat del Vallès. Identificamos los puntos débiles técnicos y las oportunidades de posicionamiento frente a tu competencia local." },
  { title: "Keyword Research de Alto Valor", desc: "Sant Cugat tiene un público de alto poder adquisitivo. Buscamos las keywords que usan los residentes y empresas de Can Magí, Mira-sol y la zona empresarial para encontrar servicios como el tuyo." },
  { title: "SEO On-Page Especializado", desc: "Optimizamos tu web para posicionarte en Sant Cugat del Vallès con contenidos de calidad que conectan con el perfil de cliente local: exigente, informado y con capacidad de decisión." },
  { title: "Linkbuilding de Autoridad", desc: "Construimos enlaces desde medios locales, directorios empresariales y webs de referencia del Vallès para aumentar la relevancia de tu dominio en las búsquedas de Sant Cugat." },
  { title: "SEO Local y Google Maps", desc: "Optimizamos tu Google Business Profile para que aparezcas en el pack local de Sant Cugat cuando potenciales clientes buscan tus servicios en Valldoreix, Can Magí o el centre." }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Agencia de Posicionamiento SEO para Pymes",
  "provider": {
    "@type": "ProfessionalService",
    "@id": "https://novamarketing.es/#organization",
    "name": "Nova Marketing",
    "image": "https://novamarketing.es/agencia-marketing-pymes-nova-marketing-logo.png",
    "telephone": "+34644738270",
    "priceRange": "€€",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Carrer de Bilbao 1",
      "addressLocality": "Sabadell",
      "addressRegion": "Barcelona",
      "postalCode": "08202",
      "addressCountry": "ES"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "20"
    }
  },
  "areaServed": {
    "@type": "City",
    "name": "Sant Cugat del Vallès",
    "sameAs": "https://www.wikidata.org/wiki/Q12260"
  },
  "description": "Expertos en posicionamiento SEO y SEO local para pequeñas y medianas empresas en Sant Cugat del Vallès. Estrategias de posicionamiento orgánico para captar clientes de alto valor en el Parc Tecnològic, el Eix Comercial y Valldoreix.",
  "offers": { "@type": "Offer", "priceRange": "€€" },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Servicios de Posicionamiento SEO",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Auditoría SEO técnica" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Keyword Research local" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "SEO On-Page y contenidos" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Linkbuilding y autoridad de dominio" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "SEO Local y Google Business Profile" }}
    ]
  }
};
---

<BaseLayout
  title="Agencia SEO en Sant Cugat del Vallès | Nova Marketing"
  description="Posicionamos tu empresa en Sant Cugat del Vallès para captar clientes de alto valor. Auditoría SEO gratis. Especialistas en SEO local en Sant Cugat."
  locale="es"
  alternates={alternates}
  schemas={[serviceSchema, faqSchema]}
>

  <!-- ═══ HERO ═══ -->
  <section class="min-h-[88vh] flex items-center justify-center pt-24 pb-16 px-4 sm:px-6 relative overflow-hidden text-center bg-white border-b border-black/5">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_40%,#000_75%,transparent_100%)]"></div>
    <div class="absolute -top-10 left-1/4 w-72 h-72 bg-accent/15 rounded-full blur-3xl opacity-30 animate-pulse"></div>
    <div class="absolute top-20 right-1/4 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl opacity-20"></div>
    <div class="max-w-7xl mx-auto reveal relative z-10">
      <span class="inline-flex items-center gap-2 bg-accent/5 backdrop-blur-sm px-4 py-2 border border-accent/10 rounded-full text-accent text-[8px] sm:text-[10px] font-black uppercase tracking-[0.3em] mb-6 shadow-sm">
        <span class="w-1.5 h-1.5 bg-accent rounded-full animate-ping"></span>
        Especialistas en Posicionamiento SEO en Sant Cugat
      </span>
      <h1 class="text-4xl sm:text-6xl md:text-7xl lg:text-[5.5rem] uppercase font-black tracking-tighter leading-[0.82] mb-8 text-zinc-900 flex flex-col items-center text-center">
        <span>Agencia de</span>
        <span>Posicionamiento SEO</span>
        <span class="text-mktg-gradient px-4 overflow-visible inline-block">en Sant Cugat</span>
      </h1>
      <p class="text-base sm:text-lg text-zinc-500 font-light leading-relaxed max-w-2xl mx-auto mb-12">
        Posicionamos tu empresa en Google para captar clientes de alto valor en Sant Cugat del Vallès. Desde el Eix Comercial y el Parc Tecnològic hasta Valldoreix y la Rambla del Celler, dominamos las búsquedas locales que generan negocio.
      </p>
      <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
        <button class="contact-modal-trigger btn-mktg-v5 shadow-[0_20px_40px_-10px_rgba(0,0,0,0.15)] hover:shadow-[0_25px_50px_-12px_rgba(0,0,0,0.25)] hover:-translate-y-1 transition-all duration-300 !py-5 !px-12 !text-[12px] !tracking-wider font-black w-full sm:w-auto">
          SOLICITAR AUDITORÍA GRATIS
        </button>
      </div>
    </div>
  </section>

  <!-- ═══ LOGOS CLIENTES ═══ -->
  <LogoMarquee />

  <!-- ═══ AUDITORÍA Y ESTRATEGIA ═══ -->
  <section class="py-20 sm:py-32 bg-zinc-50 border-b border-black/5 px-4 sm:px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808005_1px,transparent_1px),linear-gradient(to_bottom,#80808005_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_50%,#000_80%,transparent_100%)]"></div>
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 sm:mb-24 reveal">
        <h2 class="text-3xl sm:text-5xl lg:text-7xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.82]">
          Auditoría y Estrategia <br class="hidden sm:inline" /> SEO en Sant Cugat
        </h2>
        <p class="text-zinc-500 font-light text-base sm:text-lg leading-relaxed max-w-2xl mx-auto">
          Sant Cugat tiene el perfil de cliente más exigente del Vallès. Diseñamos estrategias SEO para captar ese público de alto valor: profesionales, empresas tecnológicas y familias con alto poder adquisitivo.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 items-stretch">
        {[
          { title: "Auditoría Técnica", desc: "Detectamos qué frena tu visibilidad en Sant Cugat: errores de rastreo, velocidad web y problemas de indexación que hacen invisible tu negocio ante el cliente local." },
          { title: "Keywords de Alto Valor", desc: "Analizamos las búsquedas de los usuarios de Can Magí, Mira-sol, Valldoreix y el Parc Tecnològic para posicionar términos con alta intención de compra y ticket elevado." },
          { title: "SEO On-Page", desc: "Optimizamos contenidos que conectan con el perfil de cliente de Sant Cugat: exigente, informado y dispuesto a pagar por calidad y especialización." },
          { title: "Plan de Enlaces", desc: "Construimos autoridad con enlaces de medios locales, colegios profesionales y directorios empresariales del Vallès que posicionan tu dominio como referente en Sant Cugat." }
        ].map((s, i) => (
          <div class="group flex flex-col justify-between p-8 sm:p-10 h-full bg-white rounded-3xl border border-zinc-100/80 shadow-sm hover:shadow-2xl hover:-translate-y-2 hover:border-accent/10 transition-all duration-500 relative overflow-hidden reveal flex-1">
            <div class="absolute inset-x-0 h-1 bottom-0 bg-gradient-to-r from-accent via-accent/90 to-purple-600 w-0 group-hover:w-full transition-all duration-500"></div>
            <div class="absolute -bottom-6 -right-4 text-9xl font-black text-black/2 group-hover:text-accent/[0.04] transition-all duration-500 select-none">0{i + 1}</div>
            <div class="relative z-10 flex flex-col h-full justify-between">
              <div>
                <div class="p-3 bg-zinc-50 border border-black/5 w-fit rounded-xl mb-6 group-hover:bg-accent/5 transition-colors">
                  <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                </div>
                <h3 class="text-xl sm:text-2xl uppercase mb-3 tracking-tighter group-hover:text-accent font-black text-zinc-900 border-b border-zinc-100 pb-2 w-fit">{s.title}</h3>
                <p class="text-xs sm:text-sm text-zinc-500 leading-relaxed font-light">{s.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ TIMELINE ═══ -->
  <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16 sm:mb-24 reveal">
        <h2 class="text-2xl sm:text-5xl lg:text-7xl font-black tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.85]">
          Cómo trabajamos el SEO en Sant Cugat
        </h2>
        <div class="text-zinc-500 w-[75%] mx-auto font-light text-sm sm:text-base leading-relaxed">
          <p>El cliente de Sant Cugat investiga y compara. Contarás con un <strong>Account Manager dedicado</strong> que diseña estrategias a la altura de ese nivel de exigencia y te mantiene informado con métricas de negocio reales, no con vagas promesas.</p>
        </div>
      </div>
      <div id="timeline-container" class="relative timeline-container">
        <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-zinc-200 -translate-x-1/2"></div>
        <div class="progress-bar hidden md:block absolute left-1/2 top-4 w-px bg-accent -translate-x-1/2 transition-all duration-100" style="height: 0%;"></div>
        <div class="space-y-16 md:space-y-24 flex flex-col items-center">
          {steps.map((step, index) => (
            <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full relative reveal" style={`transition-delay: ${index * 100}ms`}>
              <div class="hidden md:block md:flex-1 text-right md:order-1">
                {index % 2 === 0 && (
                  <div class="md:pr-12">
                    <h3 class="text-xl sm:text-2xl font-black uppercase tracking-tighter mb-2 text-zinc-900">{step.title}</h3>
                    <p class="text-sm text-zinc-500 font-light max-w-md ml-auto">{step.desc}</p>
                  </div>
                )}
              </div>
              <div class="md:order-2 w-12 h-12 rounded-full border-2 border-zinc-200 bg-white flex items-center justify-center font-black text-lg z-10 shrink-0 shadow-sm node-circle transition-all duration-300">0{index + 1}</div>
              <div class="flex-1 text-left md:order-3">
                <div class="md:pl-12">
                  <h3 class:list={["text-xl sm:text-2xl font-black uppercase tracking-tighter mb-2 text-zinc-900", index % 2 === 0 ? "md:hidden" : ""]}>{step.title}</h3>
                  <p class:list={["text-sm text-zinc-500 font-light max-w-md mr-auto", index % 2 === 0 ? "md:hidden" : ""]}>{step.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
  <style>
    .timeline-container .reveal { opacity: 0; transform: translateY(20px); transition: all 0.6s cubic-bezier(0.165, 0.84, 0.44, 1); }
    .timeline-container .reveal.active { opacity: 1; transform: translateY(0); }
  </style>
  <script is:inline>
    function initTimeline() {
      const timeline = document.getElementById('timeline-container');
      const progressBar = timeline?.querySelector('.progress-bar');
      function updateProgress() {
        if (!timeline || !progressBar) return;
        const rect = timeline.getBoundingClientRect();
        const winHeight = window.innerHeight;
        const topPassed = (winHeight / 2) - rect.top;
        let percentage = (topPassed / rect.height) * 100;
        percentage = Math.max(0, Math.min(100, percentage));
        progressBar.style.height = `${percentage}%`;
        const nodes = timeline.querySelectorAll('.node-circle');
        nodes.forEach((node) => {
          const nodeTop = node.getBoundingClientRect().top;
          if (nodeTop < winHeight / 2) { node.classList.add('!border-accent', '!bg-accent', '!text-white'); }
          else { node.classList.remove('!border-accent', '!bg-accent', '!text-white'); }
        });
      }
      window.addEventListener('scroll', updateProgress);
      document.addEventListener('astro:page-load', updateProgress);
      updateProgress();
    }
    document.addEventListener('DOMContentLoaded', initTimeline);
    document.addEventListener('astro:page-load', initTimeline);
  </script>

  <!-- ═══ CONSULTOR SEO ═══ -->
  <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
    <div class="max-w-6xl mx-auto reveal">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
        <div class="md:col-span-5 relative group flex justify-center">
          <div class="absolute inset-0 bg-accent/20 rounded-full blur-3xl opacity-30 group-hover:scale-105 transition-transform duration-500"></div>
          <div class="relative w-full max-w-sm">
            <div class="absolute -top-6 -left-6 w-24 h-24 bg-[radial-gradient(#000000_15%,transparent_15%)] bg-[length:12px_12px] opacity-20"></div>
            <div class="overflow-hidden rounded-[2rem] shadow-[0_30px_60px_-15px_rgba(0,0,0,0.1)] border-4 border-white">
              <img src="/img/consultor-seo-en-sant-cugat.webp" alt="Consultor SEO en Sant Cugat" class="w-full h-auto object-cover">
            </div>
            <div class="absolute -bottom-4 -right-4 backdrop-blur-md bg-black/90 text-white px-6 py-4 rounded-xl shadow-xl flex items-center gap-3 border border-white/10">
              <div class="w-2 h-2 bg-accent rounded-full animate-pulse"></div>
              <div class="text-[10px] sm:text-xs font-black uppercase tracking-widest">Estrategia SEO</div>
            </div>
          </div>
        </div>
        <div class="md:col-span-7 text-left">
          <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.4em] text-accent mb-4 block">Posicionamiento Orgánico</span>
          <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.85]">
            Consultor de posicionamiento SEO en Sant Cugat
          </h2>
          <p class="text-zinc-500 font-light text-base sm:text-lg leading-relaxed mb-8">Como consultor experto en SEO en Sant Cugat, diseño estrategias de posicionamiento orgánico para empresas y profesionales del Vallès que quieren captar clientes de alto valor. Conozco el mercado local —desde el Eix Comercial y el Parc Tecnològic hasta Valldoreix y la Rambla del Celler— y construyo visibilidad en Google orientada al perfil exigente del cliente de Sant Cugat.</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="p-6 bg-zinc-50 border border-black/5 rounded-xl hover:bg-zinc-100 transition-colors">
              <div class="text-sm font-black uppercase tracking-wider text-black mb-2">Cliente de Alto Valor</div>
              <p class="text-xs text-zinc-400 font-light">SEO orientado al perfil exigente de Sant Cugat.</p>
            </div>
            <div class="p-6 bg-zinc-50 border border-black/5 rounded-xl hover:bg-zinc-100 transition-colors">
              <div class="text-sm font-black uppercase tracking-wider text-black mb-2">SEO B2B y Profesional</div>
              <p class="text-xs text-zinc-400 font-light">Clínicas, despachos y empresas tecnológicas.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ RENTABILIDAD + STATS + TESTIMONIOS ═══ -->
  <section class="py-20 sm:py-32 bg-white px-4 sm:px-6 relative overflow-hidden border-b border-black/5">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16 sm:mb-24 reveal">
        <h2 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter uppercase mb-6 text-zinc-900 leading-[0.9]">
          Rentabilidad de trabajar el SEO en Sant Cugat
        </h2>
        <p class="text-zinc-500 font-light text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
          El SEO en Sant Cugat tiene un ROI especialmente elevado porque el ticket medio del cliente local es alto. Las empresas que posicionan bien en Google captan clientes de calidad que generan más margen y mayor fidelidad.
        </p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16 reveal text-center">
        <div class="p-8 bg-white rounded-2xl border border-black/5 shadow-sm hover:shadow-xl hover:-translate-y-1 hover:border-accent/10 transition-all duration-300"><div class="text-4xl sm:text-5xl font-black text-accent mb-2 tracking-tighter">+70%</div><div class="text-xs text-zinc-400 font-black tracking-widest uppercase">Tráfico Orgánico</div></div>
        <div class="p-8 bg-white rounded-2xl border border-black/5 shadow-sm hover:shadow-xl hover:-translate-y-1 hover:border-accent/10 transition-all duration-300"><div class="text-4xl sm:text-5xl font-black text-accent mb-2 tracking-tighter">-38%</div><div class="text-xs text-zinc-400 font-black tracking-widest uppercase">Coste por Lead</div></div>
        <div class="p-8 bg-white rounded-2xl border border-black/5 shadow-sm hover:shadow-xl hover:-translate-y-1 hover:border-accent/10 transition-all duration-300"><div class="text-4xl sm:text-5xl font-black text-accent mb-2 tracking-tighter">x3.8</div><div class="text-xs text-zinc-400 font-black tracking-widest uppercase">ROI a 12 Meses</div></div>
        <div class="p-8 bg-white rounded-2xl border border-black/5 shadow-sm hover:shadow-xl hover:-translate-y-1 hover:border-accent/10 transition-all duration-300"><div class="text-4xl sm:text-5xl font-black text-accent mb-2 tracking-tighter">+60%</div><div class="text-xs text-zinc-400 font-black tracking-widest uppercase">Posiciones Top 3</div></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 reveal">
        <div class="bg-zinc-950 text-white p-10 rounded-2xl border border-zinc-800 flex flex-col justify-between group hover:shadow-2xl hover:border-zinc-700 transition-all">
          <div>
            <div class="flex items-center gap-1 mb-6 text-accent">★★★★★</div>
            <p class="font-light text-lg leading-relaxed mb-8">"Nuestra clínica del Eix Comercial de Sant Cugat duplicó las consultas orgánicas desde Google en 5 meses. Nova entiende que el cliente de Sant Cugat busca calidad y especialización antes que precio."</p>
          </div>
          <div>
            <div class="font-black">Clínica especializada, Eix Comercial de Sant Cugat</div>
            <div class="text-[10px] text-zinc-500 uppercase tracking-widest mt-1">Sector: Salud</div>
          </div>
        </div>
        <div class="bg-white p-10 rounded-2xl border border-zinc-100 shadow-sm hover:shadow-xl hover:border-accent/10 hover:-translate-y-1 transition-all flex flex-col justify-between">
          <div>
            <div class="flex items-center gap-1 mb-6 text-accent">★★★★★</div>
            <p class="font-light text-zinc-600 text-lg leading-relaxed mb-8">"El SEO B2B que Nova diseñó para nuestra empresa de software del Parc Tecnològic nos posiciona para búsquedas de decisores. Recibimos demos cualificadas cada semana desde Google."</p>
          </div>
          <div>
            <div class="font-black text-zinc-900">Software B2B, Parc Tecnològic de Sant Cugat</div>
