---
import type { BlogPost } from '../../lib/strapi';
import { getStrapiImageUrl } from '../../lib/strapi';

interface Props {
  post: BlogPost;
  locale: 'es' | 'ca';
}

const { post, locale } = Astro.props;
const prefix = locale === 'ca' ? '/ca' : '';
const blogUrl = `${prefix}/blog/${post.slug}/`;
const imageUrl = getStrapiImageUrl(post.featuredImage ?? post.cover_image) || '/og-default.jpg';
const category = post.category?.name || (post.categories?.[0] as any)?.name || (locale === 'ca' ? 'Sense categoria' : 'Sin categoría');
---

<a href={blogUrl} class="group bg-white border border-zinc-100/80 rounded-3xl overflow-hidden hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 shadow-sm flex flex-col h-full">
  <!-- Image Container -->
  <div class="relative aspect-[16/10] overflow-hidden">
    <img 
      src={imageUrl} 
      alt={post.title}
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
    />
    <div class="absolute top-4 left-4">
      <span class="bg-white/90 backdrop-blur-sm border border-black/5 px-3 py-1.5 rounded-full text-[9px] font-black uppercase tracking-[0.2em] text-accent shadow-sm">
        {category}
      </span>
    </div>
  </div>

  <!-- Content -->
  <div class="p-8 flex flex-col flex-1">
    <h3 class="text-xl sm:text-2xl font-black uppercase tracking-tighter text-zinc-900 mb-4 group-hover:text-accent transition-colors leading-[0.9]">
      {post.title}
    </h3>
    
    <p class="text-zinc-500 font-light text-sm line-clamp-3 mb-8 leading-relaxed">
      {post.excerpt}
    </p>

    <div class="mt-auto pt-4 border-t border-zinc-50">
      <span class="text-[9px] font-black tracking-widest text-accent flex items-center gap-1 group-hover:gap-2 transition-all">
        {locale === 'ca' ? 'LLEGIR MÉS' : 'LEER MÁS'} <span class="text-sm">→</span>
      </span>
    </div>
  </div>
</a>
