---
/**
 * components/global/Breadcrumbs.astro
 * Breadcrumbs accesibles con schema markup integrado
 */
import { breadcrumbSchema } from '../../lib/schema';
import SchemaOrg from '../seo/SchemaOrg.astro';
import type { Locale } from '../../lib/i18n';

interface BreadcrumbItem {
  name: string;
  url?: string;
}

interface Props {
  items: BreadcrumbItem[];
  locale?: Locale;
  siteUrl?: string;
}

const {
  items,
  locale = 'es',
  siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://novamarketing.es',
} = Astro.props;

// Para schema: construir URL completa para cada item
const schemaItems = items.map((item, i) => ({
  name: item.name,
  url: item.url ? `${siteUrl}${item.url}` : `${siteUrl}${Astro.url.pathname}`,
}));

const schema = breadcrumbSchema(schemaItems);
---

<SchemaOrg schema={schema} />

<nav aria-label="Breadcrumb" class="py-3">
  <ol class="flex flex-wrap items-center gap-1 text-sm text-text-muted" itemscope itemtype="https://schema.org/BreadcrumbList">
    {items.map((item, i) => {
      const isLast = i === items.length - 1;
      return (
        <li
          class="flex items-center gap-1"
          itemprop="itemListElement"
          itemscope
          itemtype="https://schema.org/ListItem"
        >
          {!isLast && item.url ? (
            <a
              href={item.url}
              itemprop="item"
              class="hover:text-electric transition-colors"
            >
              <span itemprop="name">{item.name}</span>
            </a>
          ) : (
            <span itemprop="name" class={isLast ? 'text-text-secondary' : ''}>
              {item.name}
            </span>
          )}
          <meta itemprop="position" content={String(i + 1)} />

          {!isLast && (
            <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          )}
        </li>
      );
    })}
  </ol>
</nav>
