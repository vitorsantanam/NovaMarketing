---
/**
 * blocks/CtaBlock.astro
 * CTA adaptado al estilo v2 (Magnetic, Reveal, Minimalist).
 */
interface Props {
  headline?: string;
  subheadline?: string;
  ctaText?: string;
  ctaUrl?: string;
  ctaType?: 'primary' | 'secondary' | 'whatsapp' | 'phone' | 'calendar';
  variant?: 'banner' | 'inline' | 'card';
}

const {
  headline,
  subheadline,
  ctaText = 'Auditoría Gratis',
  ctaUrl = '#contacto',
} = Astro.props;
---

<div class="my-20 reveal text-center py-20 px-10 bg-gray-50/50 border-y border-black/5">
    <span class="section-tag">Empieza hoy</span>
    {headline && <h2 class="font-montserrat text-4xl md:text-6xl uppercase mb-8">{headline}</h2>}
    {subheadline && <p class="text-lg text-gray-500 font-light max-w-2xl mx-auto mb-12">{subheadline}</p>}
    
    <button class="btn-magnetic px-10 py-5 bg-black text-white hover:bg-blue-600 transition-all duration-500 uppercase text-[10px] tracking-[0.3em] font-bold">
        {ctaText}
    </button>
</div>
