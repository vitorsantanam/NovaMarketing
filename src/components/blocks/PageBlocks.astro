---
/**
 * PageBlocks.astro — Renderer de módulos de contenido
 *
 * MÓDULOS DISPONIBLES EN STRAPI:
 * - blocks.rich-text     → Editor de bloques visual
 * - blocks.html          → HTML / Markdown personalizado
 * - blocks.image         → Imagen (normal/wide/full, caption opcional)
 * - blocks.callout       → Caja destacada (dato/atencion/resultado/tip)
 * - blocks.metrics-row   → Fila de KPIs numéricos
 * - blocks.quote         → Cita tipográfica con autor
 * - blocks.cta           → Sección CTA con botón
 * - blocks.two-columns   → Dos columnas de texto
 * - blocks.image-text    → Imagen + texto (imagen izq/der)
 * - blocks.video         → Embed YouTube/Vimeo
 * - blocks.divider       → Separador visual
 * - blocks.gallery       → Galería de imágenes en grid
 * - blocks.timeline      → Proceso paso a paso
 * - blocks.comparison    → Comparativa Antes/Después
 * - blocks.big-stat      → KPI / Estadística grande
 */
import StrapiBlocks from './StrapiBlocks.astro';

interface Props {
  blocks: any[];
}
const { blocks } = Astro.props;

function imgUrl(img: any): string {
  if (!img) return '';
  if (img.url?.startsWith('http')) return img.url;
  return img.url ?? '';
}

function embedUrl(url: string): string {
  if (!url) return '';
  // YouTube
  const yt = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([\w-]+)/);
  if (yt) return `https://www.youtube.com/embed/${yt[1]}`;
  // Vimeo
  const vi = url.match(/vimeo\.com\/(\d+)/);
  if (vi) return `https://player.vimeo.com/video/${vi[1]}`;
  return url;
}
---

<div class="pb-space">
{blocks?.map((block) => (
  <>
    {/* ── HTML personalizado ── */}
    {block.__component === 'blocks.html' && block.content && (
      <div class="pb-html sb-content" set:html={block.content} />
    )}

    {/* ── Rich Text ── */}
    {block.__component === 'blocks.rich-text' && block.content?.length > 0 && (
      <div class="pb-rich-text">
        <StrapiBlocks blocks={block.content} />
      </div>
    )}

    {/* ── Image ── */}
    {block.__component === 'blocks.image' && block.image && (
      <figure class={`pb-image pb-image--${block.size ?? 'normal'}`}>
        <img src={imgUrl(block.image)} alt={block.image.alternativeText ?? ''} loading="lazy" class="pb-img" />
        {block.caption && <figcaption class="pb-figcaption">{block.caption}</figcaption>}
      </figure>
    )}

    {/* ── Callout ── */}
    {block.__component === 'blocks.callout' && (
      <div class={`pb-callout pb-callout--${block.type ?? 'dato'}`}>
        <span class="pb-callout__label">{
          block.type === 'dato' ? 'Dato clave' :
          block.type === 'atencion' ? 'Atención' :
          block.type === 'resultado' ? 'Resultado' :
          'Consejo'
        }</span>
        {block.title && <p class="pb-callout__title">{block.title}</p>}
        <p class="pb-callout__body">{block.content}</p>
      </div>
    )}

    {/* ── Metrics Row ── */}
    {block.__component === 'blocks.metrics-row' && block.items?.length > 0 && (
      <div class="pb-metrics">
        {block.title && <p class="pb-metrics__label">{block.title}</p>}
        <div class={`pb-metrics__grid pb-metrics__grid--${block.items.length <= 2 ? '2' : block.items.length === 3 ? '3' : '4'}`}>
          {block.items.map((item: any) => (
            <div class="pb-metric">
              <span class="pb-metric__value">{item.value}</span>
              <span class="pb-metric__label">{item.label}</span>
            </div>
          ))}
        </div>
      </div>
    )}

    {/* ── Quote ── */}
    {block.__component === 'blocks.quote' && (
      <blockquote class="pb-quote">
        <p class="pb-quote__text">"{block.quote}"</p>
        {(block.author || block.role) && (
          <footer class="pb-quote__footer">
            {block.author && <span class="pb-quote__author">{block.author}</span>}
            {block.role && <span class="pb-quote__role">{block.role}</span>}
          </footer>
        )}
      </blockquote>
    )}

    {/* ── CTA ── */}
    {block.__component === 'blocks.cta' && (
      <div class={`pb-cta pb-cta--${block.style ?? 'dark'}`}>
        {block.headline && <h3 class="pb-cta__headline" set:html={block.headline} />}
        {block.description && <p class="pb-cta__desc">{block.description}</p>}
        {block.open_modal !== false
          ? <button class="pb-cta__btn contact-modal-trigger">{block.button_text ?? 'Contactar'}</button>
          : block.button_url && <a href={block.button_url} class="pb-cta__btn">{block.button_text ?? 'Contactar'}</a>
        }
      </div>
    )}

    {/* ── Two Columns ── */}
    {block.__component === 'blocks.two-columns' && (
      <div class="pb-two-cols">
        <div class="pb-two-cols__col sb-content" set:html={block.left ?? ''} />
        <div class="pb-two-cols__col sb-content" set:html={block.right ?? ''} />
      </div>
    )}

    {/* ── Image + Text ── */}
    {block.__component === 'blocks.image-text' && block.image && (
      <div class={`pb-imgtext pb-imgtext--${block.image_side ?? 'right'}`}>
        <figure class="pb-imgtext__figure">
          <img src={imgUrl(block.image)} alt={block.image.alternativeText ?? ''} loading="lazy" class="pb-img" />
        </figure>
        <div class="pb-imgtext__body sb-content">
          {block.title && <h3 class="pb-imgtext__title">{block.title}</h3>}
          {block.content && <div set:html={block.content} />}
        </div>
      </div>
    )}

    {/* ── Video ── */}
    {block.__component === 'blocks.video' && block.url && (
      <figure class="pb-video">
        <div class="pb-video__wrap">
          <iframe
            src={embedUrl(block.url)}
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
            class="pb-video__iframe"
          />
        </div>
        {block.caption && <figcaption class="pb-figcaption">{block.caption}</figcaption>}
      </figure>
    )}

    {/* ── Divider ── */}
    {block.__component === 'blocks.divider' && (
      <div class={`pb-divider pb-divider--${block.style ?? 'line'}`}>
        {block.style === 'dots' && <span>· · ·</span>}
      </div>
    )}

    {/* ── Gallery ── */}
    {block.__component === 'blocks.gallery' && block.images?.length > 0 && (
      <figure class="pb-gallery">
        <div class={`pb-gallery__grid pb-gallery__grid--${block.columns ?? '3'}`}>
          {block.images.map((img: any) => (
            <div class="pb-gallery__item">
              <img src={imgUrl(img)} alt={img.alternativeText ?? ''} loading="lazy" class="pb-gallery__img" />
            </div>
          ))}
        </div>
        {block.caption && <figcaption class="pb-figcaption">{block.caption}</figcaption>}
      </figure>
    )}

    {/* ── Timeline ── */}
    {block.__component === 'blocks.timeline' && block.steps?.length > 0 && (
      <div class="pb-timeline">
        {block.title && <p class="pb-timeline__label">{block.title}</p>}
        <ol class="pb-timeline__list">
          {block.steps.map((step: any, i: number) => (
            <li class="pb-timeline__item">
              <span class="pb-timeline__num">{String(i + 1).padStart(2, '0')}</span>
              <div class="pb-timeline__body">
                {step.title && <h4 class="pb-timeline__title">{step.title}</h4>}
                {step.desc && <p class="pb-timeline__desc">{step.desc}</p>}
              </div>
            </li>
          ))}
        </ol>
      </div>
    )}

    {/* ── Comparison ── */}
    {block.__component === 'blocks.comparison' && (
      <div class="pb-comparison">
        <div class="pb-comparison__panel pb-comparison__panel--before">
          <span class="pb-comparison__label">{block.before_label ?? 'Antes'}</span>
          <p class="pb-comparison__content">{block.before_content}</p>
        </div>
        <div class="pb-comparison__panel pb-comparison__panel--after">
          <span class="pb-comparison__label">{block.after_label ?? 'Después'}</span>
          <p class="pb-comparison__content">{block.after_content}</p>
        </div>
      </div>
    )}

    {/* ── Big Stat ── */}
    {block.__component === 'blocks.big-stat' && (
      <div class={`pb-bigstat pb-bigstat--${block.color ?? 'black'}`}>
        <span class="pb-bigstat__value">{block.value}</span>
        <span class="pb-bigstat__label">{block.label}</span>
        {block.description && <p class="pb-bigstat__desc">{block.description}</p>}
      </div>
    )}
  </>
))}
</div>

<style>
/* ================================================================
   PageBlocks — Módulos de contenido editorial
   ================================================================ */

.pb-space > * + * {
  margin-top: 3rem;
}

/* ── HTML / sb-content (estilos tipográficos compartidos) ── */
.pb-html,
.sb-content {
  font-family: 'Inter', sans-serif;
  font-size: 1.0625rem;
  line-height: 1.8;
  color: #3f3f46;
}

/* Párrafos */
.pb-html p,
.sb-content p {
  margin: 0 0 1.5rem 0;
}

/* Encabezados */
.pb-html h2, .sb-content h2,
.pb-html h3, .sb-content h3,
.pb-html h4, .sb-content h4 {
  font-family: 'Montserrat', sans-serif;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: -0.02em;
  color: #09090b;
  line-height: 1.15;
  margin: 3rem 0 1rem 0;
}

.pb-html h2, .sb-content h2 {
  font-size: clamp(1.5rem, 3vw, 2rem);
  padding-bottom: 0.75rem;
  border-bottom: 2px solid #09090b;
}

.pb-html h3, .sb-content h3 {
  font-size: clamp(1.125rem, 2vw, 1.375rem);
  padding-left: 0.875rem;
  border-left: 3px solid #3b82f6;
}

.pb-html h4, .sb-content h4 {
  font-size: 0.9375rem;
  letter-spacing: 0.08em;
  color: #3b82f6;
  margin: 2rem 0 0.75rem 0;
}

/* Strong / em */
.pb-html strong, .sb-content strong {
  font-weight: 700;
  color: #09090b;
}

.pb-html em, .sb-content em {
  font-style: italic;
  color: #52525b;
}

/* Listas */
.pb-html ul,
.sb-content ul {
  list-style: none;
  padding: 0;
  margin: 0 0 1.75rem 0;
  display: flex;
  flex-direction: column;
  gap: 0.625rem;
}

.pb-html ul li,
.sb-content ul li {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
  padding: 0.625rem 0.875rem;
  background: #f8f8f8;
  border-radius: 0.625rem;
  border: 1px solid #f0f0f0;
  font-size: 1rem;
  line-height: 1.65;
  color: #3f3f46;
}

.pb-html ul li::before,
.sb-content ul li::before {
  content: '';
  display: inline-block;
  width: 7px;
  height: 7px;
  min-width: 7px;
  border-radius: 50%;
  background: #3b82f6;
  margin-top: 0.55rem;
}

.pb-html ol,
.sb-content ol {
  list-style: none;
  padding: 0;
  margin: 0 0 1.75rem 0;
  counter-reset: ol-counter;
  display: flex;
  flex-direction: column;
  gap: 0.625rem;
}

.pb-html ol li,
.sb-content ol li {
  counter-increment: ol-counter;
  display: flex;
  align-items: flex-start;
  gap: 0.875rem;
  padding: 0.625rem 0.875rem;
  background: #f8f8f8;
  border-radius: 0.625rem;
  border: 1px solid #f0f0f0;
  font-size: 1rem;
  line-height: 1.65;
  color: #3f3f46;
}

.pb-html ol li::before,
.sb-content ol li::before {
  content: counter(ol-counter);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 1.5rem;
  height: 1.5rem;
  border-radius: 50%;
  background: #09090b;
  color: #fff;
  font-family: 'Montserrat', sans-serif;
  font-weight: 900;
  font-size: 0.625rem;
  flex-shrink: 0;
  margin-top: 0.25rem;
}

/* Tablas */
.pb-html table,
.sb-content table {
  width: 100%;
  border-collapse: collapse;
  margin: 2rem 0 2.5rem 0;
  font-size: 0.9375rem;
  border-radius: 0.75rem;
  overflow: hidden;
  box-shadow: 0 2px 20px rgba(0,0,0,0.06);
}

.pb-html thead,
.sb-content thead {
  background: #09090b;
}

.pb-html thead th,
.sb-content thead th {
  padding: 0.875rem 1.25rem;
  text-align: left;
  font-family: 'Montserrat', sans-serif;
  font-weight: 900;
  font-size: 0.625rem;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: #fff;
}

.pb-html tbody tr,
.sb-content tbody tr {
  border-bottom: 1px solid #f0f0f0;
  transition: background 0.15s;
}

.pb-html tbody tr:last-child,
.sb-content tbody tr:last-child {
  border-bottom: none;
}

.pb-html tbody tr:nth-child(even),
.sb-content tbody tr:nth-child(even) {
  background: #fafafa;
}

.pb-html tbody tr:hover,
.sb-content tbody tr:hover {
  background: #eff6ff;
}

.pb-html tbody td,
.sb-content tbody td {
  padding: 0.875rem 1.25rem;
  color: #3f3f46;
  vertical-align: top;
  line-height: 1.6;
}

.pb-html tbody td strong,
.sb-content tbody td strong {
  color: #09090b;
}

/* Blockquote dentro de HTML */
.pb-html blockquote,
.sb-content blockquote {
  margin: 2rem 0;
  padding: 1.25rem 1.5rem;
  border-left: 4px solid #3b82f6;
  background: #eff6ff;
  border-radius: 0 0.5rem 0.5rem 0;
  font-style: italic;
  color: #1e40af;
}

/* Código inline */
.pb-html code,
.sb-content code {
  font-family: 'JetBrains Mono', 'Fira Code', monospace;
  font-size: 0.875em;
  background: #f4f4f5;
  border: 1px solid #e4e4e7;
  padding: 0.125em 0.4em;
  border-radius: 4px;
  color: #09090b;
}

/* ── Rich Text ── */
.pb-rich-text {
  /* heredado de StrapiBlocks */
}

/* ── Image ── */
.pb-image {
  margin: 3rem 0;
}
.pb-image--normal { max-width: 56rem; margin-left: auto; margin-right: auto; }
.pb-image--wide   { max-width: 72rem; margin-left: auto; margin-right: auto; }
.pb-image--full   { width: 100%; }

.pb-img {
  width: 100%;
  display: block;
  border-radius: 1rem;
  box-shadow: 0 30px 80px -15px rgba(0,0,0,0.15);
}
.pb-image--full .pb-img {
  border-radius: 0;
  box-shadow: none;
}

.pb-figcaption {
  text-align: center;
  font-size: 0.8125rem;
  color: #a1a1aa;
  margin-top: 0.875rem;
  font-style: italic;
  font-family: 'Inter', sans-serif;
}

/* ── Callout ── */
.pb-callout {
  padding: 1.5rem 1.75rem;
  border-radius: 10px;
  max-width: 56rem;
  margin: 2.5rem auto;
}
.pb-callout__label {
  display: inline-block;
  font-family: 'Montserrat', sans-serif;
  font-weight: 900;
  font-size: 0.625rem;
  text-transform: uppercase;
  letter-spacing: 0.18em;
  padding: 0.25rem 0.625rem;
  border-radius: 4px;
  margin-bottom: 0.625rem;
}
.pb-callout__title {
  font-family: 'Montserrat', sans-serif;
  font-weight: 900;
  font-size: 1rem;
  margin: 0.375rem 0 0.25rem 0;
  text-transform: uppercase;
  letter-spacing: -0.01em;
}
.pb-callout__body {
  margin: 0;
  font-size: 1rem;
  line-height: 1.7;
  font-weight: 400;
}

/* dato — verde */
.pb-callout--dato { background:#f0fdf4; border:1px solid #bbf7d0; border-left:4px solid #22c55e; }
.pb-callout--dato .pb-callout__label { background:#dcfce7; color:#15803d; }
.pb-callout--dato .pb-callout__title { color:#166534; }
.pb-callout--dato .pb-callout__body  { color:#166534; }

/* atencion — naranja */
.pb-callout--atencion { background:#fff7ed; border:1px solid #fed7aa; border-left:4px solid #f97316; }
.pb-callout--atencion .pb-callout__label { background:#ffedd5; color:#c2410c; }
.pb-callout--atencion .pb-callout__title { color:#7c2d12; }
.pb-callout--atencion .pb-callout__body  { color:#7c2d12; }

/* resultado — negro */
.pb-callout--resultado { background:#09090b; border:1px solid #27272a; border-left:4px solid #3b82f6; }
.pb-callout--resultado .pb-callout__label { background:#3b82f6; color:#fff; }
.pb-callout--resultado .pb-callout__title { color:#fff; }
.pb-callout--resultado .pb-callout__body  { color:#e4e4e7; }

/* tip — azul */
.pb-callout--tip { background:#eff6ff; border:1px solid #bfdbfe; border-left:4px solid #3b82f6; }
.pb-callout--tip .pb-callout__label { background:#dbeafe; color:#1d4ed8; }
.pb-callout--tip .pb-callout__title { color:#1e3a5f; }
.pb-callout--tip .pb-callout__body  { color:#1e3a5f; }

/* ── Metrics Row ── */
.pb-metrics {
  padding: 3rem 2.5rem;
  background: #09090b;
  border-radius: 1.5rem;
  margin: 3rem 0;
}
.pb-metrics__label {
  font-family: 'Montserrat', sans-serif;
  font-weight: 900;
  font-size: 0.6875rem;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  color: #71717a;
  margin: 0 0 2rem 0;
}
.pb-metrics__grid {
  display: grid;
  gap: 2rem;
}
.pb-metrics__grid--2 { grid-template-columns: repeat(2, 1fr); }
.pb-metrics__grid--3 { grid-template-columns: repeat(3, 1fr); }
.pb-metrics__grid--4 { grid-template-columns: repeat(2, 1fr); }

@media (min-width: 768px) {
  .pb-metrics__grid--4 { grid-template-columns: repeat(4, 1fr); }
}

.pb-metric {
  display: flex;
  flex-direction: column;
  gap: 0.375rem;
  padding: 1.5rem;
  border: 1px solid #27272a;
  border-radius: 0.75rem;
  transition: border-color 0.2s;
}
.pb-metric:hover { border-color: #3b82f6; }

.pb-metric__value {
  font-family: 'Montserrat', sans-serif;
  font-weight: 900;
  font-size: clamp(2rem, 4vw, 3rem);
  letter-spacing: -0.04em;
  line-height: 1;
  color: #fff;
}
.pb-metric__label {
  font-size: 0.8125rem;
  color: #71717a;
  font-weight: 400;
  font-family: 'Inter', sans-serif;
}

/* ── Quote ── */
.pb-quote {
  margin: 4rem 0;
  padding: 2.5rem 0;
  border-top: 2px solid #09090b;
  border-bottom: 2px solid #09090b;
  text-align: center;
}
.pb-quote__text {
  font-family: 'Montserrat', sans-serif;
  font-weight: 900;
  font-size: clamp(1.375rem, 3vw, 2.25rem);
  letter-spacing: -0.03em;
  line-height: 1.2;
  color: #09090b;
  text-transform: uppercase;
  margin: 0 0 1.5rem 0;
}
.pb-quote__footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.25rem;
}
.pb-quote__author {
  font-family: 'Montserrat', sans-serif;
  font-weight: 900;
  font-size: 0.875rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: #09090b;
}
.pb-quote__role {
  font-size: 0.8125rem;
  color: #71717a;
  font-family: 'Inter', sans-serif;
}

/* ── CTA ── */
.pb-cta {
  padding: 3.5rem;
  border-radius: 2rem;
  margin: 3rem 0;
  text-align: center;
}
.pb-cta--dark    { background: #09090b; border: 1px solid #27272a; }
.pb-cta--light   { background: #f4f4f5; border: 1px solid #e4e4e7; }
.pb-cta--accent  { background: #3b82f6; }

.pb-cta__headline {
  font-family: 'Montserrat', sans-serif;
  font-weight: 900;
  font-size: clamp(1.375rem, 3vw, 2rem);
  text-transform: uppercase;
  letter-spacing: -0.03em;
  line-height: 1.1;
  margin: 0 0 1rem 0;
}
.pb-cta--dark  .pb-cta__headline { color: #fff; }
.pb-cta--light .pb-cta__headline { color: #09090b; }
.pb-cta--accent .pb-cta__headline { color: #fff; }

.pb-cta__desc {
  font-size: 1rem;
  line-height: 1.6;
  margin: 0 0 2rem 0;
  font-family: 'Inter', sans-serif;
}
.pb-cta--dark  .pb-cta__desc { color: #71717a; }
.pb-cta--light .pb-cta__desc { color: #52525b; }
.pb-cta--accent .pb-cta__desc { color: rgba(255,255,255,0.8); }

.pb-cta__btn {
  display: inline-flex;
  align-items: center;
  font-family: 'Montserrat', sans-serif;
  font-weight: 900;
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  padding: 1.125rem 2.5rem;
  border-radius: 999px;
  border: none;
  cursor: pointer;
  text-decoration: none;
  transition: all 0.2s;
}
.pb-cta--dark .pb-cta__btn    { background: #fff; color: #09090b; }
.pb-cta--dark .pb-cta__btn:hover { background: #3b82f6; color: #fff; }
.pb-cta--light .pb-cta__btn   { background: #09090b; color: #fff; }
.pb-cta--light .pb-cta__btn:hover { background: #3b82f6; color: #fff; }
.pb-cta--accent .pb-cta__btn  { background: #09090b; color: #fff; }
.pb-cta--accent .pb-cta__btn:hover { background: #fff; color: #09090b; }

/* ── Two Columns ── */
.pb-two-cols {
  display: grid;
