---
/** blocks/CaseStudyBlock.astro — Muestra casos de éxito seleccionados o por categoría */
interface Props {
  title?: string;
  headingLevel?: 'h2' | 'h3' | 'h4' | 'p' | 'div';
  displayMode?: 'manual' | 'by_category';
  maxItems?: number;
  // En SSG, las relaciones ya vienen populadas desde Strapi
  caseStudies?: any[];
}

const {
  title,
  headingLevel = 'h2',
  maxItems = 3,
  caseStudies = [],
} = Astro.props;

const Heading = headingLevel;
const displayed = caseStudies.slice(0, maxItems);
---

{displayed.length > 0 && (
  <section class="my-12">
    {title && (
      <Heading class="font-heading font-bold text-2xl text-text-primary mb-8">{title}</Heading>
    )}

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {displayed.map((cs) => (
        <a
          href={`/casos-de-exito/${cs.slug}`}
          class="card card-hover group"
        >
          {cs.featuredImage && (
            <img
              src={cs.featuredImage.url}
              alt={cs.title}
              class="w-full h-40 object-cover rounded-lg mb-4"
              loading="lazy"
            />
          )}
          {cs.clientName && (
            <span class="badge mb-3">{cs.clientName}</span>
          )}
          <h3 class="font-heading font-bold text-text-primary group-hover:text-electric transition-colors mb-2">
            {cs.title}
          </h3>
          {cs.excerpt && (
            <p class="text-sm text-text-secondary line-clamp-2">{cs.excerpt}</p>
          )}
        </a>
      ))}
    </div>
  </section>
)}
