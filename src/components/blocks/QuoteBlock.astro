---
/** blocks/QuoteBlock.astro */
interface Props { quote: string; author?: string; }
const { quote, author } = Astro.props;
---
<blockquote class="my-10 relative">
  <div class="absolute left-0 top-0 bottom-0 w-1 bg-electric rounded-full"></div>
  <div class="pl-6">
    <p class="text-xl font-heading font-semibold text-text-primary italic leading-relaxed">"{quote}"</p>
    {author && <footer class="mt-3 text-sm text-electric font-medium">— {author}</footer>}
  </div>
</blockquote>
