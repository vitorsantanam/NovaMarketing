---
/**
 * components/cta/CtaSticky.astro
 * Barra CTA fija en la parte inferior, solo visible en móvil (< lg)
 * Prioridad: WhatsApp > Llamar
 */
import { t, type Locale } from '../../lib/i18n';
import type { GlobalSettings } from '../../lib/strapi';

interface Props {
  locale?: Locale;
  settings?: GlobalSettings;
}

const { locale = 'es', settings } = Astro.props;
const phone = import.meta.env.PUBLIC_PHONE || settings?.phone || '+34644738270';
const whatsapp = import.meta.env.PUBLIC_WHATSAPP || settings?.whatsapp || '34644738270';
const phoneClean = phone.replace(/\s/g, '');
---

<!-- Solo visible en móvil. body tiene padding-bottom para no tapar contenido -->
<div
  id="cta-sticky"
  class="fixed bottom-0 left-0 right-0 z-50 lg:hidden"
  style="background: rgba(8,8,8,0.95); backdrop-filter: blur(16px); border-top: 1px solid rgba(42,42,42,1); padding: 10px 16px; padding-bottom: calc(10px + env(safe-area-inset-bottom, 0px));"
>
  <div class="flex gap-2 max-w-lg mx-auto">
    <!-- Teléfono (Izquierda) -->
    <a
      href={`tel:${phoneClean}`}
      id="sticky-call"
      class="flex-1 flex items-center justify-center gap-2 py-3.5 text-xs font-black uppercase text-black bg-white/80 hover:bg-white backdrop-blur-md rounded-sm border border-black/5 transition-colors shadow-sm"
      aria-label="Llamar ahora"
    >
      <svg class="w-4 h-4 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
      </svg>
      {t('cta.call', locale)}
    </a>

    <!-- WhatsApp (Derecha) -->
    <a
      href={`https://wa.me/${whatsapp}?text=Hola, me gustaría más información sobre vuestros servicios.`}
      target="_blank"
      rel="noopener noreferrer"
      id="sticky-whatsapp"
      class="flex-1 flex items-center justify-center gap-2 py-3.5 text-xs font-black uppercase text-white bg-[#25D366] hover:bg-[#128C7E] rounded-sm transition-colors shadow-sm"
      aria-label="Contactar por WhatsApp"
    >
      <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
      </svg>
      {t('cta.whatsapp', locale)}
    </a>
  </div>
</div>

<!-- Pop-up WhatsApp Desktop -->
<div class="hidden md:block fixed bottom-6 right-6 z-50">
  <div class="group relative">
    <div class="absolute bottom-full right-0 mb-3 bg-white text-black text-[10px] font-black uppercase py-2 px-4 rounded-sm shadow-[0_10px_30px_rgba(0,0,0,0.1)] border border-black/5 opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none tracking-widest">
       ¿Hablamos?
    </div>
    <a
      href={`https://wa.me/${whatsapp}?text=Hola, me gustaría más información sobre vuestros servicios.`}
      target="_blank"
      rel="noopener noreferrer"
      class="w-14 h-14 bg-[#25D366] hover:bg-[#128C7E] text-white rounded-full flex items-center justify-center shadow-lg transition-transform hover:scale-110 duration-300"
      aria-label="Contactar por WhatsApp"
    >
      <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
      </svg>
    </a>
  </div>
</div>

